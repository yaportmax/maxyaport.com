---
import { navItems, site } from "../lib/site";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="site-header">
  <div class="site-header__inner shell">
    <a class="brand" href="/">maxyaport.com</a>
    <nav class="nav" aria-label="Primary">
      {
        navItems.map((item) => (
          <a href={item.href} aria-current={currentPath.startsWith(item.href) ? "page" : undefined}>
            {item.label}
          </a>
        ))
      }
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle theme">
        <svg class="theme-toggle__moon" aria-hidden="true" viewBox="0 0 24 24" fill="none">
          <path d="M20.5 15.4A8.7 8.7 0 0 1 8.6 3.5 8.8 8.8 0 1 0 20.5 15.4Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
        </svg>
        <svg class="theme-toggle__sun" aria-hidden="true" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8" />
          <path d="M12 2.8V5M12 19v2.2M4.2 4.2l1.6 1.6M18.2 18.2l1.6 1.6M2.8 12H5M19 12h2.2M4.2 19.8l1.6-1.6M18.2 5.8l1.6-1.6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
      </button>
    </nav>
  </div>
</header>
