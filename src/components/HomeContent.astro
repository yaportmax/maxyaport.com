---

<section class="about-page" aria-labelledby="about-title">
  <header class="about-hero">
    <h1 id="about-title" class="about-title">Max Yaport</h1>
    <div class="about-intro" aria-label="Intro">
      <p>Obsessed with running, biking, and the outdoors.</p>
      <p>Spending too much free time exploring AI.</p>
    </div>
  </header>

  <section class="musings-list" aria-labelledby="musings-title">
    <h2 id="musings-title">Posts</h2>
    <RecentList items={recent} />
  </section>

  <section class="about-tabs" aria-label="About details">
    <div class="tab-list" role="tablist" aria-label="About sections">
      <button
        id="tab-work"
        class="tab-button is-active"
        type="button"
        role="tab"
        aria-selected="true"
        aria-controls="panel-work"
        data-about-tab="work"
      >
        Work
      </button>
      <button
        id="tab-races"
        class="tab-button"
        type="button"
        role="tab"
        aria-selected="false"
        aria-controls="panel-races"
        data-about-tab="races"
      >
        Races
      </button>
      <button
        id="tab-travel"
        class="tab-button"
        type="button"
        role="tab"
        aria-selected="false"
        aria-controls="panel-travel"
        data-about-tab="travel"
      >
        Travel
      </button>
    </div>

    <section
      id="panel-work"
      class="tab-panel work-list"
      role="tabpanel"
      aria-labelledby="tab-work"
      data-about-panel="work"
    >
      <div class="work-row">
        <div>
          <p><a href="https://www.magnite.com/">Magnite</a></p>
          <small>Product Manager</small>
        </div>
        <span>2025 - Present</span>
      </div>
      <div class="work-row">
        <div>
          <p><a href="https://pubmatic.com/">PubMatic</a></p>
          <small>Business Operations Manager</small>
        </div>
        <span>2024 - 2025</span>
      </div>
      <div class="work-row">
        <div>
          <p><a href="https://www.pwc.com/">PwC</a></p>
          <small>M&A Valuations Consultant</small>
        </div>
        <span>2022 - 2024</span>
      </div>
      <div class="work-row">
        <div>
          <p><a href="https://www.calpoly.edu/">Cal Poly SLO</a></p>
          <small>Economics & Finance</small>
        </div>
        <span>2018 - 2022</span>
      </div>
    </section>

    <section
      id="panel-races"
      class="tab-panel race-list"
      role="tabpanel"
      aria-labelledby="tab-races"
      data-about-panel="races"
      hidden
    >
      {
        races.map((race) => (
          <div class="race-row">
            <div>
              <p>
                <a href={race.href} target="_blank" rel="noreferrer">
                  {race.title}
                </a>
              </p>
              <small>{race.detail}</small>
            </div>
            <div class="race-result">
              <span>{race.result}</span>
              {race.rank && <small>{race.rank}</small>}
            </div>
          </div>
        ))
      }
    </section>

    <section
      id="panel-travel"
      class="tab-panel travel-list"
      role="tabpanel"
      aria-labelledby="tab-travel"
      data-about-panel="travel"
      hidden
    >
      {
        travel.map((trip) => (
          <div class="travel-row">
            <div>
              <p><a href={`/travel/#${tripSlug(trip.date, trip.title)}`}>{trip.title}</a></p>
              <small>{trip.detail}</small>
            </div>
            <span>{trip.date}</span>
          </div>
        ))
      }
    </section>
  </section>
</section>

<script>
  const tabs = document.querySelectorAll("[data-about-tab]");
  const panels = document.querySelectorAll("[data-about-panel]");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const activeTab = tab.getAttribute("data-about-tab");

      tabs.forEach((item) => {
        const isActive = item === tab;
        item.classList.toggle("is-active", isActive);
        item.setAttribute("aria-selected", String(isActive));
      });

      panels.forEach((panel) => {
        panel.hidden = panel.getAttribute("data-about-panel") !== activeTab;
      });
    });
  });
</script>
