---
import { formatDate } from "../lib/site";

interface RecentItem {
  id: string;
  kind: string;
  title: string;
  description: string;
  date: Date;
  href?: string;
}

interface Props {
  items: RecentItem[];
}

const { items } = Astro.props;
const isExternalHref = (href?: string) => Boolean(href && /^https?:\/\//i.test(href));
---

{
  items.length > 0 ? (
    <div class="list">
      {items.map((item) => (
        <article class="row">
          <div>
            <h3 class="row__title">
              {
                item.href ? (
                  <a
                    href={item.href}
                    target={isExternalHref(item.href) ? "_blank" : undefined}
                    rel={isExternalHref(item.href) ? "noreferrer noopener" : undefined}
                  >
                    {item.title}
                  </a>
                ) : (
                  item.title
                )
              }
            </h3>
            {item.description && <p class="row__description">{item.description}</p>}
          </div>
          <div class="row__meta">
            <time datetime={item.date.toISOString()}>{formatDate(item.date)}</time>
          </div>
        </article>
      ))}
    </div>
  ) : (
    <p class="empty">Nothing here yet.</p>
  )
}
