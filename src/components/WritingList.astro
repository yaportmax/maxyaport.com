---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../lib/site";

interface Props {
  posts: CollectionEntry<"writing">[];
}

const { posts } = Astro.props;
---

{
  posts.length > 0 ? (
    <div class="list">
      {posts.map((post) => (
        <article class="row">
          <div>
            <h3 class="row__title">
              <a href={`/writing/${post.id}/`}>{post.data.title}</a>
            </h3>
            {post.data.description && <p class="row__description">{post.data.description}</p>}
          </div>
          <div class="row__meta">
            <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          </div>
        </article>
      ))}
    </div>
  ) : (
    <p class="empty">No writing published yet.</p>
  )
}
