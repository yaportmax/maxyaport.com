---
import { formatDate } from "../lib/site";
import type { SanityPost } from "../lib/sanity";

interface Props {
  posts: SanityPost[];
}

const { posts } = Astro.props;
const isExternalHref = (href?: string) => Boolean(href && /^https?:\/\//i.test(href));
---

{
  posts.length > 0 ? (
    <div class="list">
      {posts.map((post) => (
        <article class="row">
          <div>
            <h3 class="row__title">
              <a
                href={post.url ?? `/writing/${post.slug}/`}
                target={isExternalHref(post.url) ? "_blank" : undefined}
                rel={isExternalHref(post.url) ? "noreferrer noopener" : undefined}
              >
                {post.title}
              </a>
            </h3>
            {post.description && <p class="row__description">{post.description}</p>}
          </div>
          <div class="row__meta">
            <time datetime={post.date.toISOString()}>{formatDate(post.date)}</time>
          </div>
        </article>
      ))}
    </div>
  ) : (
    <p class="empty">No writing published yet.</p>
  )
}
