---
import BaseLayout from "../layouts/BaseLayout.astro";
import mapData from "../data/travel-map.json";

const monthLookup: Record<string, number> = {
  jan: 0,
  feb: 1,
  mar: 2,
  apr: 3,
  may: 4,
  jun: 5,
  jul: 6,
  aug: 7,
  sep: 8,
  oct: 9,
  nov: 10,
  dec: 11,
};
const sortDate = (date: string) => {
  const normalized = String(date || "").trim();
  const isoMatch = normalized.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (isoMatch) {
    const [, year, month, day] = isoMatch;
    return Date.UTC(Number(year), Number(month) - 1, Number(day));
  }

  const exactMatch = normalized.match(/^([A-Za-z]+)\s+(\d{1,2}),?\s+(\d{4})$/);
  if (exactMatch) {
    const [, month, day, year] = exactMatch;
    const monthIndex = monthLookup[month.slice(0, 3).toLowerCase()] ?? 0;
    return Date.UTC(Number(year), monthIndex, Number(day));
  }

  const monthMatch = normalized.match(/^([A-Za-z]+)\s+(\d{4})$/);
  if (monthMatch) {
    const [, month, year] = monthMatch;
    const monthIndex = monthLookup[month.slice(0, 3).toLowerCase()] ?? 0;
    return Date.UTC(Number(year), monthIndex, 15);
  }

  const year = Number(normalized) || 0;
  return Date.UTC(year, 6, 1);
};
const mapItems = [...mapData.trips, ...mapData.races].sort((a, b) => sortDate(a.date) - sortDate(b.date));
const timelineItems = [...mapItems].reverse();
const activeTimelineItem = timelineItems[0];
const timelineStart = mapItems.length ? sortDate(mapItems[0].date) : Date.UTC(2020, 0, 1);
const timelineEnd = Math.max(
  mapItems.length ? sortDate(mapItems[mapItems.length - 1].date) : Date.UTC(2026, 0, 1),
  Date.now(),
);
const timelineSpan = Math.max(1, timelineEnd - timelineStart);
const timelinePosition = (date: string) => Math.min(95, Math.max(5, ((sortDate(date) - timelineStart) / timelineSpan) * 100));
const startYear = new Date(timelineStart).getUTCFullYear();
const endYear = new Date(timelineEnd).getUTCFullYear();
const timelineYears = Array.from({ length: endYear - startYear + 1 }, (_, index) => startYear + index);
const timelineFocusStart = Date.UTC(2020, 0, 1);
const timelineFocusSpan = Math.max(1, timelineEnd - timelineFocusStart);
const timelineWidth = Math.max(100, Math.min(360, (timelineSpan / timelineFocusSpan) * 100));
const timelineScrollStart = ((timelineFocusStart - timelineStart) / timelineSpan) * timelineWidth;
const serializedMapData = JSON.stringify(mapData).replace(/</g, "\\u003c");
---

<BaseLayout title="Travel">
  <section class="map-page" aria-labelledby="travel-title">
    <header class="map-page__header">
      <p class="eyebrow">travel / races</p>
      <h1 id="travel-title">Map</h1>
    </header>

    <section class="map-stage">
      <div class="map-stage__content">
        <div class="map-legend" aria-label="Map key">
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="flight" aria-pressed="true">
            <i class="map-key-line map-key-line--flight"></i>Flights
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="drive" aria-pressed="true">
            <i class="map-key-line map-key-line--drive"></i>Drives
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="sail" aria-pressed="true">
            <i class="map-key-line map-key-line--sail"></i>Sails
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="train" aria-pressed="true">
            <i class="map-key-line map-key-line--train"></i>Trains
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="strava" aria-pressed="true">
            <i class="map-key-line map-key-line--strava"></i>Strava
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="race" aria-pressed="true">
            <i class="map-key-dot map-key-dot--race"></i>Races
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="stop" aria-pressed="true">
            <i class="map-key-dot map-key-dot--stop"></i>Stops
          </button>
        </div>
        <section class="map-frame" aria-label="Travel and race map">
          <div id="travel-map" class="travel-map"></div>
        </section>

        <section class="map-timeline" aria-label="Travel timeline">
          <div
            class="travel-timeline-rail"
            aria-label="Trip and race years"
            data-travel-timeline-rail
            style={`--timeline-width: ${timelineWidth}%; --timeline-scroll-start: ${timelineScrollStart}%;`}
          >
            <div class="travel-timeline-rail__axis">
              {
                timelineYears.map((year) => (
                  <span class="travel-timeline-rail__year" style={`--x: ${timelinePosition(`Jan ${year}`)}%`}>
                    {year}
                  </span>
                ))
              }
              {
                mapItems.map((item) => (
                  <button
                    type="button"
                    class={`travel-timeline-rail__dot travel-timeline-rail__dot--${item.type}`}
                    style={`--x: ${timelinePosition(item.date)}%`}
                    data-map-timeline-item={item.slug}
                    aria-label={`${item.title}, ${item.date}`}
                  />
                ))
              }
            </div>
          </div>
          <article class="map-timeline__active" data-map-active-card aria-live="polite">
            <div>
              <p data-map-active-title>{activeTimelineItem?.title}</p>
              <small data-map-active-detail>{activeTimelineItem?.detail}</small>
            </div>
            <span data-map-active-date>{activeTimelineItem?.date}</span>
          </article>
        </section>
      </div>

      <section id="route-editor" class="route-editor" aria-label="Route editor" hidden>
        <header class="route-editor__header">
          <div>
            <p class="route-editor__kicker">route editor</p>
            <h2>Trip routes</h2>
          </div>
          <div class="route-editor__actions">
            <button type="button" id="route-editor-close">Close</button>
            <button type="button" id="route-editor-reset">Reset</button>
            <button type="button" id="route-editor-recalculate">Recalculate route</button>
            <button type="button" id="route-editor-save">Save routes</button>
          </div>
        </header>
        <div class="route-editor__status" id="route-editor-status" aria-live="polite"></div>
        <div class="route-editor__grid">
          <div class="route-editor__panel">
            <label class="route-editor__field">
              <span>Trip</span>
              <select id="route-editor-trip"></select>
            </label>
            <form class="route-editor__search" id="route-editor-search">
              <label class="route-editor__field">
                <span>Destination search</span>
                <input id="route-editor-query" type="search" placeholder="Search destination" autocomplete="off" />
              </label>
              <label class="route-editor__field">
                <span>Insert</span>
                <select id="route-editor-insert"></select>
              </label>
              <button type="submit">Find</button>
            </form>
            <div class="route-editor__results" id="route-editor-results"></div>
          </div>
          <div class="route-editor__panel">
            <div class="route-editor__stops-header">
              <span>Stops</span>
              <button type="button" id="route-editor-fit">Fit route</button>
            </div>
            <div class="route-editor__stops" id="route-editor-stops"></div>
          </div>
        </div>
      </section>

    </section>
  </section>

  <script type="application/json" id="travel-map-data" set:html={serializedMapData} />
</BaseLayout>

<script>
  import mapboxgl from "mapbox-gl";
  import "mapbox-gl/dist/mapbox-gl.css";

  const dataElement = document.getElementById("travel-map-data");
  const mapElement = document.getElementById("travel-map");
  const timelineRail = document.querySelector("[data-travel-timeline-rail]");
  const timelineDots = Array.from(document.querySelectorAll("[data-map-timeline-item]"));
  const activeTitleElement = document.querySelector("[data-map-active-title]");
  const activeDetailElement = document.querySelector("[data-map-active-detail]");
  const activeDateElement = document.querySelector("[data-map-active-date]");
  const routeEditorToggle = document.querySelector("[data-route-editor-toggle]");
  const routeEditor = document.getElementById("route-editor");
  const routeEditorTrip = document.getElementById("route-editor-trip");
  const routeEditorStops = document.getElementById("route-editor-stops");
  const routeEditorInsert = document.getElementById("route-editor-insert");
  const routeEditorSearch = document.getElementById("route-editor-search");
  const routeEditorQuery = document.getElementById("route-editor-query");
  const routeEditorResults = document.getElementById("route-editor-results");
  const routeEditorStatus = document.getElementById("route-editor-status");
  const routeEditorSave = document.getElementById("route-editor-save");
  const routeEditorReset = document.getElementById("route-editor-reset");
  const routeEditorClose = document.getElementById("route-editor-close");
  const routeEditorRecalculate = document.getElementById("route-editor-recalculate");
  const routeEditorFit = document.getElementById("route-editor-fit");
  const layerToggleButtons = Array.from(document.querySelectorAll("[data-map-layer-toggle]"));
  const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || "";

  if (!mapElement || !mapboxToken) {
    if (mapElement) mapElement.setAttribute("data-map-empty", "true");
    throw new Error("Travel map needs PUBLIC_MAPBOX_TOKEN.");
  }

  mapboxgl.accessToken = mapboxToken;

  const cloneData = (value) => JSON.parse(JSON.stringify(value));
  const mapData = JSON.parse(dataElement?.textContent || "{\"trips\":[],\"races\":[]}");
  let editorData = cloneData(mapData);
  const allPoints = [...mapData.trips, ...mapData.races];
  const allPointsBySlug = new Map(allPoints.map((point) => [point.slug, point]));
  const timelineSequence = timelineDots
    .map((dot) => allPointsBySlug.get(dot.getAttribute("data-map-timeline-item")))
    .filter(Boolean);
  let activeTimelineSlug = timelineSequence[timelineSequence.length - 1]?.slug || timelineSequence[0]?.slug || "";
  let stopLookupTimeout = 0;
  let stopLookupRequestId = 0;
  let editorDirty = false;
  let editorSaving = false;
  let generatedTripRoutes = null;
  const layerVisibility = {
    flight: true,
    drive: true,
    sail: true,
    train: true,
    strava: true,
    race: true,
    stop: true,
  };

  const isFiniteCoordinate = (node) =>
    Number.isFinite(Number(node?.lat)) && Number.isFinite(Number(node?.lon));

  const showNodeOnMap = (node, defaultValue = true) => {
    if (node?.showOnMap === false) return false;
    if (node?.showOnMap === true) return true;
    return defaultValue;
  };

  const routeNodeFrom = (node, index) => {
    const routeNode = {
      title: node.title || `Stop ${index + 1}`,
      lat: Number(node.lat),
      lon: Number(node.lon),
    };
    if (node.showOnMap === false || node.showOnMap === true) routeNode.showOnMap = node.showOnMap;
    return routeNode;
  };

  const sameRouteCoordinate = (first, second) =>
    isFiniteCoordinate(first) &&
    isFiniteCoordinate(second) &&
    Math.abs(Number(first.lat) - Number(second.lat)) < 0.00001 &&
    Math.abs(Number(first.lon) - Number(second.lon)) < 0.00001;

  const returnNodeForStart = (start, existing = {}) => ({
    title: `Return to ${start.title || "start"}`,
    lat: Number(start.lat),
    lon: Number(start.lon),
    showOnMap: showNodeOnMap(existing, false),
  });

  const routeNodesReturningToStart = (nodes) => {
    if (nodes.length < 2) return nodes;
    const start = nodes[0];
    const finalNode = nodes[nodes.length - 1];
    if (sameRouteCoordinate(start, finalNode)) {
      return [...nodes.slice(0, -1), returnNodeForStart(start, finalNode)];
    }
    return [...nodes, returnNodeForStart(start)];
  };

  const isReturnNode = (trip, index) =>
    Array.isArray(trip?.routeNodes) &&
    trip.routeNodes.length > 2 &&
    index === trip.routeNodes.length - 1 &&
    sameRouteCoordinate(trip.routeNodes[0], trip.routeNodes[index]);

  const hasRoutedTrip = (item) =>
    item.type === "trip" && Array.isArray(item.routeNodes) && item.routeNodes.filter(isFiniteCoordinate).length >= 2;

  const pointProperties = (item) => ({
    type: item.type,
    slug: item.slug,
    title: item.title,
    detail: item.detail,
    date: item.date,
    result: item.result || "",
    rank: item.rank || "",
    href: item.href || "",
    travelMode: item.travelMode || "",
  });

  const visibleMapPoints = allPoints.filter((item) => !hasRoutedTrip(item));

  const featureCollection = {
    type: "FeatureCollection",
    features: visibleMapPoints.map((item) => ({
      type: "Feature",
      geometry: { type: "Point", coordinates: [item.lon, item.lat] },
      properties: pointProperties(item),
    })),
  };

  const normalizedTripNodes = (trip) => {
    const nodes = Array.isArray(trip.routeNodes) ? trip.routeNodes.filter(isFiniteCoordinate) : [];
    if (nodes.length) {
      return routeNodesReturningToStart(
        nodes.map((node, index) => ({
          ...routeNodeFrom(node, index),
          title: node.title || (index === nodes.length - 1 ? trip.title : `Node ${index + 1}`),
        })),
      );
    }
    if (isFiniteCoordinate(trip)) {
      return [{ title: trip.title, lat: Number(trip.lat), lon: Number(trip.lon) }];
    }
    return [];
  };

  const tripNodeMap = (sourceData) =>
    new Map((sourceData.trips || []).map((trip) => [trip.slug, normalizedTripNodes(trip)]));
  let tripNodesBySlug = tripNodeMap(mapData);

  const sanitizedCoordinates = (coordinates) => {
    if (!Array.isArray(coordinates)) return [];
    return coordinates
      .filter((coord) => Array.isArray(coord) && Number.isFinite(Number(coord[0])) && Number.isFinite(Number(coord[1])))
      .map((coord) => [Number(coord[0]), Number(coord[1])]);
  };

  const toRadians = (degrees) => (degrees * Math.PI) / 180;
  const toDegrees = (radians) => (radians * 180) / Math.PI;

  const greatCircleCoordinates = (start, end, steps = 72) => {
    const lng1 = toRadians(start[0]);
    const lat1 = toRadians(start[1]);
    const lng2 = toRadians(end[0]);
    const lat2 = toRadians(end[1]);
    const delta =
      2 *
      Math.asin(
        Math.sqrt(
          Math.sin((lat2 - lat1) / 2) ** 2 +
            Math.cos(lat1) * Math.cos(lat2) * Math.sin((lng2 - lng1) / 2) ** 2,
        ),
      );

    if (!Number.isFinite(delta) || delta === 0) return [start, end];

    const coordinates = [];
    for (let index = 0; index <= steps; index += 1) {
      const fraction = index / steps;
      const a = Math.sin((1 - fraction) * delta) / Math.sin(delta);
      const b = Math.sin(fraction * delta) / Math.sin(delta);
      const x = a * Math.cos(lat1) * Math.cos(lng1) + b * Math.cos(lat2) * Math.cos(lng2);
      const y = a * Math.cos(lat1) * Math.sin(lng1) + b * Math.cos(lat2) * Math.sin(lng2);
      const z = a * Math.sin(lat1) + b * Math.sin(lat2);
      let lon = toDegrees(Math.atan2(y, x));
      const lat = toDegrees(Math.atan2(z, Math.sqrt(x * x + y * y)));

      const previous = coordinates[coordinates.length - 1]?.[0];
      if (Number.isFinite(previous)) {
        while (lon - previous > 180) lon -= 360;
        while (lon - previous < -180) lon += 360;
      }

      coordinates.push([Number(lon.toFixed(5)), Number(lat.toFixed(5))]);
    }
    return coordinates;
  };

  const segmentConfigForTrip = (trip, index) =>
    Array.isArray(trip.routeSegments) && trip.routeSegments[index] ? trip.routeSegments[index] : {};

  const segmentModeForTrip = (trip, index) => {
    const configuredMode = segmentConfigForTrip(trip, index).mode || trip.travelMode || "drive";
    if (configuredMode === "flight" || configuredMode === "sail" || configuredMode === "train") return configuredMode;
    return "drive";
  };

  const segmentCoordinates = (trip, nodes, index) => {
    const config = segmentConfigForTrip(trip, index);
    const configuredCoordinates = sanitizedCoordinates(config.coordinates);
    if (configuredCoordinates.length > 1) return configuredCoordinates;

    const start = [nodes[index].lon, nodes[index].lat];
    const end = [nodes[index + 1].lon, nodes[index + 1].lat];
    return ["flight", "sail", "train"].includes(segmentModeForTrip(trip, index))
      ? greatCircleCoordinates(start, end)
      : [start, end];
  };

  const createTripRouteCollections = (sourceData = mapData) => {
    const routeFeatures = [];
    const nodeFeatures = [];

    for (const trip of sourceData.trips || []) {
      const nodes = normalizedTripNodes(trip);
      const baseMode = trip.travelMode === "flight" ? "flight" : "drive";

      nodes.forEach((node, index) => {
        if (!showNodeOnMap(node)) return;
        nodeFeatures.push({
          type: "Feature",
          geometry: { type: "Point", coordinates: [node.lon, node.lat] },
          properties: {
            slug: trip.slug,
            title: trip.title,
            nodeTitle: node.title,
            nodeIndex: index,
            mode: index > 0 ? segmentModeForTrip(trip, index - 1) : baseMode,
            showOnMap: true,
          },
        });
      });

      for (let index = 0; index < nodes.length - 1; index += 1) {
        const mode = segmentModeForTrip(trip, index);
        const coordinates = segmentCoordinates(trip, nodes, index);
        if (coordinates.length < 2) continue;

        routeFeatures.push({
          type: "Feature",
          geometry: { type: "LineString", coordinates },
          properties: {
            slug: trip.slug,
            title: trip.title,
            mode,
            segmentIndex: index,
          },
        });
      }
    }

    return {
      routes: { type: "FeatureCollection", features: routeFeatures },
      nodes: { type: "FeatureCollection", features: nodeFeatures },
    };
  };

  let tripRouteCollections = createTripRouteCollections(editorData);
  const adventureMapStyle = {
    version: 8,
    glyphs: "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
    sources: {
      "esri-topo": {
        type: "raster",
        tiles: ["https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}"],
        tileSize: 256,
        attribution: "Tiles © Esri — Sources: Esri, USGS, NOAA",
      },
      "esri-hillshade": {
        type: "raster",
        tiles: ["https://server.arcgisonline.com/ArcGIS/rest/services/Elevation/World_Hillshade/MapServer/tile/{z}/{y}/{x}"],
        tileSize: 256,
        attribution: "Hillshade © Esri",
      },
    },
    layers: [
      {
        id: "esri-topo",
        type: "raster",
        source: "esri-topo",
        paint: {
          "raster-saturation": -0.18,
          "raster-contrast": -0.03,
          "raster-brightness-min": 0.03,
          "raster-brightness-max": 0.98,
        },
      },
      {
        id: "esri-hillshade",
        type: "raster",
        source: "esri-hillshade",
        paint: {
          "raster-opacity": 0.12,
          "raster-saturation": -1,
          "raster-contrast": -0.1,
        },
      },
    ],
  };

  const map = new mapboxgl.Map({
    container: mapElement,
    style: adventureMapStyle,
    center: [-42, 28],
    zoom: mapElement.clientWidth < 680 ? 0.45 : 1.15,
    pitch: 0,
    projection: "mercator",
    attributionControl: false,
    scrollZoom: true,
  });

  let wheelZoomFrame = 0;
  let pendingWheelDelta = 0;
  let pendingWheelPoint = null;
  const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
  const wheelDeltaScale = (event) => {
    if (event.deltaMode === WheelEvent.DOM_DELTA_LINE) return 18;
    if (event.deltaMode === WheelEvent.DOM_DELTA_PAGE) return 360;
    return 1;
  };
  const zoomMapFromWheel = () => {
    const delta = pendingWheelDelta;
    const point = pendingWheelPoint;
    pendingWheelDelta = 0;
    pendingWheelPoint = null;
    wheelZoomFrame = 0;
    if (!point || !Number.isFinite(delta)) return;

    const zoomDelta = clamp(-delta / 360, -1.25, 1.25);
    if (!zoomDelta) return;

    map.easeTo({
      zoom: clamp(map.getZoom() + zoomDelta, map.getMinZoom(), map.getMaxZoom()),
      around: map.unproject(point),
      duration: 120,
      essential: true,
    });
  };
  mapElement.addEventListener(
    "wheel",
    (event) => {
      event.preventDefault();
      event.stopPropagation();
      const rect = mapElement.getBoundingClientRect();
      pendingWheelDelta += event.deltaY * wheelDeltaScale(event);
      pendingWheelPoint = [event.clientX - rect.left, event.clientY - rect.top];
      if (!wheelZoomFrame) wheelZoomFrame = window.requestAnimationFrame(zoomMapFromWheel);
    },
    { passive: false, capture: true },
  );

  map.addControl(new mapboxgl.NavigationControl({ visualizePitch: true }), "top-right");

  const popup = new mapboxgl.Popup({
    closeButton: false,
    closeOnClick: true,
    offset: 16,
    className: "map-popup",
  });

  const escapeHtml = (value) =>
    String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");

  const updateActiveSummary = (item) => {
    if (!item) return;
    if (activeTitleElement) activeTitleElement.textContent = item.title || "";
    if (activeDetailElement) activeDetailElement.textContent = item.detail || item.result || "";
    if (activeDateElement) activeDateElement.textContent = item.date || "";
  };

  const popupHtml = (item) => {
    const meta =
      item.type === "race"
        ? [item.result, item.rank].filter(Boolean).map(escapeHtml).join("<br>")
        : escapeHtml(item.detail);
    const title = item.href
      ? `<a href="${escapeHtml(item.href)}">${escapeHtml(item.title)}</a>`
      : escapeHtml(item.title);
    return `<strong>${title}</strong><span>${escapeHtml(item.date)}</span><small>${meta}</small>`;
  };

  const setRouteHighlight = (slug) => {
    const visibleModes = ["flight", "drive", "sail", "train"].filter((mode) => layerVisibility[mode]);
    const filter =
      slug && visibleModes.length
        ? ["all", ["==", ["get", "slug"], slug], ["in", ["get", "mode"], ["literal", visibleModes]]]
        : ["==", ["get", "slug"], ""];
    for (const layerId of ["trip-route-highlight-casing", "trip-route-highlight", "trip-route-node-highlight"]) {
      if (map.getLayer(layerId)) map.setFilter(layerId, filter);
    }
  };

  const fitTripRoute = (item) => {
    const nodes = tripNodesBySlug.get(item.slug) || [];
    if (nodes.length < 2) return false;

    const bounds = new mapboxgl.LngLatBounds();
    nodes.forEach((node) => bounds.extend([node.lon, node.lat]));
    if (bounds.isEmpty()) return false;

    const isCompact = mapElement.clientWidth < 680;
    map.fitBounds(bounds, {
      padding: isCompact ? 58 : { top: 104, bottom: 74, left: 86, right: 86 },
      maxZoom: item.travelMode === "flight" ? 4.7 : 7,
      duration: 850,
    });
    return true;
  };

  const fitRoute = (slug) => {
    const item = [...editorData.trips, ...allPoints].find((point) => point.slug === slug);
    return item ? fitTripRoute(item) : false;
  };

  const routeAnchorCoordinate = (slug) => {
    const routeCoordinates = (tripRouteCollections.routes.features || [])
      .filter((feature) => feature.properties?.slug === slug)
      .flatMap((feature) => sanitizedCoordinates(feature.geometry?.coordinates));

    if (routeCoordinates.length) return routeCoordinates[Math.floor(routeCoordinates.length / 2)];

    const nodes = tripNodesBySlug.get(slug) || [];
    const node = nodes[Math.floor(nodes.length / 2)];
    return node ? [node.lon, node.lat] : null;
  };

  const popupCoordinateForItem = (item, preferredCoordinate = null) => {
    if (Array.isArray(preferredCoordinate) && preferredCoordinate.length >= 2) return preferredCoordinate;
    if (item.type === "trip" && hasRoutedTrip(item)) return routeAnchorCoordinate(item.slug) || [item.lon, item.lat];
    return [item.lon, item.lat];
  };

  const fitOverview = () => {
    const bounds = new mapboxgl.LngLatBounds();
    visibleMapPoints.forEach((item) => bounds.extend([item.lon, item.lat]));
    for (const nodes of tripNodesBySlug.values()) {
      nodes.forEach((node) => bounds.extend([node.lon, node.lat]));
    }
    if (bounds.isEmpty()) return;

    map.fitBounds(bounds, {
      padding: mapElement.clientWidth < 680 ? 22 : { top: 68, bottom: 44, left: 42, right: 42 },
      maxZoom: mapElement.clientWidth < 680 ? 1.1 : 1.75,
      duration: 0,
    });
  };

  const selectItem = (slug, shouldScroll = false, preferredCoordinate = null) => {
    const item = allPoints.find((point) => point.slug === slug);
    if (!item) return;

    activeTimelineSlug = slug;
    updateActiveSummary(item);
    timelineDots.forEach((dot) =>
      dot.classList.toggle("is-active", dot.getAttribute("data-map-timeline-item") === slug),
    );
    if (map.getLayer("map-point-highlight")) {
      map.setFilter("map-point-highlight", ["==", ["get", "slug"], slug]);
    }
    setRouteHighlight(item.type === "trip" ? slug : "");
    updateLayerVisibility();

    if (!fitTripRoute(item)) {
      map.flyTo({ center: [item.lon, item.lat], zoom: item.type === "race" ? 4.2 : 4.8, duration: 850 });
    }
    popup.setLngLat(popupCoordinateForItem(item, preferredCoordinate)).setHTML(popupHtml(item)).addTo(map);
  };

  const setVisibility = (layerIds, visible) => {
    layerIds.forEach((layerId) => {
      if (map.getLayer(layerId)) map.setLayoutProperty(layerId, "visibility", visible ? "visible" : "none");
    });
  };

  const visibleRouteModesForSlug = (slug) => {
    const features = (tripRouteCollections.routes.features || []).filter((feature) => feature.properties?.slug === slug);
    if (!features.length) return true;
    return features.some((feature) => layerVisibility[feature.properties?.mode || "drive"] !== false);
  };

  const updateLayerVisibility = () => {
    const activeItem = allPoints.find((point) => point.slug === activeTimelineSlug);
    if (activeItem?.type === "trip") setRouteHighlight(activeTimelineSlug);

    setVisibility(["trip-routes-flight"], layerVisibility.flight);
    setVisibility(["trip-routes-drive"], layerVisibility.drive);
    setVisibility(["trip-routes-sail"], layerVisibility.sail);
    setVisibility(["trip-routes-train"], layerVisibility.train);
    setVisibility(["trip-route-nodes"], layerVisibility.stop);
    setVisibility(["strava-routes-heat", "strava-routes"], layerVisibility.strava);
    setVisibility(["map-points", "map-point-labels"], layerVisibility.race);
    setVisibility(["map-point-highlight"], layerVisibility.race && Boolean(activeTimelineSlug));
    setVisibility(["trip-route-highlight-casing", "trip-route-highlight"], Boolean(activeTimelineSlug) && visibleRouteModesForSlug(activeTimelineSlug));
    setVisibility(["trip-route-node-highlight"], layerVisibility.stop && Boolean(activeTimelineSlug));

    layerToggleButtons.forEach((button) => {
      const key = button.getAttribute("data-map-layer-toggle");
      const visible = layerVisibility[key] !== false;
      button.setAttribute("aria-pressed", String(visible));
      button.classList.toggle("is-muted", !visible);
    });
  };

  const bindPointerLayer = (layerId) => {
    map.on("mouseenter", layerId, () => {
      map.getCanvas().style.cursor = "pointer";
    });
    map.on("mouseleave", layerId, () => {
      map.getCanvas().style.cursor = "";
    });
  };

  const routeFeatureKey = (feature) =>
    `${feature.properties?.slug || ""}:${Number(feature.properties?.segmentIndex ?? -1)}`;

  const renderedRouteCollection = (fallbackRoutes, previewSlug = "") => {
    if (!generatedTripRoutes?.features?.length) return fallbackRoutes;

    const previewingSlug = previewSlug && editorDirty ? previewSlug : "";
    const generatedFeatures = generatedTripRoutes.features.filter(
      (feature) => feature.properties?.slug !== previewingSlug,
    );
    const generatedKeys = new Set(generatedFeatures.map(routeFeatureKey));
    const fallbackFeatures = fallbackRoutes.features.filter(
      (feature) => feature.properties?.slug === previewingSlug || !generatedKeys.has(routeFeatureKey(feature)),
    );

    return { type: "FeatureCollection", features: [...generatedFeatures, ...fallbackFeatures] };
  };

  const refreshRouteSources = (previewSlug = "") => {
    tripNodesBySlug = tripNodeMap(editorData);
    const fallbackCollections = createTripRouteCollections(editorData);
    tripRouteCollections = {
      routes: renderedRouteCollection(fallbackCollections.routes, previewSlug),
      nodes: fallbackCollections.nodes,
    };

    const routeSource = map.getSource("trip-routes");
    if (routeSource && "setData" in routeSource) routeSource.setData(tripRouteCollections.routes);

    const nodeSource = map.getSource("trip-route-nodes");
    if (nodeSource && "setData" in nodeSource) nodeSource.setData(tripRouteCollections.nodes);
  };

  const loadGeneratedTripRoutes = async ({ bustCache = false } = {}) => {
    const path = bustCache ? `/data/trip-routes.geojson?t=${Date.now()}` : "/data/trip-routes.geojson";
    const response = await fetch(path, { cache: "no-store" }).catch(() => null);
    if (!response?.ok) return;

    const routes = await response.json().catch(() => null);
    if (!routes?.features?.length) return;

    generatedTripRoutes = routes;
    refreshRouteSources(routeEditorTrip?.value || "");
    updateLayerVisibility();
  };

  const loadTripRoutes = () => {
    if (!tripRouteCollections.routes.features.length) return;

    map.addSource("trip-routes", { type: "geojson", data: tripRouteCollections.routes, lineMetrics: true });
    map.addSource("trip-route-nodes", { type: "geojson", data: tripRouteCollections.nodes });
    map.addLayer(
      {
        id: "trip-routes-flight",
        type: "line",
        source: "trip-routes",
        filter: ["==", ["get", "mode"], "flight"],
        layout: { "line-cap": "round", "line-join": "round" },
        paint: {
          "line-color": "#476f4b",
          "line-width": ["interpolate", ["linear"], ["zoom"], 1, 1.1, 6, 2.4],
          "line-opacity": 0.72,
          "line-dasharray": [0.5, 1.8],
        },
      },
      "map-points",
    );
    map.addLayer(
      {
        id: "trip-routes-drive",
        type: "line",
        source: "trip-routes",
        filter: ["==", ["get", "mode"], "drive"],
        layout: { "line-cap": "round", "line-join": "round" },
        paint: {
          "line-color": "#b46d20",
          "line-width": ["interpolate", ["linear"], ["zoom"], 1, 1.25, 6, 3.2],
          "line-opacity": 0.62,
          "line-blur": 0.15,
        },
      },
      "map-points",
    );
    map.addLayer(
      {
        id: "trip-routes-sail",
        type: "line",
        source: "trip-routes",
        filter: ["==", ["get", "mode"], "sail"],
        layout: { "line-cap": "round", "line-join": "round" },
        paint: {
          "line-color": "#2f7f8c",
          "line-width": ["interpolate", ["linear"], ["zoom"], 1, 1.1, 6, 2.8],
          "line-opacity": 0.68,
          "line-dasharray": [1.2, 1.4],
        },
      },
      "map-points",
    );
    map.addLayer(
      {
        id: "trip-routes-train",
        type: "line",
        source: "trip-routes",
        filter: ["==", ["get", "mode"], "train"],
        layout: { "line-cap": "round", "line-join": "round" },
        paint: {
          "line-color": "#736c4f",
          "line-width": ["interpolate", ["linear"], ["zoom"], 1, 1.1, 6, 2.7],
          "line-opacity": 0.7,
          "line-dasharray": [0.25, 1.1],
        },
      },
      "map-points",
    );
    map.addLayer(
      {
        id: "trip-route-highlight-casing",
        type: "line",
        source: "trip-routes",
        filter: ["==", ["get", "slug"], ""],
        layout: { "line-cap": "round", "line-join": "round" },
        paint: {
          "line-color": "#15110c",
          "line-width": ["interpolate", ["linear"], ["zoom"], 1, 4.1, 7, 9.2],
          "line-opacity": 0.84,
          "line-blur": 0.25,
        },
      },
      "map-points",
    );
    map.addLayer(
      {
        id: "trip-route-highlight",
        type: "line",
        source: "trip-routes",
        filter: ["==", ["get", "slug"], ""],
        layout: { "line-cap": "round", "line-join": "round" },
        paint: {
          "line-color": "#ff7a1a",
          "line-width": ["interpolate", ["linear"], ["zoom"], 1, 3.1, 7, 7.2],
          "line-opacity": 0.98,
          "line-blur": 0,
        },
      },
      "map-points",
    );
    map.addLayer(
      {
        id: "trip-route-nodes",
        type: "circle",
        source: "trip-route-nodes",
        paint: {
          "circle-radius": ["interpolate", ["linear"], ["zoom"], 0, 0.45, 2, 0.8, 5, 2.2, 8, 4],
          "circle-color": "#5f7f49",
          "circle-stroke-color": "#fffaf0",
          "circle-stroke-width": ["interpolate", ["linear"], ["zoom"], 0, 0.35, 5, 0.9],
          "circle-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.45, 3, 0.78],
        },
      },
      "map-points",
    );
    map.addLayer(
      {
        id: "trip-route-node-highlight",
        type: "circle",
        source: "trip-route-nodes",
        filter: ["==", ["get", "slug"], ""],
        paint: {
          "circle-radius": ["interpolate", ["linear"], ["zoom"], 0, 1.8, 3, 3.2, 7, 6],
          "circle-color": "rgba(255, 240, 207, 0.18)",
          "circle-stroke-color": "#fff0cf",
          "circle-stroke-width": ["interpolate", ["linear"], ["zoom"], 0, 0.9, 6, 1.6],
        },
      },
      "map-points",
    );

    for (const layerId of ["trip-routes-flight", "trip-routes-drive", "trip-routes-sail", "trip-routes-train", "trip-route-nodes", "trip-route-highlight", "trip-route-highlight-casing"]) {
      map.on("click", layerId, (event) => {
        const slug = event.features?.[0]?.properties?.slug;
        const clickedCoordinate = event.lngLat ? [event.lngLat.lng, event.lngLat.lat] : null;
        if (slug) selectItem(slug, false, clickedCoordinate);
      });
      bindPointerLayer(layerId);
    }
    updateLayerVisibility();
    void loadGeneratedTripRoutes();
  };

  const stravaPopupHtml = (properties) => {
    const miles = Number(properties.distanceMeters || 0) / 1609.344;
    const distance = miles > 0 ? `${miles.toFixed(1)} mi` : "";
    const details = [properties.activityGroup, distance, String(properties.startDate || "").slice(0, 10)]
      .filter(Boolean)
      .join(" / ");
    return `<strong>${escapeHtml(properties.name || "Strava route")}</strong><span>${escapeHtml(details)}</span>`;
  };

  const loadStravaRoutes = async () => {
    const response = await fetch("/data/strava-routes.geojson", { cache: "no-store" }).catch(() => null);
    if (!response?.ok) return;
    const routes = await response.json();
    if (!routes.features?.length) return;

    map.addSource("strava-routes", { type: "geojson", data: routes });
    map.addLayer(
      {
        id: "strava-routes-heat",
        type: "line",
        source: "strava-routes",
        layout: { "line-cap": "round", "line-join": "round" },
        paint: {
          "line-color": "#f36523",
          "line-width": ["interpolate", ["linear"], ["zoom"], 1, 1.6, 8, 5, 12, 9],
          "line-opacity": ["interpolate", ["linear"], ["zoom"], 1, 0.055, 8, 0.075, 12, 0.1],
          "line-blur": ["interpolate", ["linear"], ["zoom"], 1, 0.35, 9, 1.4],
        },
      },
      "map-points",
    );
    map.addLayer(
      {
        id: "strava-routes",
        type: "line",
        source: "strava-routes",
        layout: { "line-cap": "round", "line-join": "round" },
        paint: {
          "line-color": "#f36523",
          "line-width": ["interpolate", ["linear"], ["zoom"], 1, 0.42, 8, 1.6, 12, 3],
          "line-opacity": ["interpolate", ["linear"], ["zoom"], 1, 0.16, 8, 0.24, 12, 0.34],
        },
      },
      "map-points",
    );

    map.on("click", "strava-routes", (event) => {
      const feature = event.features?.[0];
      if (!feature) return;
      popup.setLngLat(event.lngLat).setHTML(stravaPopupHtml(feature.properties || {})).addTo(map);
    });
    bindPointerLayer("strava-routes");
    updateLayerVisibility();
  };

  map.on("style.load", () => {
    map.addSource("map-points", { type: "geojson", data: featureCollection });
    map.addLayer({
      id: "map-points",
      type: "circle",
      source: "map-points",
      paint: {
        "circle-radius": [
          "interpolate",
          ["linear"],
          ["zoom"],
          0,
          ["case", ["==", ["get", "type"], "race"], 2.2, 2],
          2,
          ["case", ["==", ["get", "type"], "race"], 3, 2.7],
          6,
          ["case", ["==", ["get", "type"], "race"], 5.2, 4.6],
        ],
        "circle-color": [
          "case",
          ["==", ["get", "type"], "race"],
          "#b58246",
          ["==", ["get", "travelMode"], "flight"],
          "#476f4b",
          "#b46d20",
        ],
        "circle-stroke-color": "#fffaf0",
        "circle-stroke-width": ["interpolate", ["linear"], ["zoom"], 0, 0.8, 6, 1.6],
        "circle-opacity": 0.92,
      },
    });
    map.addLayer({
      id: "map-point-highlight",
      type: "circle",
      source: "map-points",
      filter: ["==", ["get", "slug"], ""],
      paint: {
        "circle-radius": 10,
        "circle-color": "rgba(255, 255, 255, 0.2)",
        "circle-stroke-color": "#fffaf0",
        "circle-stroke-width": 2,
      },
    });
    try {
      if (map.getStyle()?.glyphs) {
        map.addLayer({
          id: "map-point-labels",
          type: "symbol",
          source: "map-points",
          minzoom: 3,
          layout: {
            "text-field": ["get", "title"],
            "text-size": 12,
            "text-offset": [0, 1.25],
            "text-anchor": "top",
            "text-allow-overlap": false,
          },
          paint: {
            "text-color": "#1f1a13",
            "text-halo-color": "#fff8ea",
            "text-halo-width": 1.2,
          },
        });
      }
    } catch {
      // Labels are optional; routes and interaction should not depend on glyph availability.
    }

    loadTripRoutes();
    loadStravaRoutes();
    fitOverview();
    if (activeTimelineSlug) selectItem(activeTimelineSlug, false);
  });

  map.on("click", "map-points", (event) => {
    const feature = event.features?.[0];
    const slug = feature?.properties?.slug;
    if (slug) selectItem(slug, false);
  });

  map.on("mouseenter", "map-points", () => {
    map.getCanvas().style.cursor = "pointer";
  });

  map.on("mouseleave", "map-points", () => {
    map.getCanvas().style.cursor = "";
  });

  const editorAvailable =
    routeEditor &&
    routeEditorToggle &&
    routeEditorTrip &&
    routeEditorStops &&
    routeEditorInsert &&
    routeEditorSearch &&
    routeEditorQuery &&
    routeEditorResults &&
    routeEditorStatus &&
    routeEditorSave &&
    routeEditorReset &&
    routeEditorClose &&
    routeEditorRecalculate &&
    routeEditorFit &&
    ["localhost", "127.0.0.1", "::1"].includes(window.location.hostname);

  const setEditorStatus = (message = "", tone = "") => {
    if (!routeEditorStatus) return;
    routeEditorStatus.textContent = message;
    routeEditorStatus.setAttribute("data-tone", tone);
  };

  const setEditorBusy = (busy) => {
    editorSaving = busy;
    if (routeEditorSave) routeEditorSave.disabled = busy || !editorDirty;
    if (routeEditorReset) routeEditorReset.disabled = busy || !editorDirty;
    if (routeEditorRecalculate) routeEditorRecalculate.disabled = busy;
  };

  const activeEditorTrip = () =>
    editorData.trips.find((trip) => trip.slug === routeEditorTrip?.value) || editorData.trips[0];

  const normalizeEditorTrip = (trip) => {
    if (!trip) return false;
    const beforeNodes = JSON.stringify(Array.isArray(trip.routeNodes) ? trip.routeNodes : []);
    const beforeSegmentCount = Array.isArray(trip.routeSegments) ? trip.routeSegments.length : 0;
    const nodes = Array.isArray(trip.routeNodes)
      ? trip.routeNodes.filter(isFiniteCoordinate).map(routeNodeFrom)
      : [];

    if (nodes.length < 2 && isFiniteCoordinate(trip)) {
      nodes.push({ title: "Start", lat: Number(trip.lat), lon: Number(trip.lon), showOnMap: true });
      nodes.push({ title: trip.title, lat: Number(trip.lat), lon: Number(trip.lon), showOnMap: true });
    }

    trip.routeNodes = routeNodesReturningToStart(nodes);
    trip.travelMode = trip.travelMode === "flight" ? "flight" : "drive";

    const existingSegments = Array.isArray(trip.routeSegments) ? trip.routeSegments : [];
    trip.routeSegments = Array.from({ length: Math.max(0, trip.routeNodes.length - 1) }, (_, index) => {
      const existing = existingSegments[index] || {};
      return { mode: ["flight", "sail", "train"].includes(existing.mode) ? existing.mode : "drive" };
    });
    return beforeNodes !== JSON.stringify(trip.routeNodes) || beforeSegmentCount !== trip.routeSegments.length;
  };

  const markEditorDirty = (message = "Unsaved changes") => {
    editorDirty = true;
    setEditorStatus(message, "dirty");
    setEditorBusy(false);
    refreshRouteSources(routeEditorTrip?.value || "");
    setRouteHighlight(routeEditorTrip?.value || "");
  };

  const renderTripSelect = () => {
    if (!routeEditorTrip) return;
    const current = routeEditorTrip.value;
    routeEditorTrip.innerHTML = "";
    for (const trip of editorData.trips) {
      const option = document.createElement("option");
      option.value = trip.slug;
      option.textContent = `${trip.date} - ${trip.title}`;
      routeEditorTrip.append(option);
    }
    routeEditorTrip.value = current || editorData.trips[0]?.slug || "";
  };

  const renderInsertOptions = (trip) => {
    if (!routeEditorInsert) return;
    routeEditorInsert.innerHTML = "";
    const insertableNodes = trip.routeNodes.slice(0, Math.max(1, trip.routeNodes.length - 1));
    insertableNodes.forEach((node, index) => {
      const option = document.createElement("option");
      option.value = String(index + 1);
      option.textContent = `After ${node.title || `Stop ${index + 1}`}`;
      routeEditorInsert.append(option);
    });
    routeEditorInsert.value = String(insertableNodes.length);
  };

  const renderEditorStops = () => {
    const trip = activeEditorTrip();
    if (!trip || !routeEditorStops) return;
    const normalizedChanged = normalizeEditorTrip(trip);
    routeEditorStops.innerHTML = "";
    renderInsertOptions(trip);

    trip.routeNodes.forEach((node, index) => {
      if (index > 0) {
        const segment = document.createElement("div");
        segment.className = "route-editor__segment";

        const label = document.createElement("span");
        label.textContent = `${trip.routeNodes[index - 1].title || `Stop ${index}`} to ${node.title || `Stop ${index + 1}`}`;

        const mode = document.createElement("select");
        mode.setAttribute("aria-label", `Mode for leg ${index}`);
        mode.dataset.segmentIndex = String(index - 1);
        for (const value of ["drive", "flight", "sail", "train"]) {
          const option = document.createElement("option");
          option.value = value;
          option.textContent =
            value === "flight" ? "Flight" : value === "sail" ? "Sail" : value === "train" ? "Train" : "Drive";
          mode.append(option);
        }
        mode.value = ["flight", "sail", "train"].includes(trip.routeSegments[index - 1]?.mode)
          ? trip.routeSegments[index - 1].mode
          : "drive";

        segment.append(label, mode);
        routeEditorStops.append(segment);
      }

      const lockedReturnNode = isReturnNode(trip, index);
      const row = document.createElement("div");
      row.className = "route-editor__stop";
      if (lockedReturnNode) row.classList.add("route-editor__stop--return");
      row.dataset.nodeIndex = String(index);

      const marker = document.createElement("span");
      marker.className = "route-editor__stop-index";
      marker.textContent = String(index + 1);

      const title = document.createElement("input");
      title.type = "text";
      title.value = node.title || "";
      title.placeholder = "Stop name";
      title.dataset.nodeField = "title";
      title.setAttribute("aria-label", `Stop ${index + 1} name`);
      title.readOnly = lockedReturnNode;

      const lat = document.createElement("input");
      lat.type = "number";
      lat.step = "0.0001";
      lat.value = String(node.lat);
      lat.dataset.nodeField = "lat";
      lat.setAttribute("aria-label", `Stop ${index + 1} latitude`);
      lat.readOnly = lockedReturnNode;

      const lon = document.createElement("input");
      lon.type = "number";
      lon.step = "0.0001";
      lon.value = String(node.lon);
      lon.dataset.nodeField = "lon";
      lon.setAttribute("aria-label", `Stop ${index + 1} longitude`);
      lon.readOnly = lockedReturnNode;

      const showOnMap = document.createElement("label");
      showOnMap.className = "route-editor__stop-toggle";
      const showOnMapInput = document.createElement("input");
      showOnMapInput.type = "checkbox";
      showOnMapInput.checked = showNodeOnMap(node, !lockedReturnNode);
      showOnMapInput.dataset.nodeField = "showOnMap";
      showOnMapInput.setAttribute("aria-label", `Show stop ${index + 1} on map`);
      const showOnMapText = document.createElement("span");
      showOnMapText.textContent = "Show";
      showOnMap.append(showOnMapInput, showOnMapText);

      const controls = document.createElement("div");
      controls.className = "route-editor__stop-actions";
      for (const [action, labelText] of [
        ["up", "Up"],
        ["down", "Down"],
        ["remove", "Remove"],
      ]) {
        const button = document.createElement("button");
        button.type = "button";
        button.dataset.nodeAction = action;
        button.textContent = labelText;
        button.disabled =
          lockedReturnNode ||
          (action === "up" && index === 0) ||
          (action === "down" && index >= trip.routeNodes.length - 2) ||
          (action === "remove" && trip.routeNodes.length <= 3);
        controls.append(button);
      }

      row.append(marker, title, lat, lon, showOnMap, controls);
      routeEditorStops.append(row);
    });

    if (normalizedChanged && !editorDirty) {
      markEditorDirty("Return to start added; save to keep it");
    }
  };

  const renderRouteEditor = () => {
    if (!editorAvailable) return;
    renderTripSelect();
    renderEditorStops();
    setEditorBusy(editorSaving);
    const trip = activeEditorTrip();
    if (trip) {
      selectItem(trip.slug, false);
      fitRoute(trip.slug);
    }
  };

  const insertStop = (stop, index) => {
    const trip = activeEditorTrip();
    if (!trip) return;
    normalizeEditorTrip(trip);
    const insertIndex = Math.min(Math.max(0, index), Math.max(0, trip.routeNodes.length - 1));
    trip.routeNodes.splice(insertIndex, 0, { ...stop, showOnMap: showNodeOnMap(stop) });
    normalizeEditorTrip(trip);
    renderEditorStops();
    markEditorDirty(`Added ${stop.title}`);
    fitRoute(trip.slug);
  };

  const fetchLocationMatches = async (query) => {
    const trimmed = query.trim();
    if (!trimmed) return [];

    const params = new URLSearchParams({
      access_token: mapboxToken,
      limit: "6",
      types: "poi,address,place,locality,region,country",
    });
    const url = `https://api.mapbox.com/geocoding/v5/mapbox.places/${encodeURIComponent(trimmed)}.json?${params}`;
    const response = await fetch(url);
    if (!response.ok) throw new Error("Destination search failed.");
    const payload = await response.json();
    return Array.isArray(payload.features) ? payload.features : [];
  };

  const locationFromFeature = (feature) => {
    const center = feature?.center || [];
    if (!Number.isFinite(Number(center[0])) || !Number.isFinite(Number(center[1]))) return null;
    return {
      title: feature.text || feature.place_name || "Destination",
      lat: Number(Number(center[1]).toFixed(5)),
      lon: Number(Number(center[0]).toFixed(5)),
      label: feature.place_name || feature.text || "Destination",
    };
  };

  const renderLocationResults = (features, onSelect) => {
    if (!routeEditorResults) return 0;
    routeEditorResults.innerHTML = "";

    let rendered = 0;
    for (const feature of features) {
      const location = locationFromFeature(feature);
      if (!location) continue;
      const button = document.createElement("button");
      button.type = "button";
      button.textContent = location.label;
      button.addEventListener("click", () => onSelect(location));
      routeEditorResults.append(button);
      rendered += 1;
    }
    return rendered;
  };

  const geocodeDestination = async (query) => {
    const trimmed = query.trim();
    if (!trimmed || !routeEditorResults) return;

    setEditorStatus("Searching...", "");
    const features = await fetchLocationMatches(trimmed);

    if (!features.length) {
      setEditorStatus("No matches", "error");
      return;
    }

    const rendered = renderLocationResults(features, (location) => {
        insertStop(
          {
            title: location.title,
            lat: location.lat,
            lon: location.lon,
          },
          Number(routeEditorInsert?.value || activeEditorTrip()?.routeNodes?.length || 0),
        );
        routeEditorResults.innerHTML = "";
        if (routeEditorQuery) routeEditorQuery.value = "";
    });
    setEditorStatus(`${rendered} matches`, rendered ? "" : "error");
  };

  const updateStopFromLocation = (index, location) => {
    const trip = activeEditorTrip();
    if (!trip || !trip.routeNodes[index]) return;

    trip.routeNodes[index] = {
      title: location.title,
      lat: location.lat,
      lon: location.lon,
      showOnMap: showNodeOnMap(trip.routeNodes[index]),
    };
    normalizeEditorTrip(trip);
    renderEditorStops();
    markEditorDirty(`Updated ${location.title}`);
    if (routeEditorResults) routeEditorResults.innerHTML = "";
    fitRoute(trip.slug);
  };

  const geocodeStopName = async (query, index, requestId) => {
    const trimmed = query.trim();
    if (!trimmed || trimmed.length < 3 || !routeEditorResults) return;

    setEditorStatus(`Searching for stop ${index + 1}...`, "");
    const features = await fetchLocationMatches(trimmed);
    if (requestId !== stopLookupRequestId) return;

    if (!features.length) {
      routeEditorResults.innerHTML = "";
      setEditorStatus("No stop matches", "error");
      return;
    }

    const rendered = renderLocationResults(features, (location) => updateStopFromLocation(index, location));
    setEditorStatus(`${rendered} stop matches`, rendered ? "" : "error");
  };

  const scheduleStopNameLookup = (query, index) => {
    window.clearTimeout(stopLookupTimeout);
    stopLookupRequestId += 1;

    if (!query.trim() || query.trim().length < 3) {
      if (routeEditorResults) routeEditorResults.innerHTML = "";
      return;
    }

    const requestId = stopLookupRequestId;
    stopLookupTimeout = window.setTimeout(() => {
      geocodeStopName(query, index, requestId).catch((error) => {
        if (requestId !== stopLookupRequestId) return;
        setEditorStatus(error.message, "error");
      });
    }, 350);
  };

  const roundedRouteCoordinates = (coordinates) =>
    coordinates
      .filter((coord) => Array.isArray(coord) && Number.isFinite(Number(coord[0])) && Number.isFinite(Number(coord[1])))
      .map((coord) => [Number(Number(coord[0]).toFixed(5)), Number(Number(coord[1]).toFixed(5))]);

  const fetchDriveRoute = async (start, end) => {
    const coordinates = `${start.lon},${start.lat};${end.lon},${end.lat}`;
    const params = new URLSearchParams({
      access_token: mapboxToken,
      geometries: "geojson",
      overview: "full",
      alternatives: "false",
    });
    const response = await fetch(`https://api.mapbox.com/directions/v5/mapbox/driving/${coordinates}?${params}`);
    const payload = await response.json().catch(() => ({}));
    if (!response.ok || payload.code !== "Ok" || !payload.routes?.[0]?.geometry?.coordinates?.length) {
      throw new Error(payload.message || payload.code || "Drive route failed.");
    }
    const route = payload.routes[0];
    return {
      coordinates: roundedRouteCoordinates(route.geometry.coordinates),
      distanceMeters: Math.round(Number(route.distance || 0)),
      durationSeconds: Math.round(Number(route.duration || 0)),
    };
  };

  const recalculateActiveTripRoute = async () => {
    const trip = activeEditorTrip();
    if (!trip) return;
    normalizeEditorTrip(trip);
    if (trip.routeNodes.length < 2) {
      setEditorStatus("Add at least two stops first", "error");
      return;
    }

    setEditorBusy(true);
    setEditorStatus("Recalculating route...", "");
    if (routeEditorResults) routeEditorResults.innerHTML = "";

    let routed = 0;
    let flights = 0;
    let sails = 0;
    let trains = 0;
    let failed = 0;

    for (let index = 0; index < trip.routeNodes.length - 1; index += 1) {
      const start = trip.routeNodes[index];
      const end = trip.routeNodes[index + 1];
      const segment = trip.routeSegments[index] || { mode: "drive" };
      const mode = ["flight", "sail", "train"].includes(segment.mode) ? segment.mode : "drive";

      if (mode === "flight" || mode === "sail" || mode === "train") {
        segment.coordinates = greatCircleCoordinates([start.lon, start.lat], [end.lon, end.lat]);
        segment.routeProvider = "great-circle";
        segment.routeProfile = mode;
        delete segment.distanceMeters;
        delete segment.durationSeconds;
        flights += mode === "flight" ? 1 : 0;
        sails += mode === "sail" ? 1 : 0;
        trains += mode === "train" ? 1 : 0;
      } else {
        try {
          const route = await fetchDriveRoute(start, end);
          segment.coordinates = route.coordinates;
          segment.distanceMeters = route.distanceMeters;
          segment.durationSeconds = route.durationSeconds;
          segment.routeProvider = "mapbox-directions";
          segment.routeProfile = "mapbox/driving";
          routed += 1;
        } catch (error) {
          failed += 1;
          segment.coordinates = [
            [start.lon, start.lat],
            [end.lon, end.lat],
          ];
          segment.routeProvider = "fallback";
          segment.routeProfile = "straight-line";
          console.warn(`Route failed for ${start.title} to ${end.title}:`, error);
        }
      }

      trip.routeSegments[index] = segment;
    }

    editorDirty = true;
    refreshRouteSources(trip.slug);
    setRouteHighlight(trip.slug);
    fitRoute(trip.slug);
    renderEditorStops();
    setEditorStatus(
      failed
        ? `Recalculated ${routed} drive leg(s), ${flights} flight leg(s), ${sails} sail leg(s), ${trains} train leg(s); ${failed} failed`
        : `Recalculated ${routed} drive leg(s), ${flights} flight leg(s), ${sails} sail leg(s), ${trains} train leg(s)`,
      failed ? "error" : "dirty",
    );
    setEditorBusy(false);
  };

  const saveRouteEditor = async () => {
    if (!editorDirty || editorSaving) return;
    setEditorBusy(true);
    setEditorStatus("Saving routes...", "");

    const response = await fetch("/api/travel-config/save", {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify(editorData),
    });
    const payload = await response.json().catch(() => ({}));
    if (!response.ok || !payload.ok) {
      throw new Error(payload.error || "Route save failed.");
    }

    editorDirty = false;
    setEditorStatus("Saved routes", "saved");
    setEditorBusy(false);
    await loadGeneratedTripRoutes({ bustCache: true });
    refreshRouteSources("");
    const trip = activeEditorTrip();
    if (trip) {
      setRouteHighlight(trip.slug);
      fitRoute(trip.slug);
    }
  };

  if (editorAvailable) {
    routeEditorToggle.hidden = false;
    routeEditorToggle.setAttribute("aria-expanded", "false");
    const setRouteEditorOpen = (open) => {
      routeEditor.hidden = !open;
      routeEditorToggle.classList.toggle("is-active", open);
      routeEditorToggle.textContent = open ? "Close editor" : "Edit routes";
      routeEditorToggle.setAttribute("aria-expanded", String(open));
      if (open) renderRouteEditor();
    };

    routeEditorToggle.addEventListener("click", () => {
      setRouteEditorOpen(routeEditor.hidden);
    });

    routeEditorClose.addEventListener("click", () => {
      setRouteEditorOpen(false);
    });

    routeEditorTrip.addEventListener("change", () => {
      renderEditorStops();
      const trip = activeEditorTrip();
      if (trip) {
        refreshRouteSources(trip.slug);
        selectItem(trip.slug, false);
        fitRoute(trip.slug);
      }
    });

    routeEditorSearch.addEventListener("submit", (event) => {
      event.preventDefault();
      geocodeDestination(routeEditorQuery.value).catch((error) => {
        setEditorStatus(error.message, "error");
      });
    });

    routeEditorStops.addEventListener("input", (event) => {
      const target = event.target;
      const trip = activeEditorTrip();
      if (!trip || !(target instanceof HTMLInputElement || target instanceof HTMLSelectElement)) return;

      if (target.dataset.nodeField) {
        const row = target.closest("[data-node-index]");
        const nodeIndex = Number(row?.dataset.nodeIndex);
        const node = trip.routeNodes[nodeIndex];
        if (!node) return;
        if (target.dataset.nodeField === "showOnMap") {
          node.showOnMap = target.checked;
          markEditorDirty(target.checked ? "Stop will show on map" : "Stop hidden from map");
          return;
        }
        if (target.dataset.nodeField === "title") {
          node.title = target.value;
          scheduleStopNameLookup(target.value, nodeIndex);
        }
        if (target.dataset.nodeField === "lat") node.lat = Number(target.value);
        if (target.dataset.nodeField === "lon") node.lon = Number(target.value);
        trip.routeNodes = routeNodesReturningToStart(trip.routeNodes.filter(isFiniteCoordinate).map(routeNodeFrom));
        markEditorDirty("Unsaved stop changes");
      }

      if (target.dataset.segmentIndex) {
        const segment = trip.routeSegments[Number(target.dataset.segmentIndex)];
        if (!segment) return;
        segment.mode = ["flight", "sail", "train"].includes(target.value) ? target.value : "drive";
        trip.travelMode = trip.routeSegments.some((item) => item.mode === "flight") ? "flight" : "drive";
        markEditorDirty("Unsaved mode changes");
      }
    });

    routeEditorStops.addEventListener("click", (event) => {
      const button = event.target.closest("[data-node-action]");
      if (!button) return;
      const trip = activeEditorTrip();
      const row = button.closest("[data-node-index]");
      const index = Number(row?.dataset.nodeIndex);
      if (!trip || !Number.isInteger(index)) return;

      if (button.dataset.nodeAction === "remove") {
        trip.routeNodes.splice(index, 1);
      }
      if (button.dataset.nodeAction === "up" && index > 0) {
        [trip.routeNodes[index - 1], trip.routeNodes[index]] = [trip.routeNodes[index], trip.routeNodes[index - 1]];
      }
      if (button.dataset.nodeAction === "down" && index < trip.routeNodes.length - 1) {
        [trip.routeNodes[index], trip.routeNodes[index + 1]] = [trip.routeNodes[index + 1], trip.routeNodes[index]];
      }

      normalizeEditorTrip(trip);
      renderEditorStops();
      markEditorDirty("Unsaved stop changes");
      fitRoute(trip.slug);
    });

    routeEditorSave.addEventListener("click", () => {
      saveRouteEditor().catch((error) => {
        setEditorStatus(error.message, "error");
        setEditorBusy(false);
      });
    });

    routeEditorRecalculate.addEventListener("click", () => {
      recalculateActiveTripRoute().catch((error) => {
        setEditorStatus(error.message, "error");
        setEditorBusy(false);
      });
    });

    routeEditorReset.addEventListener("click", () => {
      editorData = cloneData(mapData);
      editorDirty = false;
      setEditorStatus("Reset", "");
      if (routeEditorResults) routeEditorResults.innerHTML = "";
      renderRouteEditor();
      refreshRouteSources("");
    });

    routeEditorFit.addEventListener("click", () => {
      const trip = activeEditorTrip();
      if (trip) fitRoute(trip.slug);
    });
  }

  timelineDots.forEach((dot) => {
    dot.addEventListener("click", () => selectItem(dot.getAttribute("data-map-timeline-item"), false));
  });

  if (timelineRail) {
    const scrollStart = Number.parseFloat(
      getComputedStyle(timelineRail).getPropertyValue("--timeline-scroll-start"),
    );
    const applyInitialTimelineScroll = () => {
      if (!Number.isFinite(scrollStart)) return;
      timelineRail.scrollLeft = Math.max(0, (timelineRail.scrollWidth * scrollStart) / 100 - 18);
    };
    applyInitialTimelineScroll();
    window.addEventListener("resize", applyInitialTimelineScroll);
  }

  layerToggleButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const key = button.getAttribute("data-map-layer-toggle");
      if (!key || !(key in layerVisibility)) return;
      layerVisibility[key] = !layerVisibility[key];
      if (key === "race" && !layerVisibility.race) {
        const activeItem = allPoints.find((point) => point.slug === activeTimelineSlug);
        if (activeItem?.type === "race") popup.remove();
      }
      updateLayerVisibility();
    });
  });

  updateActiveSummary(timelineSequence[0]);
</script>
