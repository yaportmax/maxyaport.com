  map.on("style.load", () => {
    map.setTerrain({ source: "mapbox-terrain-dem", exaggeration: 1.35 });

    map.setFog({
      color: "rgba(0, 0, 0, 0)",
      "high-color": "rgba(0, 0, 0, 0)",
      "horizon-blend": 0.015,
      "space-color": "rgba(0, 0, 0, 0)",
      "star-intensity": 0,
    });

    map.addSource("map-points", { type: "geojson", data: featureCollection });
    map.addLayer({
      id: "map-points",
      type: "circle",
      source: "map-points",
      paint: {
        "circle-radius": [
          "interpolate",
          ["linear"],
          ["zoom"],
          0,
          ["case", ["==", ["get", "type"], "race"], 2.2, 2],
          2,
          ["case", ["==", ["get", "type"], "race"], 3, 2.7],
          6,
          ["case", ["==", ["get", "type"], "race"], 5.2, 4.6],
        ],
        "circle-color": [
          "case",
          ["==", ["get", "type"], "race"],
          "#b58246",
