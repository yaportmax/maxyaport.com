  const setEditorBusy = (busy) => {
    editorSaving = busy;
    if (routeEditorSave) routeEditorSave.disabled = busy || !editorDirty;
    if (routeEditorReset) routeEditorReset.disabled = busy || !editorDirty;
    if (routeEditorRecalculate) routeEditorRecalculate.disabled = busy;
  };

  const activeEditorTrip = () =>
    editorData.trips.find((trip) => trip.slug === routeEditorTrip?.value) || editorData.trips[0];

  const normalizeEditorTrip = (trip) => {
    if (!trip) return false;
    const beforeNodes = JSON.stringify(Array.isArray(trip.routeNodes) ? trip.routeNodes : []);
    const beforeSegmentCount = Array.isArray(trip.routeSegments) ? trip.routeSegments.length : 0;
    const nodes = Array.isArray(trip.routeNodes)
      ? trip.routeNodes.filter(isFiniteCoordinate).map(routeNodeFrom)
      : [];

    if (nodes.length < 2 && isFiniteCoordinate(trip)) {
      nodes.push({ title: "Start", lat: Number(trip.lat), lon: Number(trip.lon), showOnMap: true });
      nodes.push({ title: trip.title, lat: Number(trip.lat), lon: Number(trip.lon), showOnMap: true });
    }

    trip.routeNodes = routeNodesReturningToStart(nodes);
    trip.travelMode = trip.travelMode === "flight" ? "flight" : "drive";

    const existingSegments = Array.isArray(trip.routeSegments) ? trip.routeSegments : [];
    trip.routeSegments = Array.from({ length: Math.max(0, trip.routeNodes.length - 1) }, (_, index) => {
      const existing = existingSegments[index] || {};
      return { mode: ["flight", "sail"].includes(existing.mode) ? existing.mode : "drive" };
    });
    return beforeNodes !== JSON.stringify(trip.routeNodes) || beforeSegmentCount !== trip.routeSegments.length;
  };

  const markEditorDirty = (message = "Unsaved changes") => {
    editorDirty = true;
    setEditorStatus(message, "dirty");
    setEditorBusy(false);
    refreshRouteSources(routeEditorTrip?.value || "");
    setRouteHighlight(routeEditorTrip?.value || "");
  };

  const renderTripSelect = () => {
    if (!routeEditorTrip) return;
    const current = routeEditorTrip.value;
    routeEditorTrip.innerHTML = "";
    for (const trip of editorData.trips) {
      const option = document.createElement("option");
      option.value = trip.slug;
      option.textContent = `${trip.date} - ${trip.title}`;
      routeEditorTrip.append(option);
    }
    routeEditorTrip.value = current || editorData.trips[0]?.slug || "";
  };

  const renderInsertOptions = (trip) => {
    if (!routeEditorInsert) return;
    routeEditorInsert.innerHTML = "";
    const insertableNodes = trip.routeNodes.slice(0, Math.max(1, trip.routeNodes.length - 1));
    insertableNodes.forEach((node, index) => {
      const option = document.createElement("option");
      option.value = String(index + 1);
      option.textContent = `After ${node.title || `Stop ${index + 1}`}`;
      routeEditorInsert.append(option);
    });
    routeEditorInsert.value = String(insertableNodes.length);
  };

  const renderEditorStops = () => {
    const trip = activeEditorTrip();
    if (!trip || !routeEditorStops) return;
    const normalizedChanged = normalizeEditorTrip(trip);
    routeEditorStops.innerHTML = "";
    renderInsertOptions(trip);

    trip.routeNodes.forEach((node, index) => {
      if (index > 0) {
        const segment = document.createElement("div");
        segment.className = "route-editor__segment";

        const label = document.createElement("span");
        label.textContent = `${trip.routeNodes[index - 1].title || `Stop ${index}`} to ${node.title || `Stop ${index + 1}`}`;

        const mode = document.createElement("select");
        mode.setAttribute("aria-label", `Mode for leg ${index}`);
        mode.dataset.segmentIndex = String(index - 1);
        for (const value of ["drive", "flight", "sail"]) {
          const option = document.createElement("option");
          option.value = value;
          option.textContent = value === "flight" ? "Plane" : value === "sail" ? "Boat" : "Car";
          mode.append(option);
        }
        mode.value = ["flight", "sail"].includes(trip.routeSegments[index - 1]?.mode)
          ? trip.routeSegments[index - 1].mode
          : "drive";

        segment.append(label, mode);
        routeEditorStops.append(segment);
      }

      const lockedReturnNode = isReturnNode(trip, index);
      const row = document.createElement("div");
      row.className = "route-editor__stop";
      if (lockedReturnNode) row.classList.add("route-editor__stop--return");
      row.dataset.nodeIndex = String(index);

      const marker = document.createElement("span");
      marker.className = "route-editor__stop-index";
      marker.textContent = String(index + 1);

      const title = document.createElement("input");
      title.type = "text";
      title.value = node.title || "";
      title.placeholder = "Stop name";
      title.dataset.nodeField = "title";
      title.setAttribute("aria-label", `Stop ${index + 1} name`);
      title.readOnly = lockedReturnNode;

      const lat = document.createElement("input");
      lat.type = "number";
      lat.step = "0.0001";
      lat.value = String(node.lat);
      lat.dataset.nodeField = "lat";
      lat.setAttribute("aria-label", `Stop ${index + 1} latitude`);
      lat.readOnly = lockedReturnNode;

      const lon = document.createElement("input");
      lon.type = "number";
      lon.step = "0.0001";
      lon.value = String(node.lon);
      lon.dataset.nodeField = "lon";
      lon.setAttribute("aria-label", `Stop ${index + 1} longitude`);
      lon.readOnly = lockedReturnNode;

      const showOnMap = document.createElement("label");
      showOnMap.className = "route-editor__stop-toggle";
      const showOnMapInput = document.createElement("input");
      showOnMapInput.type = "checkbox";
      showOnMapInput.checked = showNodeOnMap(node, !lockedReturnNode);
      showOnMapInput.dataset.nodeField = "showOnMap";
      showOnMapInput.setAttribute("aria-label", `Show stop ${index + 1} on map`);
      const showOnMapText = document.createElement("span");
      showOnMapText.textContent = "Show";
      showOnMap.append(showOnMapInput, showOnMapText);

      const controls = document.createElement("div");
      controls.className = "route-editor__stop-actions";
      for (const [action, labelText] of [
        ["up", "Up"],
        ["down", "Down"],
        ["remove", "Remove"],
      ]) {
        const button = document.createElement("button");
        button.type = "button";
        button.dataset.nodeAction = action;
        button.textContent = labelText;
        button.disabled =
          lockedReturnNode ||
          (action === "up" && index === 0) ||
          (action === "down" && index >= trip.routeNodes.length - 2) ||
          (action === "remove" && trip.routeNodes.length <= 3);
        controls.append(button);
      }

      row.append(marker, title, lat, lon, showOnMap, controls);
      routeEditorStops.append(row);
    });

    if (normalizedChanged && !editorDirty) {
      markEditorDirty("Return to start added; save to keep it");
    }
  };

  const renderRouteEditor = () => {
    if (!editorAvailable) return;
    renderTripSelect();
    renderEditorStops();
    setEditorBusy(editorSaving);
    const trip = activeEditorTrip();
    if (trip) {
      selectItem(trip.slug, false);
      fitRoute(trip.slug);
    }
  };

  const insertStop = (stop, index) => {
    const trip = activeEditorTrip();
    if (!trip) return;
    normalizeEditorTrip(trip);
    const insertIndex = Math.min(Math.max(0, index), Math.max(0, trip.routeNodes.length - 1));
    trip.routeNodes.splice(insertIndex, 0, { ...stop, showOnMap: showNodeOnMap(stop) });
    normalizeEditorTrip(trip);
    renderEditorStops();
    markEditorDirty(`Added ${stop.title}`);
    fitRoute(trip.slug);
  };

  const fetchLocationMatches = async (query) => {
    const trimmed = query.trim();
    if (!trimmed) return [];

    const params = new URLSearchParams({
      access_token: mapboxToken,
      limit: "6",
      types: "poi,address,place,locality,region,country",
    });
    const url = `https://api.mapbox.com/geocoding/v5/mapbox.places/${encodeURIComponent(trimmed)}.json?${params}`;
    const response = await fetch(url);
    if (!response.ok) throw new Error("Destination search failed.");
    const payload = await response.json();
    return Array.isArray(payload.features) ? payload.features : [];
  };

  const locationFromFeature = (feature) => {
    const center = feature?.center || [];
    if (!Number.isFinite(Number(center[0])) || !Number.isFinite(Number(center[1]))) return null;
    return {
      title: feature.text || feature.place_name || "Destination",
      lat: Number(Number(center[1]).toFixed(5)),
      lon: Number(Number(center[0]).toFixed(5)),
      label: feature.place_name || feature.text || "Destination",
    };
  };

  const renderLocationResults = (features, onSelect) => {
    if (!routeEditorResults) return 0;
    routeEditorResults.innerHTML = "";

    let rendered = 0;
    for (const feature of features) {
      const location = locationFromFeature(feature);
      if (!location) continue;
      const button = document.createElement("button");
      button.type = "button";
      button.textContent = location.label;
      button.addEventListener("click", () => onSelect(location));
      routeEditorResults.append(button);
      rendered += 1;
    }
    return rendered;
  };

  const geocodeDestination = async (query) => {
    const trimmed = query.trim();
    if (!trimmed || !routeEditorResults) return;

    setEditorStatus("Searching...", "");
    const features = await fetchLocationMatches(trimmed);

    if (!features.length) {
      setEditorStatus("No matches", "error");
      return;
    }

    const rendered = renderLocationResults(features, (location) => {
        insertStop(
          {
            title: location.title,
            lat: location.lat,
            lon: location.lon,
          },
          Number(routeEditorInsert?.value || activeEditorTrip()?.routeNodes?.length || 0),
        );
        routeEditorResults.innerHTML = "";
        if (routeEditorQuery) routeEditorQuery.value = "";
    });
    setEditorStatus(`${rendered} matches`, rendered ? "" : "error");
  };

  const updateStopFromLocation = (index, location) => {
    const trip = activeEditorTrip();
    if (!trip || !trip.routeNodes[index]) return;

    trip.routeNodes[index] = {
      title: location.title,
      lat: location.lat,
      lon: location.lon,
      showOnMap: showNodeOnMap(trip.routeNodes[index]),
    };
    normalizeEditorTrip(trip);
    renderEditorStops();
    markEditorDirty(`Updated ${location.title}`);
    if (routeEditorResults) routeEditorResults.innerHTML = "";
    fitRoute(trip.slug);
  };

  const geocodeStopName = async (query, index, requestId) => {
    const trimmed = query.trim();
    if (!trimmed || trimmed.length < 3 || !routeEditorResults) return;

    setEditorStatus(`Searching for stop ${index + 1}...`, "");
    const features = await fetchLocationMatches(trimmed);
    if (requestId !== stopLookupRequestId) return;

    if (!features.length) {
      routeEditorResults.innerHTML = "";
      setEditorStatus("No stop matches", "error");
      return;
    }

    const rendered = renderLocationResults(features, (location) => updateStopFromLocation(index, location));
    setEditorStatus(`${rendered} stop matches`, rendered ? "" : "error");
  };

  const scheduleStopNameLookup = (query, index) => {
    window.clearTimeout(stopLookupTimeout);
    stopLookupRequestId += 1;

    if (!query.trim() || query.trim().length < 3) {
      if (routeEditorResults) routeEditorResults.innerHTML = "";
      return;
    }

    const requestId = stopLookupRequestId;
    stopLookupTimeout = window.setTimeout(() => {
      geocodeStopName(query, index, requestId).catch((error) => {
        if (requestId !== stopLookupRequestId) return;
        setEditorStatus(error.message, "error");
      });
    }, 350);
  };

  const roundedRouteCoordinates = (coordinates) =>
    coordinates
      .filter((coord) => Array.isArray(coord) && Number.isFinite(Number(coord[0])) && Number.isFinite(Number(coord[1])))
      .map((coord) => [Number(Number(coord[0]).toFixed(5)), Number(Number(coord[1]).toFixed(5))]);

  const fetchDriveRoute = async (start, end) => {
    const coordinates = `${start.lon},${start.lat};${end.lon},${end.lat}`;
    const params = new URLSearchParams({
      access_token: mapboxToken,
      geometries: "geojson",
      overview: "full",
      alternatives: "false",
    });
    const response = await fetch(`https://api.mapbox.com/directions/v5/mapbox/driving/${coordinates}?${params}`);
    const payload = await response.json().catch(() => ({}));
    if (!response.ok || payload.code !== "Ok" || !payload.routes?.[0]?.geometry?.coordinates?.length) {
      throw new Error(payload.message || payload.code || "Drive route failed.");
    }
    const route = payload.routes[0];
    return {
      coordinates: roundedRouteCoordinates(route.geometry.coordinates),
      distanceMeters: Math.round(Number(route.distance || 0)),
      durationSeconds: Math.round(Number(route.duration || 0)),
    };
  };

  const recalculateActiveTripRoute = async () => {
    const trip = activeEditorTrip();
    if (!trip) return;
    normalizeEditorTrip(trip);
    if (trip.routeNodes.length < 2) {
      setEditorStatus("Add at least two stops first", "error");
      return;
    }

    setEditorBusy(true);
    setEditorStatus("Recalculating route...", "");
    if (routeEditorResults) routeEditorResults.innerHTML = "";

    let routed = 0;
    let flights = 0;
    let sails = 0;
    let failed = 0;

    for (let index = 0; index < trip.routeNodes.length - 1; index += 1) {
      const start = trip.routeNodes[index];
      const end = trip.routeNodes[index + 1];
      const segment = trip.routeSegments[index] || { mode: "drive" };
      const mode = ["flight", "sail"].includes(segment.mode) ? segment.mode : "drive";

      if (mode === "flight" || mode === "sail") {
        segment.coordinates = greatCircleCoordinates([start.lon, start.lat], [end.lon, end.lat]);
        segment.routeProvider = "great-circle";
        segment.routeProfile = mode;
        delete segment.distanceMeters;
        delete segment.durationSeconds;
        flights += mode === "flight" ? 1 : 0;
        sails += mode === "sail" ? 1 : 0;
      } else {
        try {
          const route = await fetchDriveRoute(start, end);
          segment.coordinates = route.coordinates;
          segment.distanceMeters = route.distanceMeters;
          segment.durationSeconds = route.durationSeconds;
          segment.routeProvider = "mapbox-directions";
          segment.routeProfile = "mapbox/driving";
          routed += 1;
        } catch (error) {
          failed += 1;
          segment.coordinates = [
            [start.lon, start.lat],
            [end.lon, end.lat],
          ];
          segment.routeProvider = "fallback";
          segment.routeProfile = "straight-line";
          console.warn(`Route failed for ${start.title} to ${end.title}:`, error);
        }
      }

      trip.routeSegments[index] = segment;
    }

    editorDirty = true;
    refreshRouteSources(trip.slug);
    setRouteHighlight(trip.slug);
    fitRoute(trip.slug);
    renderEditorStops();
    setEditorStatus(
      failed
        ? `Recalculated ${routed} car leg(s), ${flights} plane leg(s), ${sails} boat leg(s); ${failed} failed`
        : `Recalculated ${routed} car leg(s), ${flights} plane leg(s), ${sails} boat leg(s)`,
      failed ? "error" : "dirty",
    );
    setEditorBusy(false);
  };

  const saveRouteEditor = async () => {
    if (!editorDirty || editorSaving) return;
    setEditorBusy(true);
    setEditorStatus("Saving routes...", "");

    const response = await fetch("/api/travel-config/save", {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify(editorData),
    });
    const payload = await response.json().catch(() => ({}));
    if (!response.ok || !payload.ok) {
      throw new Error(payload.error || "Route save failed.");
    }

    editorDirty = false;
    setEditorStatus("Saved routes", "saved");
    setEditorBusy(false);
    await loadGeneratedTripRoutes({ bustCache: true });
    refreshRouteSources("");
    const trip = activeEditorTrip();
    if (trip) {
      setRouteHighlight(trip.slug);
      fitRoute(trip.slug);
    }
  };

  if (editorAvailable) {
    routeEditorToggle.hidden = false;
    routeEditorToggle.setAttribute("aria-expanded", "false");
    const setRouteEditorOpen = (open) => {
      routeEditor.hidden = !open;
      routeEditorToggle.classList.toggle("is-active", open);
      routeEditorToggle.textContent = open ? "Close editor" : "Edit routes";
      routeEditorToggle.setAttribute("aria-expanded", String(open));
      if (open) renderRouteEditor();
    };

    routeEditorToggle.addEventListener("click", () => {
      setRouteEditorOpen(routeEditor.hidden);
    });

    routeEditorClose.addEventListener("click", () => {
      setRouteEditorOpen(false);
    });

    routeEditorTrip.addEventListener("change", () => {
      renderEditorStops();
      const trip = activeEditorTrip();
      if (trip) {
        refreshRouteSources(trip.slug);
        selectItem(trip.slug, false);
        fitRoute(trip.slug);
      }
    });

    routeEditorSearch.addEventListener("submit", (event) => {
      event.preventDefault();
      geocodeDestination(routeEditorQuery.value).catch((error) => {
        setEditorStatus(error.message, "error");
      });
    });

    routeEditorStops.addEventListener("input", (event) => {
      const target = event.target;
      const trip = activeEditorTrip();
      if (!trip || !(target instanceof HTMLInputElement || target instanceof HTMLSelectElement)) return;

      if (target.dataset.nodeField) {
        const row = target.closest("[data-node-index]");
        const nodeIndex = Number(row?.dataset.nodeIndex);
        const node = trip.routeNodes[nodeIndex];
        if (!node) return;
        if (target.dataset.nodeField === "showOnMap") {
          node.showOnMap = target.checked;
          markEditorDirty(target.checked ? "Stop will show on map" : "Stop hidden from map");
          return;
        }
        if (target.dataset.nodeField === "title") {
          node.title = target.value;
          scheduleStopNameLookup(target.value, nodeIndex);
        }
        if (target.dataset.nodeField === "lat") node.lat = Number(target.value);
        if (target.dataset.nodeField === "lon") node.lon = Number(target.value);
        trip.routeNodes = routeNodesReturningToStart(trip.routeNodes.filter(isFiniteCoordinate).map(routeNodeFrom));
        markEditorDirty("Unsaved stop changes");
      }

      if (target.dataset.segmentIndex) {
        const segment = trip.routeSegments[Number(target.dataset.segmentIndex)];
        if (!segment) return;
        segment.mode = ["flight", "sail"].includes(target.value) ? target.value : "drive";
        trip.travelMode = trip.routeSegments.some((item) => item.mode === "flight") ? "flight" : "drive";
        markEditorDirty("Unsaved mode changes");
      }
    });

    routeEditorStops.addEventListener("click", (event) => {
      const button = event.target.closest("[data-node-action]");
      if (!button) return;
      const trip = activeEditorTrip();
      const row = button.closest("[data-node-index]");
      const index = Number(row?.dataset.nodeIndex);
      if (!trip || !Number.isInteger(index)) return;

      if (button.dataset.nodeAction === "remove") {
        trip.routeNodes.splice(index, 1);
      }
      if (button.dataset.nodeAction === "up" && index > 0) {
        [trip.routeNodes[index - 1], trip.routeNodes[index]] = [trip.routeNodes[index], trip.routeNodes[index - 1]];
      }
      if (button.dataset.nodeAction === "down" && index < trip.routeNodes.length - 1) {
        [trip.routeNodes[index], trip.routeNodes[index + 1]] = [trip.routeNodes[index + 1], trip.routeNodes[index]];
      }

      normalizeEditorTrip(trip);
      renderEditorStops();
      markEditorDirty("Unsaved stop changes");
      fitRoute(trip.slug);
    });

    routeEditorSave.addEventListener("click", () => {
      saveRouteEditor().catch((error) => {
        setEditorStatus(error.message, "error");
        setEditorBusy(false);
      });
    });

    routeEditorRecalculate.addEventListener("click", () => {
      recalculateActiveTripRoute().catch((error) => {
        setEditorStatus(error.message, "error");
        setEditorBusy(false);
      });
    });

    routeEditorReset.addEventListener("click", () => {
      editorData = cloneData(mapData);
      editorDirty = false;
      setEditorStatus("Reset", "");
      if (routeEditorResults) routeEditorResults.innerHTML = "";
      renderRouteEditor();
      refreshRouteSources("");
    });

    routeEditorFit.addEventListener("click", () => {
      const trip = activeEditorTrip();
      if (trip) fitRoute(trip.slug);
    });
  }

  timelinePlayButton?.addEventListener("click", toggleTimelinePlayback);
  renderTimelinePlaybackButton();
  timelineCameraButton?.addEventListener("click", toggleTimelineCamera);
  timelineCameraResetButton?.addEventListener("click", resetPlaybackCameraOffset);

  timelineSpeedButton?.addEventListener("click", cycleTimelineSpeed);
  playbackOptionsToggle?.addEventListener("click", () => {
    const expanded = playbackOptionsToggle.getAttribute("aria-expanded") === "true";
    playbackOptionsToggle.setAttribute("aria-expanded", String(!expanded));
    if (playbackOptionsPanel) playbackOptionsPanel.hidden = expanded;
  });
  playbackStravaToggle?.addEventListener("change", () => {
    includeStravaInPlayback = Boolean(playbackStravaToggle.checked);
    clearPlaybackRouteCaches();
    setScrubberProgress(scrubberValue, { trackCamera: false, centerDot: false });
  });
  document.addEventListener("click", (event) => {
    if (!playbackOptions || !playbackOptionsToggle || !playbackOptionsPanel) return;
    if (playbackOptions.contains(event.target)) return;
    playbackOptionsToggle.setAttribute("aria-expanded", "false");
    playbackOptionsPanel.hidden = true;
  });
  renderTimelineCameraButton();
  renderTimelineCameraResetButton();

  const schedulePlaybackCameraOffsetUpdate = () => {
    if (playbackCameraOffsetFrame) window.cancelAnimationFrame(playbackCameraOffsetFrame);
    playbackCameraOffsetFrame = window.requestAnimationFrame(() => {
      playbackCameraOffsetFrame = 0;
      rememberPlaybackCameraOffset();
    });
  };
  const notePlaybackCameraUserStart = (event) => {
    if (!event?.originalEvent || !timelinePlaybackActive) return;
    playbackCameraUserInteracting = true;
    playbackCameraOffsetActive = true;
    renderTimelineCameraResetButton();
    clearScheduledPopup();
    popup.remove();
    map.stop?.();
    if (playbackCameraInteractionTimer) window.clearTimeout(playbackCameraInteractionTimer);
    playbackCameraInteractionTimer = window.setTimeout(() => {
      playbackCameraUserInteracting = false;
      schedulePlaybackCameraOffsetUpdate();
    }, 420);
    schedulePlaybackCameraOffsetUpdate();
  };
  const notePlaybackCameraManualPanStart = (event) => {
    if (!event?.originalEvent || !timelinePlaybackActive) return;
    playbackCameraManualOverride = true;
    notePlaybackCameraUserStart(event);
  };
  const notePlaybackCameraUserChange = (event) => {
    if (!timelinePlaybackActive) return;
    if (event?.originalEvent) {
      notePlaybackCameraUserStart(event);
      return;
    }
    if (!playbackCameraUserInteracting) return;
    schedulePlaybackCameraOffsetUpdate();
  };
  ["rotatestart", "pitchstart", "zoomstart"].forEach((eventName) => map.on(eventName, notePlaybackCameraUserStart));
  map.on("dragstart", notePlaybackCameraManualPanStart);
  ["rotate", "pitch", "zoom", "moveend"].forEach((eventName) => map.on(eventName, notePlaybackCameraUserChange));
  const mapCanvas = map.getCanvas?.();
  ["wheel"].forEach((eventName) => {
    mapCanvas?.addEventListener(eventName, (event) => notePlaybackCameraUserStart({ originalEvent: event }), { passive: true });
  });

  timelineDots.forEach((dot) => {
    dot.addEventListener("click", () => {
      stopTimelinePlayback();
      selectItem(dot.getAttribute("data-map-timeline-item"), true);
    });
  });

  const handleTimelineWheel = (event) => {
    if (!timelineRail) return;
    stopTimelinePlayback();
    event.preventDefault();
    const dominantDelta = Math.abs(event.deltaX) > Math.abs(event.deltaY) ? event.deltaX : event.deltaY;
    if (!dominantDelta) return;
    const axis = timelineRail.querySelector(".travel-timeline-rail__axis");
    const beforeAxisWidth = axis?.scrollWidth || timelineAxisWidth();
    const pointerX = Math.min(timelineRail.clientWidth, Math.max(0, event.clientX - timelineRail.getBoundingClientRect().left));
    const focusRatio = Math.min(1, Math.max(0, (timelineRail.scrollLeft + pointerX) / Math.max(1, beforeAxisWidth)));
    const zoomDelta = event.deltaMode === 1 ? dominantDelta * 0.045 : event.deltaMode === 2 ? dominantDelta * 0.36 : dominantDelta * 0.0032;
    const nextWidth = timelineZoomWidth * Math.exp(-Math.max(-0.42, Math.min(0.42, zoomDelta)));

    setTimelineZoomWidth(nextWidth);
    window.requestAnimationFrame(() => {
      const afterAxisWidth = axis?.scrollWidth || timelineAxisWidth();
      timelineRail.scrollLeft = Math.min(Math.max(0, focusRatio * afterAxisWidth - pointerX), maxTimelineScroll());
    });
  };

  if (timelineRail) {
    let dragStartX = 0;
    let dragStartScrollLeft = 0;
    let dragStartTime = 0;
    let suppressTimelineClick = false;
    let isTimelineDragging = false;

    const timelineValueFromClientX = (clientX) => {
      const axis = timelineRail.querySelector(".travel-timeline-rail__axis");
      const axisRect = axis?.getBoundingClientRect();
      const axisWidth = axis?.scrollWidth || axisRect?.width || timelineAxisWidth();
      if (!axisRect || !axisWidth) return timelineValueFromScroll();
      const ratio = Math.min(1, Math.max(0, (clientX - axisRect.left) / Math.max(1, axisWidth)));
      return scrubberValueFromTimelineTime(timelineStartTime + ratio * timelineTimeSpan);
    };

    const centerTimelineOnClientX = (clientX) => {
      const axis = timelineRail.querySelector(".travel-timeline-rail__axis");
      const axisRect = axis?.getBoundingClientRect();
      const axisWidth = axis?.scrollWidth || axisRect?.width || timelineAxisWidth();
      if (!axisRect || !axisWidth) return;
      const ratio = Math.min(1, Math.max(0, (clientX - axisRect.left) / Math.max(1, axisWidth)));
      timelineRail.scrollLeft = Math.min(Math.max(0, ratio * axisWidth - timelineRail.clientWidth / 2), maxTimelineScroll());
    };

    const applyInitialTimelineScroll = () => {
      setTimelineZoomWidth(timelineZoomWidth);
      scrollTimelineToValue(scrubberValue, "auto");
    };

    applyInitialTimelineScroll();
    window.addEventListener("resize", applyInitialTimelineScroll);
    timelineRail.addEventListener("wheel", handleTimelineWheel, { passive: false });
    timelineRail.addEventListener("pointerdown", (event) => {
      if (event.target?.closest?.("[data-map-timeline-item]")) return;
      stopTimelinePlayback();
      isTimelineDragging = true;
      suppressTimelineClick = false;
      dragStartX = event.clientX;
      dragStartScrollLeft = timelineRail.scrollLeft;
      dragStartTime = performance.now();
      timelineRail.classList.add("is-dragging");
      timelineRail.setPointerCapture?.(event.pointerId);
    });
    timelineRail.addEventListener("pointermove", (event) => {
      if (!isTimelineDragging) return;
      event.preventDefault();
      const dragDelta = event.clientX - dragStartX;
      if (Math.abs(dragDelta) > 4) suppressTimelineClick = true;
      timelineRail.scrollLeft = dragStartScrollLeft - dragDelta;
    });
    const stopTimelineDrag = (event) => {
      if (!isTimelineDragging) return;
      const dragDistance = Math.abs(event.clientX - dragStartX);
      const dragDuration = performance.now() - dragStartTime;
      isTimelineDragging = false;
      timelineRail.classList.remove("is-dragging");
      timelineRail.releasePointerCapture?.(event.pointerId);
      if (!suppressTimelineClick && dragDistance < 6 && dragDuration < 450) {
        event.preventDefault();
        const tappedValue = timelineValueFromClientX(event.clientX);
        centerTimelineOnClientX(event.clientX);
        setScrubberProgress(tappedValue, { trackCamera: true, centerDot: false });
      }
    };
    timelineRail.addEventListener("pointerup", stopTimelineDrag);
    timelineRail.addEventListener("pointercancel", stopTimelineDrag);
  }

  layerToggleButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const key = button.getAttribute("data-map-layer-toggle");
      if (!key || !(key in layerVisibility)) return;
      layerVisibility[key] = !layerVisibility[key];
      if (key === "race" && !layerVisibility.race) {
        const activeItem = allPointsBySlug.get(activeTimelineSlug);
        if (activeItem?.type === "race") popup.remove();
      }
      if (key === "dots" && !layerVisibility.dots) {
        const activeItem = allPointsBySlug.get(activeTimelineSlug);
        if (activeItem?.type === "race") popup.remove();
      }
      updateLayerVisibility();
    });
  });

  updateActiveSummary(timelineSequence[0]);
</script>
