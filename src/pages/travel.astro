    const routes = await response.json().catch(() => null);
    if (!routes?.features?.length) return;

    raceRouteFeaturesBySlug = new Map();
    for (const feature of routes.features) {
      const slug = feature.properties?.raceSlug;
      if (!slug) continue;
      const features = raceRouteFeaturesBySlug.get(slug) || [];
      features.push(feature);
      raceRouteFeaturesBySlug.set(slug, features);
    }

    map.addSource("race-routes", { type: "geojson", data: routes, lineMetrics: true });
    map.addLayer(
      {
        id: "race-route-highlight-casing",
