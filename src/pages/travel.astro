    for (const layerId of ["race-route-highlight-casing", "race-route-highlight"]) {
      map.on("click", layerId, (event) => {
        const slug = event.features?.[0]?.properties?.raceSlug;
        const clickedCoordinate = event.lngLat ? [event.lngLat.lng, event.lngLat.lat] : null;
        if (slug) selectItem(slug, false, clickedCoordinate);
      });
