---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import mapData from "../data/travel-map.json";

const monthLookup: Record<string, number> = {
  jan: 0,
  feb: 1,
  mar: 2,
  apr: 3,
  may: 4,
  jun: 5,
  jul: 6,
  aug: 7,
  sep: 8,
  oct: 9,
  nov: 10,
  dec: 11,
};
const sortDate = (date: string) => {
  const normalized = String(date || "").trim();
  const isoMatch = normalized.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (isoMatch) {
    const [, year, month, day] = isoMatch;
    return Date.UTC(Number(year), Number(month) - 1, Number(day));
  }

  const exactMatch = normalized.match(/^([A-Za-z]+)\s+(\d{1,2}),?\s+(\d{4})$/);
  if (exactMatch) {
    const [, month, day, year] = exactMatch;
    const monthIndex = monthLookup[month.slice(0, 3).toLowerCase()] ?? 0;
    return Date.UTC(Number(year), monthIndex, Number(day));
  }

  const monthMatch = normalized.match(/^([A-Za-z]+)\s+(\d{4})$/);
  if (monthMatch) {
    const [, month, year] = monthMatch;
    const monthIndex = monthLookup[month.slice(0, 3).toLowerCase()] ?? 0;
    return Date.UTC(Number(year), monthIndex, 15);
  }

  const year = Number(normalized) || 0;
  return Date.UTC(year, 6, 1);
};
const stravaRoutesPath = path.resolve("public/data/strava-routes.geojson");
const stravaRouteData = fs.existsSync(stravaRoutesPath)
  ? JSON.parse(fs.readFileSync(stravaRoutesPath, "utf8"))
  : { features: [] };
const humanActivityLabel = (properties: any) => {
  const raw = String(properties?.sportType || properties?.type || properties?.activityGroup || "").trim();
  const normalized = raw.replace(/[_-]/g, " ").replace(/([a-z])([A-Z])/g, "$1 $2").toLowerCase();
  if (/trail\s*run/.test(normalized)) return "Trail run";
  if (/hike/.test(normalized)) return "Hike";
  if (/walk/.test(normalized)) return "Walk";
  if (/kayak/.test(normalized)) return "Kayak";
  if (/canoe/.test(normalized)) return "Canoe";
  if (/row|paddle/.test(normalized)) return "Paddle";
  if (/swim/.test(normalized)) return "Swim";
  if (/ski|snowboard/.test(normalized)) return "Ski";
  if (/mountain.*bike/.test(normalized)) return "Mountain bike";
  if (/ride|bike|cycling/.test(normalized)) return "Ride";
  if (/run/.test(normalized)) return "Run";
  return raw || "Strava";
};
const stravaTimelineItems = (stravaRouteData.features || [])
  .map((feature: any) => {
    const properties = feature.properties || {};
    const coordinates = Array.isArray(feature.geometry?.coordinates) ? feature.geometry.coordinates : [];
    const midpoint = coordinates.length ? coordinates[Math.floor(coordinates.length / 2)] : null;
    const id = String(properties.id || "");
    const startDate = String(properties.startDate || "");
    const timelineTime = Date.parse(startDate);
    if (!id || !Number.isFinite(timelineTime) || !Array.isArray(midpoint)) return null;
    return {
      type: "strava",
      slug: `strava-${id}`,
      stravaActivityId: id,
      title: properties.name || "Strava activity",
      detail: humanActivityLabel(properties),
      date: startDate.slice(0, 10),
      startDate,
      activityType: properties.type || properties.activityGroup || "",
      sportType: properties.sportType || properties.type || "",
      activityGroup: properties.activityGroup || properties.type || "",
      distanceMeters: Number(properties.distanceMeters || 0),
      movingTimeSeconds: Number(properties.movingTimeSeconds || 0),
      elapsedTimeSeconds: Number(properties.elapsedTimeSeconds || 0),
      lat: Number(midpoint[1]),
      lon: Number(midpoint[0]),
      timelineTime,
      href: `https://www.strava.com/activities/${encodeURIComponent(id)}`,
    };
  })
  .filter(Boolean);
const tripPhotosPath = path.resolve("public/data/trip-photos/manifest.json");
const tripPhotoManifest = fs.existsSync(tripPhotosPath)
  ? JSON.parse(fs.readFileSync(tripPhotosPath, "utf8"))
  : { trips: {} };
const itemTimelineTime = (item: any) => Number.isFinite(item.timelineTime) ? item.timelineTime : sortDate(item.date);
const mapItems = [...mapData.trips, ...mapData.races, ...stravaTimelineItems].sort((a, b) => itemTimelineTime(a) - itemTimelineTime(b));
const timelineStart = mapItems.length ? itemTimelineTime(mapItems[0]) : Date.UTC(2020, 0, 1);
const timelineEnd = Math.max(
  mapItems.length ? itemTimelineTime(mapItems[mapItems.length - 1]) : Date.UTC(2026, 0, 1),
  Date.now(),
);
const timelineSpan = Math.max(1, timelineEnd - timelineStart);
const timelinePositionForTime = (time: number) => Math.min(98.75, Math.max(1.25, ((time - timelineStart) / timelineSpan) * 100));
const timelinePosition = (date: string) => timelinePositionForTime(sortDate(date));
const startYear = new Date(timelineStart).getUTCFullYear();
const endYear = new Date(timelineEnd).getUTCFullYear();
const timelineYears = Array.from({ length: endYear - startYear + 1 }, (_, index) => startYear + index);
const monthLabels = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const startMonth = new Date(timelineStart);
const endMonth = new Date(timelineEnd);
const timelineMonths: Array<{ year: number; month: number; time: number; label: string; isQuarter: boolean }> = [];
for (
  let year = startMonth.getUTCFullYear(), month = startMonth.getUTCMonth();
  year < endMonth.getUTCFullYear() || (year === endMonth.getUTCFullYear() && month <= endMonth.getUTCMonth());
  month += 1
) {
  if (month > 11) {
    month = 0;
    year += 1;
  }
  const time = Date.UTC(year, month, 1);
  timelineMonths.push({
    year,
    month,
    time,
    label: monthLabels[month],
    isQuarter: month % 3 === 0,
  });
}
const timelineFocusStart = Date.UTC(2020, 0, 1);
const timelineFocusSpan = Math.max(1, timelineEnd - timelineFocusStart);
const timelineWidth = Math.max(100, Math.min(720, (timelineSpan / timelineFocusSpan) * 180));
const timelineScrollStart = ((timelineFocusStart - timelineStart) / timelineSpan) * timelineWidth;
const firstFocusedTimelineIndex = mapItems.findIndex((item) => itemTimelineTime(item) >= timelineFocusStart);
const initialTimelineSlug = "dec-2024-new-zealand";
const initialTimelineSlugIndex = mapItems.findIndex((item) => item.slug === initialTimelineSlug);
const initialTimelineIndex =
  initialTimelineSlugIndex >= 0
    ? initialTimelineSlugIndex
    : firstFocusedTimelineIndex >= 0
      ? firstFocusedTimelineIndex
      : Math.max(0, mapItems.length - 1);
const timelineUnit = 100;
const initialTimelineValue = initialTimelineIndex * timelineUnit;
const stravaTimelineBucket = (item: any) => {
  if (item.type !== "strava") return "";
  const activity = String(item.activityType || item.activityGroup || item.detail || "").toLowerCase();
  if (/swim/.test(activity)) return "swim";
  if (/run|walk|hike|foot|snowshoe/.test(activity)) return "run";
  if (/ride|bike|cycling|ski|snowboard|skate|surf|wheelchair|handcycle/.test(activity)) return "bike";
  return "other";
};
const timelineDotClass = (item: any) => [
  "travel-timeline-rail__dot",
  `travel-timeline-rail__dot--${item.type}`,
  item.type === "strava" ? `travel-timeline-rail__dot--strava-${stravaTimelineBucket(item)}` : "",
].filter(Boolean).join(" ");
const serializedMapData = JSON.stringify(mapData).replace(/</g, "\\u003c");
const serializedStravaTimelineItems = JSON.stringify(stravaTimelineItems).replace(/</g, "\\u003c");
const serializedTripPhotoManifest = JSON.stringify(tripPhotoManifest).replace(/</g, "\\u003c");
---

<BaseLayout title="Journey" bodyClass="travel-app">
  <section class="map-page" aria-label="Journey map">
    <section class="map-stage">
      <div class="map-stage__content">
        <div class="map-legend" aria-label="Map key">
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="flight" aria-pressed="true">
            <i class="map-key-line map-key-line--flight"></i>Plane
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="drive" aria-pressed="true">
            <i class="map-key-line map-key-line--drive"></i>Car
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="sail" aria-pressed="true">
            <i class="map-key-line map-key-line--sail"></i>Boat
          </button>
          <button type="button" class="map-legend__toggle map-legend__toggle--strava" data-map-layer-toggle="strava" aria-pressed="true" aria-label="Toggle Strava runs and bike rides">
            <span class="map-key-strava-text">Run</span>
            <i class="map-key-line map-key-line--strava"></i>
            <span class="map-key-strava-text">Bike</span>
          </button>
          <button type="button" class="map-legend__toggle map-legend__toggle--dots" data-map-layer-toggle="dots" aria-pressed="true" aria-label="Toggle map dots">
            <i class="map-key-dot map-key-dot--stop"></i>
          </button>
        </div>
        <section class="map-frame" aria-label="Journey map">
          <div id="travel-map" class="travel-map"></div>
        </section>

        <section class="map-timeline" aria-label="Journey timeline">
          <div class="map-playback">
            <button type="button" class="map-playback__button map-playback__button--icon" data-timeline-play aria-pressed="false" aria-label="Play timeline">
              <span class="map-playback__icon" aria-hidden="true"></span>
              <span class="sr-only" data-timeline-play-label>Play</span>
            </button>
            <button type="button" class="map-playback__button map-playback__button--icon map-playback__button--camera" data-timeline-camera aria-pressed="false" aria-label="Enable cinematic camera">
              <span class="map-playback__camera-icon" aria-hidden="true"></span>
              <span class="sr-only" data-timeline-camera-label>Camera</span>
            </button>
            <button type="button" class="map-playback__button map-playback__button--speed" data-timeline-speed aria-label="Playback speed 1x">
              <span data-timeline-speed-label>1x</span>
            </button>
            <div class="map-playback__menu" data-playback-options>
              <button type="button" class="map-playback__button map-playback__button--icon map-playback__button--options" data-playback-options-toggle aria-expanded="false" aria-label="Playback options">
                <span class="map-playback__options-icon" aria-hidden="true"></span>
              </button>
              <div class="map-playback__panel" data-playback-options-panel hidden>
                <label>
                  <input type="checkbox" data-playback-strava-toggle checked />
                  <span>Strava in play</span>
                </label>
              </div>
            </div>
            <button type="button" class="map-playback__button map-playback__button--icon map-playback__button--reset" data-timeline-camera-reset aria-label="Reset playback camera" hidden>
              <span class="map-playback__reset-icon" aria-hidden="true"></span>
            </button>
          </div>
          <div
            class="travel-timeline-rail"
            aria-label="Trip and race years"
            data-travel-timeline-rail
            data-initial-scrub-value={initialTimelineValue}
            data-timeline-start={timelineStart}
            data-timeline-end={timelineEnd}
            data-timeline-focus-start={timelineFocusStart}
            style={`--timeline-width: ${timelineWidth}%; --timeline-scroll-start: ${timelineScrollStart}%;`}
          >
            <div class="travel-timeline-rail__axis">
              {
                timelineYears.map((year) => (
                  <span class="travel-timeline-rail__year" style={`--x: ${timelinePosition(`Jan ${year}`)}%`}>
                    {year}
                  </span>
                ))
              }
              {
                timelineMonths.map((month) => (
                  <span
                    class={`travel-timeline-rail__month${month.isQuarter ? " travel-timeline-rail__month--quarter" : ""}`}
                    style={`--x: ${timelinePositionForTime(month.time)}%`}
                    aria-hidden="true"
                  >
                    {month.label}
                  </span>
                ))
              }
              {
                mapItems.map((item) => (
                  <button
                    type="button"
                    class={timelineDotClass(item)}
                    style={`--x: ${timelinePositionForTime(itemTimelineTime(item))}%`}
                    data-map-timeline-item={item.slug}
                    data-map-timeline-time={itemTimelineTime(item)}
                    aria-label={`${item.title}, ${item.date}`}
                  />
                ))
              }
            </div>
          </div>
          <output class="sr-only" data-travel-scrubber-title aria-live="polite"></output>
        </section>
      </div>

      <section id="route-editor" class="route-editor" aria-label="Route editor" hidden>
        <header class="route-editor__header">
          <div>
            <p class="route-editor__kicker">route editor</p>
            <h2>Trip routes</h2>
          </div>
          <div class="route-editor__actions">
            <button type="button" id="route-editor-close">Close</button>
            <button type="button" id="route-editor-reset">Reset</button>
            <button type="button" id="route-editor-recalculate">Recalculate route</button>
            <button type="button" id="route-editor-save">Save routes</button>
          </div>
        </header>
        <div class="route-editor__status" id="route-editor-status" aria-live="polite"></div>
        <div class="route-editor__grid">
          <div class="route-editor__panel">
            <label class="route-editor__field">
              <span>Trip</span>
              <select id="route-editor-trip"></select>
            </label>
            <form class="route-editor__search" id="route-editor-search">
              <label class="route-editor__field">
                <span>Destination search</span>
                <input id="route-editor-query" type="search" placeholder="Search destination" autocomplete="off" />
              </label>
              <label class="route-editor__field">
                <span>Insert</span>
                <select id="route-editor-insert"></select>
              </label>
              <button type="submit">Find</button>
            </form>
            <div class="route-editor__results" id="route-editor-results"></div>
          </div>
          <div class="route-editor__panel">
            <div class="route-editor__stops-header">
              <span>Stops</span>
              <button type="button" id="route-editor-fit">Fit route</button>
            </div>
            <div class="route-editor__stops" id="route-editor-stops"></div>
          </div>
        </div>
      </section>

    </section>
  </section>

  <script type="application/json" id="travel-map-data" set:html={serializedMapData} />
  <script type="application/json" id="travel-strava-timeline-data" set:html={serializedStravaTimelineItems} />
  <script type="application/json" id="travel-trip-photo-data" set:html={serializedTripPhotoManifest} />
</BaseLayout>

<script>
  import mapboxgl from "mapbox-gl";
  import "mapbox-gl/dist/mapbox-gl.css";

  const dataElement = document.getElementById("travel-map-data");
  const stravaTimelineElement = document.getElementById("travel-strava-timeline-data");
  const tripPhotoElement = document.getElementById("travel-trip-photo-data");
  const mapElement = document.getElementById("travel-map");
  const timelineRail = document.querySelector("[data-travel-timeline-rail]");
  const timelineDots = Array.from(document.querySelectorAll("[data-map-timeline-item]"));
  const scrubberTitleElement = document.querySelector("[data-travel-scrubber-title]");
  const timelinePlayButton = document.querySelector("[data-timeline-play]");
  const timelinePlayLabel = document.querySelector("[data-timeline-play-label]");
  const timelineCameraButton = document.querySelector("[data-timeline-camera]");
  const timelineCameraLabel = document.querySelector("[data-timeline-camera-label]");
  const timelineSpeedButton = document.querySelector("[data-timeline-speed]");
  const timelineSpeedLabel = document.querySelector("[data-timeline-speed-label]");
  const timelineCameraResetButton = document.querySelector("[data-timeline-camera-reset]");
  const playbackOptions = document.querySelector("[data-playback-options]");
  const playbackOptionsToggle = document.querySelector("[data-playback-options-toggle]");
  const playbackOptionsPanel = document.querySelector("[data-playback-options-panel]");
  const playbackStravaToggle = document.querySelector("[data-playback-strava-toggle]");
  const routeEditorToggle = document.querySelector("[data-route-editor-toggle]");
  const routeEditor = document.getElementById("route-editor");
  const routeEditorTrip = document.getElementById("route-editor-trip");
  const routeEditorStops = document.getElementById("route-editor-stops");
  const routeEditorInsert = document.getElementById("route-editor-insert");
  const routeEditorSearch = document.getElementById("route-editor-search");
  const routeEditorQuery = document.getElementById("route-editor-query");
  const routeEditorResults = document.getElementById("route-editor-results");
  const routeEditorStatus = document.getElementById("route-editor-status");
  const routeEditorSave = document.getElementById("route-editor-save");
  const routeEditorReset = document.getElementById("route-editor-reset");
  const routeEditorClose = document.getElementById("route-editor-close");
  const routeEditorRecalculate = document.getElementById("route-editor-recalculate");
  const routeEditorFit = document.getElementById("route-editor-fit");
  const layerToggleButtons = Array.from(document.querySelectorAll("[data-map-layer-toggle]"));
  const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || "";
  const travelDataVersion = "2026-05-01-race-leg-playback";
  const dataUrl = (path, { bustCache = false } = {}) => {
    const separator = path.includes("?") ? "&" : "?";
    const version = bustCache ? Date.now() : travelDataVersion;
    return `${path}${separator}v=${encodeURIComponent(version)}`;
  };
  const staticFetchOptions = ({ bustCache = false } = {}) => ({
    cache: bustCache ? "no-store" : "force-cache",
  });

  if (!mapElement) {
    if (mapElement) mapElement.setAttribute("data-map-empty", "true");
    throw new Error("Travel map needs a map container.");
  }

  if (!mapboxToken) {
    mapElement.setAttribute("data-map-empty", "true");
    throw new Error("Travel map needs PUBLIC_MAPBOX_TOKEN.");
  }

  mapboxgl.accessToken = mapboxToken;

  const cloneData = (value) => JSON.parse(JSON.stringify(value));
  const mapData = JSON.parse(dataElement?.textContent || "{\"trips\":[],\"races\":[]}");
  const stravaTimelineItems = JSON.parse(stravaTimelineElement?.textContent || "[]");
  const tripPhotoManifest = JSON.parse(tripPhotoElement?.textContent || "{\"trips\":{}}");
  const tripPhotosBySlug = new Map(Object.entries(tripPhotoManifest.trips || {}).map(([slug, photos]) => [slug, Array.isArray(photos) ? photos : []]));
  const stravaPhotosById = new Map(
    Object.entries(tripPhotoManifest.strava || tripPhotoManifest.activities || {}).map(([id, photos]) => [
      String(id),
      Array.isArray(photos) ? photos : [],
    ]),
  );
  let editorData = cloneData(mapData);
  const allPoints = [...mapData.trips, ...mapData.races, ...stravaTimelineItems];
  const allPointsBySlug = new Map(allPoints.map((point) => [point.slug, point]));
  const stravaTimelineItemByActivityId = new Map(stravaTimelineItems.map((item) => [String(item.stravaActivityId || ""), item]));
  const timelineDotBySlug = new Map(timelineDots.map((dot) => [dot.getAttribute("data-map-timeline-item"), dot]));
  const timelineSequence = timelineDots
    .map((dot) => {
      const item = allPointsBySlug.get(dot.getAttribute("data-map-timeline-item"));
      if (item) item.timelineTime = Number(dot.getAttribute("data-map-timeline-time")) || 0;
      return item;
    })
    .filter(Boolean);
  let activeTimelineSlug = "";
  let activeStravaActivityId = "";
  let stopLookupTimeout = 0;
  let stopLookupRequestId = 0;
  let editorDirty = false;
  let editorSaving = false;
  let generatedTripRoutes = null;
  let raceRouteFeaturesBySlug = new Map();
  let stravaRouteFeatureList = [];
  let stravaFeatureById = new Map();
  let tripPlaybackSegmentsCache = new Map();
  let routeCoordinatesCache = new Map();
  let coordinateDistanceCache = new WeakMap();
  let timelineTransitionRouteCache = new Map();
  const emptyFeatureCollection = { type: "FeatureCollection", features: [] };
  const stravaHeatTileZoom = 4;
  const stravaHeatDetailMinZoom = 3.15;
  let stravaHeatTileKeys = new Set();
  let stravaHeatTileCache = new Map();
  let stravaHeatTileInflight = new Map();
  let stravaHeatTileEventsBound = false;
  let activeTimelineDot = null;
  let activeTripRouteSegment = null;
  const layerVisibility = {
    flight: true,
    drive: true,
    sail: true,
    strava: true,
    race: true,
    dots: true,
  };
  let playbackStravaActivityId = "";
  let playbackRaceSlug = "";

  const clearPlaybackRouteCaches = () => {
    tripPlaybackSegmentsCache = new Map();
    routeCoordinatesCache = new Map();
    coordinateDistanceCache = new WeakMap();
  };

  const clearRouteRuntimeCaches = () => {
    clearPlaybackRouteCaches();
    timelineTransitionRouteCache = new Map();
  };

  const clampNumber = (value, min, max) => Math.min(max, Math.max(min, value));

  const normalizeLongitude = (longitude) => {
    const value = Number(longitude);
    if (!Number.isFinite(value)) return 0;
    return ((((value + 180) % 360) + 360) % 360) - 180;
  };

  const heatTileForLngLat = (longitude, latitude, zoom = stravaHeatTileZoom) => {
    const tileCount = 2 ** zoom;
    const safeLng = normalizeLongitude(longitude);
    const safeLat = clampNumber(Number(latitude) || 0, -85.05112878, 85.05112878);
    const latRad = (safeLat * Math.PI) / 180;
    const x = Math.floor(((safeLng + 180) / 360) * tileCount);
    const y = Math.floor(((1 - Math.asinh(Math.tan(latRad)) / Math.PI) / 2) * tileCount);
    return [clampNumber(x, 0, tileCount - 1), clampNumber(y, 0, tileCount - 1)];
  };

  const visibleStravaHeatTileKeys = () => {
    if (!map || map.getZoom() < stravaHeatDetailMinZoom || !stravaHeatTileKeys.size) return [];
    const bounds = map.getBounds();
    if (!bounds) return [];
    const tileCount = 2 ** stravaHeatTileZoom;
    const west = normalizeLongitude(bounds.getWest());
    const east = normalizeLongitude(bounds.getEast());
    const south = clampNumber(bounds.getSouth(), -85.05112878, 85.05112878);
    const north = clampNumber(bounds.getNorth(), -85.05112878, 85.05112878);
    const longitudeRanges = east < west ? [[west, 180], [-180, east]] : [[west, east]];
    const keys = new Set();

    longitudeRanges.forEach(([rangeWest, rangeEast]) => {
      const [westX, northY] = heatTileForLngLat(rangeWest, north, stravaHeatTileZoom);
      const [eastX, southY] = heatTileForLngLat(rangeEast, south, stravaHeatTileZoom);
      const minX = clampNumber(Math.min(westX, eastX) - 1, 0, tileCount - 1);
      const maxX = clampNumber(Math.max(westX, eastX) + 1, 0, tileCount - 1);
      const minY = clampNumber(Math.min(northY, southY) - 1, 0, tileCount - 1);
      const maxY = clampNumber(Math.max(northY, southY) + 1, 0, tileCount - 1);
      for (let x = minX; x <= maxX; x += 1) {
        for (let y = minY; y <= maxY; y += 1) {
          const key = `${stravaHeatTileZoom}/${x}/${y}`;
          if (stravaHeatTileKeys.has(key)) keys.add(key);
        }
      }
    });

    return [...keys];
  };

  const heatFeatureKey = (feature) => {
    const coordinates = feature?.geometry?.coordinates || [];
    const first = coordinates[0] || [];
    const last = coordinates[coordinates.length - 1] || [];
    return [
      feature?.properties?.heatColor || "",
      feature?.properties?.weight || "",
      coordinates.length,
      first[0],
      first[1],
      last[0],
      last[1],
    ].join(":");
  };

  const fetchStravaHeatTile = async (key) => {
    if (stravaHeatTileCache.has(key)) return stravaHeatTileCache.get(key);
    if (stravaHeatTileInflight.has(key)) return stravaHeatTileInflight.get(key);
    const request = fetch(dataUrl(`/data/route-tiles/strava-heat/${key}.geojson`), staticFetchOptions())
      .then((response) => (response?.ok ? response.json() : emptyFeatureCollection))
      .then((data) => {
        const features = Array.isArray(data?.features) ? data.features : [];
        stravaHeatTileCache.set(key, features);
        stravaHeatTileInflight.delete(key);
        return features;
      })
      .catch(() => {
        stravaHeatTileInflight.delete(key);
        stravaHeatTileCache.set(key, []);
        return [];
      });
    stravaHeatTileInflight.set(key, request);
    return request;
  };

  const updateStravaHeatTileSource = async () => {
    const source = map.getSource("strava-line-heatmap");
    if (!source || !("setData" in source)) return;
    if (!layerVisibility.strava || map.getZoom() < stravaHeatDetailMinZoom) {
      source.setData(emptyFeatureCollection);
      return;
    }
    const keys = visibleStravaHeatTileKeys();
    if (!keys.length) {
      source.setData(emptyFeatureCollection);
      return;
    }
    await Promise.all(keys.map(fetchStravaHeatTile));
    const seen = new Set();
    const features = [];
    keys.forEach((key) => {
      (stravaHeatTileCache.get(key) || []).forEach((feature) => {
        const dedupeKey = heatFeatureKey(feature);
        if (seen.has(dedupeKey)) return;
        seen.add(dedupeKey);
        features.push(feature);
      });
    });
    source.setData({ type: "FeatureCollection", features });
  };

  const loadStravaHeatTiles = async () => {
    const response = await fetch(dataUrl("/data/route-tiles/strava-heat/manifest.json"), staticFetchOptions()).catch(() => null);
    const manifest = response?.ok ? await response.json().catch(() => null) : null;
    const tiles = Array.isArray(manifest?.tiles) ? manifest.tiles : [];
    stravaHeatTileKeys = new Set(tiles);
    if (!stravaHeatTileEventsBound) {
      stravaHeatTileEventsBound = true;
      map.on("moveend", updateStravaHeatTileSource);
      map.on("zoomend", updateStravaHeatTileSource);
    }
    await updateStravaHeatTileSource();
  };

  const setActiveTimelineDot = (slug = "") => {
    const nextDot = slug ? timelineDotBySlug.get(slug) || null : null;
    if (nextDot === activeTimelineDot) return;
    if (activeTimelineDot) activeTimelineDot.classList.remove("is-active");
    activeTimelineDot = nextDot;
    if (activeTimelineDot) activeTimelineDot.classList.add("is-active");
  };

  const isFiniteCoordinate = (node) =>
    Number.isFinite(Number(node?.lat)) && Number.isFinite(Number(node?.lon));

  const showNodeOnMap = (node, defaultValue = true) => {
    if (node?.showOnMap === false) return false;
    if (node?.showOnMap === true) return true;
    return defaultValue;
  };

  const routeNodeFrom = (node, index) => {
    const routeNode = {
      title: node.title || `Stop ${index + 1}`,
      lat: Number(node.lat),
      lon: Number(node.lon),
    };
    if (node.showOnMap === false || node.showOnMap === true) routeNode.showOnMap = node.showOnMap;
    return routeNode;
  };

  const sameRouteCoordinate = (first, second) =>
    isFiniteCoordinate(first) &&
    isFiniteCoordinate(second) &&
    Math.abs(Number(first.lat) - Number(second.lat)) < 0.00001 &&
    Math.abs(Number(first.lon) - Number(second.lon)) < 0.00001;

  const sameLngLat = (first, second) =>
    Array.isArray(first) &&
    Array.isArray(second) &&
    Math.abs(Number(first[0]) - Number(second[0])) < 0.00001 &&
    Math.abs(Number(first[1]) - Number(second[1])) < 0.00001;

  const returnNodeForStart = (start, existing = {}) => ({
    title: `Return to ${start.title || "start"}`,
    lat: Number(start.lat),
    lon: Number(start.lon),
    showOnMap: showNodeOnMap(existing, false),
  });

  const routeNodesReturningToStart = (nodes) => {
    if (nodes.length < 2) return nodes;
    const start = nodes[0];
    const finalNode = nodes[nodes.length - 1];
    if (sameRouteCoordinate(start, finalNode)) {
      return [...nodes.slice(0, -1), returnNodeForStart(start, finalNode)];
    }
    return [...nodes, returnNodeForStart(start)];
  };

  const isReturnNode = (trip, index) =>
    Array.isArray(trip?.routeNodes) &&
    trip.routeNodes.length > 2 &&
    index === trip.routeNodes.length - 1 &&
    sameRouteCoordinate(trip.routeNodes[0], trip.routeNodes[index]);

  const hasRoutedTrip = (item) =>
    item.type === "trip" && Array.isArray(item.routeNodes) && item.routeNodes.filter(isFiniteCoordinate).length >= 2;

  const pointProperties = (item) => ({
    type: item.type,
    slug: item.slug,
    title: item.title,
    detail: item.detail,
    date: item.date,
    result: item.result || "",
    rank: item.rank || "",
    href: item.href || "",
    travelMode: item.travelMode || "",
  });

  const visibleMapPoints = allPoints.filter((item) => item.type !== "strava" && !hasRoutedTrip(item));

  const featureCollection = {
    type: "FeatureCollection",
    features: visibleMapPoints.map((item) => ({
      type: "Feature",
      geometry: { type: "Point", coordinates: [item.lon, item.lat] },
      properties: pointProperties(item),
    })),
  };

  const normalizedTripNodes = (trip) => {
    const nodes = Array.isArray(trip.routeNodes) ? trip.routeNodes.filter(isFiniteCoordinate) : [];
    if (nodes.length) {
      return routeNodesReturningToStart(
        nodes.map((node, index) => ({
          ...routeNodeFrom(node, index),
          title: node.title || (index === nodes.length - 1 ? trip.title : `Node ${index + 1}`),
        })),
      );
    }
    if (isFiniteCoordinate(trip)) {
      return [{ title: trip.title, lat: Number(trip.lat), lon: Number(trip.lon) }];
    }
    return [];
  };

  const tripNodeMap = (sourceData) =>
    new Map((sourceData.trips || []).map((trip) => [trip.slug, normalizedTripNodes(trip)]));
  let tripNodesBySlug = tripNodeMap(mapData);

  const sanitizedCoordinates = (coordinates) => {
    if (!Array.isArray(coordinates)) return [];
    return coordinates
      .filter((coord) => Array.isArray(coord) && Number.isFinite(Number(coord[0])) && Number.isFinite(Number(coord[1])))
      .map((coord) => [Number(coord[0]), Number(coord[1])]);
  };

  const toRadians = (degrees) => (degrees * Math.PI) / 180;
  const toDegrees = (radians) => (radians * 180) / Math.PI;

  const greatCircleCoordinates = (start, end, steps = 72) => {
    const lng1 = toRadians(start[0]);
    const lat1 = toRadians(start[1]);
    const lng2 = toRadians(end[0]);
    const lat2 = toRadians(end[1]);
    const delta =
      2 *
      Math.asin(
        Math.sqrt(
          Math.sin((lat2 - lat1) / 2) ** 2 +
            Math.cos(lat1) * Math.cos(lat2) * Math.sin((lng2 - lng1) / 2) ** 2,
        ),
      );

    if (!Number.isFinite(delta) || delta === 0) return [start, end];

    const coordinates = [];
    for (let index = 0; index <= steps; index += 1) {
      const fraction = index / steps;
      const a = Math.sin((1 - fraction) * delta) / Math.sin(delta);
      const b = Math.sin(fraction * delta) / Math.sin(delta);
      const x = a * Math.cos(lat1) * Math.cos(lng1) + b * Math.cos(lat2) * Math.cos(lng2);
      const y = a * Math.cos(lat1) * Math.sin(lng1) + b * Math.cos(lat2) * Math.sin(lng2);
      const z = a * Math.sin(lat1) + b * Math.sin(lat2);
      let lon = toDegrees(Math.atan2(y, x));
      const lat = toDegrees(Math.atan2(z, Math.sqrt(x * x + y * y)));

      const previous = coordinates[coordinates.length - 1]?.[0];
      if (Number.isFinite(previous)) {
        while (lon - previous > 180) lon -= 360;
        while (lon - previous < -180) lon += 360;
      }

      coordinates.push([Number(lon.toFixed(5)), Number(lat.toFixed(5))]);
    }
    return coordinates;
  };

  const segmentConfigForTrip = (trip, index) =>
    Array.isArray(trip.routeSegments) && trip.routeSegments[index] ? trip.routeSegments[index] : {};

  const shouldRenderTripSegment = (trip, index) => segmentConfigForTrip(trip, index).render !== false;

  const segmentModeForTrip = (trip, index) => {
    const configuredMode = segmentConfigForTrip(trip, index).mode || trip.travelMode || "drive";
    if (configuredMode === "flight" || configuredMode === "sail") return configuredMode;
    return "drive";
  };

  const segmentCoordinates = (trip, nodes, index) => {
    const config = segmentConfigForTrip(trip, index);
    const configuredCoordinates = sanitizedCoordinates(config.coordinates);
    if (configuredCoordinates.length > 1) return configuredCoordinates;

    const start = [nodes[index].lon, nodes[index].lat];
    const end = [nodes[index + 1].lon, nodes[index + 1].lat];
    return ["flight", "sail"].includes(segmentModeForTrip(trip, index))
      ? greatCircleCoordinates(start, end)
      : [start, end];
  };

  const createTripRouteCollections = (sourceData = mapData) => {
    const routeFeatures = [];
    const nodeFeatures = [];

    for (const trip of sourceData.trips || []) {
      const nodes = normalizedTripNodes(trip);
      const baseMode = trip.travelMode === "flight" ? "flight" : "drive";

      nodes.forEach((node, index) => {
        if (!showNodeOnMap(node)) return;
        nodeFeatures.push({
          type: "Feature",
          geometry: { type: "Point", coordinates: [node.lon, node.lat] },
          properties: {
            slug: trip.slug,
            title: trip.title,
            nodeTitle: node.title,
            nodeIndex: index,
            mode: index > 0 ? segmentModeForTrip(trip, index - 1) : baseMode,
            showOnMap: true,
          },
        });
      });

      for (let index = 0; index < nodes.length - 1; index += 1) {
        if (!shouldRenderTripSegment(trip, index)) continue;
        const mode = segmentModeForTrip(trip, index);
        const coordinates = segmentCoordinates(trip, nodes, index);
        if (coordinates.length < 2) continue;

        routeFeatures.push({
          type: "Feature",
          geometry: { type: "LineString", coordinates },
          properties: {
            slug: trip.slug,
            title: trip.title,
            mode,
            vehicle: segmentConfigForTrip(trip, index).vehicle || "",
            segmentIndex: index,
          },
        });
      }
    }

    return {
      routes: { type: "FeatureCollection", features: routeFeatures },
      nodes: { type: "FeatureCollection", features: nodeFeatures },
    };
  };

  let tripRouteCollections = createTripRouteCollections(editorData);
  const satelliteGlobeStyle = {
    version: 8,
    sources: {
      "esri-satellite": {
        type: "raster",
        tiles: ["https://services.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}"],
        tileSize: 256,
        maxzoom: 19,
        attribution: "Satellite imagery © Esri",
      },
      "mapbox-terrain-dem": {
        type: "raster-dem",
        url: "mapbox://mapbox.mapbox-terrain-dem-v1",
        tileSize: 512,
        maxzoom: 14,
      },
    },
    layers: [
      {
        id: "satellite",
        type: "raster",
        source: "esri-satellite",
        paint: {
          "raster-saturation": -0.08,
          "raster-contrast": 0.05,
          "raster-brightness-min": 0.03,
          "raster-brightness-max": 0.84,
        },
      },
    ],
  };

  const map = new mapboxgl.Map({
    container: mapElement,
    style: satelliteGlobeStyle,
    center: [-54, 28],
    zoom: mapElement.clientWidth < 680 ? 0.18 : 0.92,
    pitch: 0,
    projection: "globe",
    attributionControl: false,
    scrollZoom: true,
    antialias: true,
    minZoom: 0,
    maxZoom: 18,
  });

  map.scrollZoom.enable();
  map.dragRotate?.enable?.();
  map.touchZoomRotate?.enable?.();
  map.touchZoomRotate?.enableRotation?.();

  map.addControl(new mapboxgl.NavigationControl({ visualizePitch: true }), "top-right");

  const popupOffset = {
    top: [0, 18],
    bottom: [0, -18],
    left: [18, 0],
    right: [-18, 0],
    "top-left": [14, 14],
    "top-right": [-14, 14],
    "bottom-left": [14, -14],
    "bottom-right": [-14, -14],
  };

  const createPopup = (anchor = undefined) =>
    new mapboxgl.Popup({
      anchor,
      closeButton: false,
      closeOnClick: false,
      offset: popupOffset,
      className: "map-popup",
    });

  const playbackNodeTagElement = document.createElement("div");
  playbackNodeTagElement.className = "map-node-callout";
  const playbackNodeMarker = new mapboxgl.Marker({
    element: playbackNodeTagElement,
    anchor: "bottom",
    offset: [0, -18],
  });
  const playbackPhotoPinElement = document.createElement("span");
  playbackPhotoPinElement.className = "map-photo-pin";
  const playbackPhotoPinMarker = new mapboxgl.Marker({
    element: playbackPhotoPinElement,
    anchor: "center",
  });
  const playbackPhotoElement = document.createElement("figure");
  playbackPhotoElement.className = "map-photo-callout";
  const playbackPhotoMarker = new mapboxgl.Marker({
    element: playbackPhotoElement,
    anchor: "bottom",
    offset: [0, -24],
  });

  let popup = createPopup();
  let popupTimer = 0;
  let popupSequence = 0;
  let activePopupChoices = [];
  let activePopupChoiceIndex = 0;
  let activePopupCoordinate = null;
  let handledInteractiveClick = false;
  let scrubPlaybackPopupSlug = "";
  let scrubPlaybackPopupAnchor = "";
  let scrubPlaybackPopupPreferredAnchor = "";
  let activePlaybackNodeKey = "";
  let activePlaybackPhotoKey = "";

  const escapeHtml = (value) =>
    String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");

  const updateActiveSummary = (item) => {
    if (!item) return;
    if (scrubberTitleElement) scrubberTitleElement.textContent = `${item.title || "Timeline item"}, ${item.date || ""}`;
  };

  const popupHtml = (item) => {
    if (item.type === "strava") {
      return stravaPopupHtml({
        id: item.stravaActivityId,
        name: item.title,
        activityGroup: item.activityGroup,
        sportType: item.sportType,
        type: item.activityType || item.activityGroup,
        startDate: item.startDate || item.date,
        distanceMeters: item.distanceMeters,
      });
    }
    const meta =
      item.type === "race"
        ? [item.result, item.rank].filter(Boolean).map(escapeHtml).join("<br>")
        : escapeHtml(item.detail);
    const title = item.href
      ? `<a href="${escapeHtml(item.href)}">${escapeHtml(item.title)}</a>`
      : escapeHtml(item.title);
    return `<strong>${title}</strong><span>${escapeHtml(item.date)}</span><small>${meta}</small>`;
  };

  const helicopterPopupHtml = (segment = {}) => {
    const properties = segment.properties || {};
    const detail = [properties.startTitle, properties.endTitle].filter(Boolean).join(" to ");
    return `<strong>Helicopter</strong><span>${escapeHtml(detail || "Scenic flight")}</span>`;
  };

  const stravaActivityUrl = (id) => {
    const activityId = String(id || "").trim();
    return activityId ? `https://www.strava.com/activities/${encodeURIComponent(activityId)}` : "";
  };

  const linkedTitleHtml = (title, href) =>
    href
      ? `<a href="${escapeHtml(href)}" target="_blank" rel="noreferrer">${escapeHtml(title)}</a>`
      : escapeHtml(title);

  const humanizeActivityType = (value) =>
    String(value || "")
      .replace(/[_-]/g, " ")
      .replace(/([a-z])([A-Z])/g, "$1 $2")
      .trim();

  const activityDisplayLabel = (properties = {}) => {
    const raw = String(properties.sportType || properties.type || properties.activityType || properties.activityGroup || "").trim();
    const normalized = humanizeActivityType(raw).toLowerCase();
    if (/trail\s*run/.test(normalized)) return "Trail run";
    if (/tennis/.test(normalized)) return "Tennis";
    if (/hike/.test(normalized)) return "Hike";
    if (/walk/.test(normalized)) return "Walk";
    if (/kayak/.test(normalized)) return "Kayak";
    if (/canoe/.test(normalized)) return "Canoe";
    if (/row|paddle/.test(normalized)) return "Paddle";
    if (/swim/.test(normalized)) return "Swim";
    if (/ski|snowboard/.test(normalized)) return "Ski";
    if (/mountain.*bike/.test(normalized)) return "Mountain bike";
    if (/ride|bike|cycling/.test(normalized)) return "Ride";
    if (/run/.test(normalized)) return "Run";
    return humanizeActivityType(raw || properties.activityGroup || "Strava");
  };

  const choiceLabel = (choice) => {
    if (choice.kind === "strava") return activityDisplayLabel(choice.properties || {});
    return choice.item?.type === "race" ? "Race" : "Trip";
  };

  const choiceTitle = (choice) =>
    choice.kind === "strava" ? choice.properties.name || "Strava route" : choice.item?.title || "Route";

  const choiceDetails = (choice) => {
    if (choice.kind === "strava") {
      const miles = Number(choice.properties.distanceMeters || 0) / 1609.344;
      const distance = miles > 0 ? `${miles.toFixed(1)} mi` : "";
      return [distance, String(choice.properties.startDate || "").slice(0, 10)]
        .filter(Boolean)
        .join(" / ");
    }
    if (choice.item?.type === "race") return [choice.item.date, choice.item.result].filter(Boolean).join(" / ");
    return [choice.item?.date, choice.item?.detail].filter(Boolean).join(" / ");
  };

  const popupChoicePanelHtml = (choice) => {
    const title = choiceTitle(choice);
    const href = choice.kind === "strava" ? stravaActivityUrl(choice.properties.id) : choice.item?.href;
    const detail = choiceDetails(choice);
    return `
      <div class="map-popup-stack__panel">
        <span>${escapeHtml(choiceLabel(choice))}</span>
        <strong>${linkedTitleHtml(title, href)}</strong>
        <small>${escapeHtml(detail)}</small>
      </div>
    `;
  };

  const stackedPopupHtml = (choices, activeIndex = 0) => `
    <div class="map-popup-stack" data-map-popup-stack>
      <div class="map-popup-stack__header">
        <button type="button" data-popup-stack-step="-1" aria-label="Previous route">‹</button>
        <span>${activeIndex + 1} / ${choices.length}</span>
        <button type="button" data-popup-stack-step="1" aria-label="Next route">›</button>
      </div>
      <div data-popup-stack-panel>${popupChoicePanelHtml(choices[activeIndex])}</div>
    </div>
  `;

  const setRouteHighlight = (slug, segmentIndex = null) => {
    const visibleModes = ["flight", "drive", "sail"].filter((mode) => layerVisibility[mode]);
    const finiteSegmentIndex = Number(segmentIndex);
    const filter =
      slug && visibleModes.length
        ? [
            "all",
            ["==", ["get", "slug"], slug],
            ["in", ["get", "mode"], ["literal", visibleModes]],
            ...(Number.isFinite(finiteSegmentIndex) ? [["==", ["get", "segmentIndex"], finiteSegmentIndex]] : []),
          ]
        : ["==", ["get", "slug"], ""];
    for (const layerId of ["trip-route-highlight-casing", "trip-route-highlight", "trip-route-node-highlight"]) {
      if (map.getLayer(layerId)) map.setFilter(layerId, filter);
    }
  };

  const setRaceRouteHighlight = (slug) => {
    const filter =
      slug && raceRouteFeaturesBySlug.has(slug)
        ? ["==", ["get", "raceSlug"], slug]
        : ["==", ["get", "raceSlug"], ""];
    for (const layerId of ["race-route-highlight-casing", "race-route-highlight"]) {
      if (map.getLayer(layerId)) map.setFilter(layerId, filter);
    }
  };

  const setMapPointLabelFilter = (activeItem = null) => {
    if (!map.getLayer("map-point-labels")) return;
    const selectedRaceSlug = activeItem?.type === "race" ? activeItem.slug : "";
    map.setFilter("map-point-labels", [
      "any",
      ["!=", ["get", "type"], "race"],
      ["==", ["get", "slug"], selectedRaceSlug],
    ]);
  };

  const setStravaRouteHighlight = (activityId) => {
    const id = Number(activityId);
    const filter = Number.isFinite(id) && id > 0 ? ["==", ["get", "id"], id] : ["==", ["get", "id"], ""];
    for (const layerId of ["strava-route-highlight-casing", "strava-route-highlight"]) {
      if (map.getLayer(layerId)) map.setFilter(layerId, filter);
    }
  };

  const raceRouteCoordinates = (slug) =>
    (raceRouteFeaturesBySlug.get(slug) || []).flatMap((feature) =>
      sanitizedCoordinates(feature.geometry?.coordinates),
    );

  const raceRouteAnchorCoordinate = (slug) => {
    const coordinates = raceRouteCoordinates(slug);
    return coordinates.length ? coordinates[Math.floor(coordinates.length / 2)] : null;
  };

  const routePopupPlacement = (coordinate = null, options = {}) => {
    const compact = mapElement.clientWidth < 680;
    const projected =
      Array.isArray(coordinate) && Number.isFinite(Number(coordinate[0])) && Number.isFinite(Number(coordinate[1]))
        ? map.project(coordinate)
        : { x: mapElement.clientWidth / 2, y: mapElement.clientHeight / 2 };
    const preferredAnchor = String(options.preferredAnchor || "");
    const topEdge = compact ? 126 : 108;
    const bottomEdge = mapElement.clientHeight - (compact ? 174 : 132);
    const sidePadding = Math.round(Math.min(mapElement.clientWidth * (compact ? 0.62 : 0.3), compact ? 220 : 340));
    const baseX = compact ? 38 : 82;
    const top = compact ? 76 : 92;
    const bottom = compact ? 110 : 76;

    if (compact) {
      const preferredVertical = preferredAnchor === "top" || preferredAnchor === "bottom" ? preferredAnchor : "";
      const anchor =
        projected.y < topEdge
          ? "top"
          : projected.y > bottomEdge
            ? "bottom"
            : preferredVertical || "bottom";

      return {
        anchor,
        padding:
          anchor === "top"
            ? { top, bottom: Math.max(bottom, sidePadding), left: baseX, right: baseX }
            : { top: Math.max(top, sidePadding), bottom, left: baseX, right: baseX },
      };
    }

    const verticalAnchor =
      projected.y < topEdge ? "top" : projected.y > bottomEdge ? "bottom" : "";
    const naturalHorizontalAnchor = projected.x < mapElement.clientWidth / 2 ? "left" : "right";
    const preferredHorizontal = preferredAnchor.includes("left")
      ? "left"
      : preferredAnchor.includes("right")
        ? "right"
        : "";
    const horizontalAnchor =
      projected.x < mapElement.clientWidth * 0.28
        ? "left"
        : projected.x > mapElement.clientWidth * 0.72
          ? "right"
          : preferredHorizontal || naturalHorizontalAnchor;
    const anchor = verticalAnchor ? `${verticalAnchor}-${horizontalAnchor}` : horizontalAnchor;

    return {
      anchor,
      padding:
        horizontalAnchor === "right"
          ? { top, bottom, left: Math.max(baseX, sidePadding), right: baseX }
          : { top, bottom, left: baseX, right: Math.max(baseX, sidePadding) },
    };
  };

  const nudgePopupIntoMapBounds = (targetPopup = popup) => {
    const popupElement = targetPopup?.getElement?.();
    if (!popupElement?.isConnected) return;

    const mapRect = mapElement.getBoundingClientRect();
    const popupRect = popupElement.getBoundingClientRect();
    const margin = mapElement.clientWidth < 680 ? 10 : 14;
    let x = 0;
    let y = 0;

    if (popupRect.left < mapRect.left + margin) x += mapRect.left + margin - popupRect.left;
    if (popupRect.right > mapRect.right - margin) x -= popupRect.right - (mapRect.right - margin);
    if (popupRect.top < mapRect.top + margin) y += mapRect.top + margin - popupRect.top;
    if (popupRect.bottom > mapRect.bottom - margin) y -= popupRect.bottom - (mapRect.bottom - margin);

    if (Math.abs(x) > 0.5 || Math.abs(y) > 0.5) targetPopup.setOffset([x, y]);
  };

  const requestPopupBoundsCheck = (targetPopup = popup) => {
    window.requestAnimationFrame(() => {
      window.requestAnimationFrame(() => nudgePopupIntoMapBounds(targetPopup));
    });
  };

  const clearScheduledPopup = () => {
    popupSequence += 1;
    if (popupTimer) window.clearTimeout(popupTimer);
    popupTimer = 0;
    scrubPlaybackPopupSlug = "";
    scrubPlaybackPopupAnchor = "";
    scrubPlaybackPopupPreferredAnchor = "";
  };

  const showPopup = (item, coordinate, anchor = undefined, waitForMove = false) => {
    clearScheduledPopup();
    popup.remove();
    const sequence = popupSequence;

    const renderPopup = () => {
      if (sequence !== popupSequence) return;
      popup.remove();
      const settledAnchor = waitForMove && coordinate ? routePopupPlacement(coordinate).anchor : anchor;
      popup = createPopup(settledAnchor);
      popup.setLngLat(coordinate).setHTML(popupHtml(item)).addTo(map);
    };

    if (!waitForMove) {
      renderPopup();
      return;
    }

    let rendered = false;
    let timerId = 0;
    const renderOnce = () => {
      if (rendered) return;
      rendered = true;
      map.off("moveend", renderOnce);
      if (sequence !== popupSequence) return;
      if (popupTimer === timerId) {
        window.clearTimeout(popupTimer);
        popupTimer = 0;
      }
      renderPopup();
    };

    map.once("moveend", renderOnce);
    timerId = window.setTimeout(renderOnce, 980);
    popupTimer = timerId;
  };

  const showScrubPlaybackPopup = (state) => {
    if (!state?.item || !state.coordinate) return;
    if (state.inGap) {
      clearScheduledPopup();
      popup.remove();
      return;
    }
    const segment = state.segment || {};
    const popupKey =
      segment.kind === "strava"
        ? `strava:${segment.properties?.id || ""}`
        : segment.kind === "race"
          ? `race:${segment.item?.slug || ""}`
          : isHelicopterSegment(segment)
            ? `helicopter:${state.item.slug}:${segment.segmentIndex ?? ""}`
          : `item:${state.item.slug}`;
    const placement = routePopupPlacement(state.coordinate, {
      preferredAnchor: popupKey === scrubPlaybackPopupSlug ? scrubPlaybackPopupPreferredAnchor : "",
    });
    const html =
      segment.kind === "strava"
        ? stravaPopupHtml(segment.properties || {})
        : isHelicopterSegment(segment)
          ? helicopterPopupHtml(segment)
          : popupHtml(segment.kind === "race" && segment.item ? segment.item : state.item);
    const shouldCreate = !popup?.isOpen?.() || scrubPlaybackPopupSlug !== popupKey || scrubPlaybackPopupAnchor !== placement.anchor;
    if (shouldCreate) {
      clearScheduledPopup();
      popup.remove();
      popup = createPopup(placement.anchor);
      popup.setLngLat(state.coordinate).setHTML(html).addTo(map);
      scrubPlaybackPopupSlug = popupKey;
      scrubPlaybackPopupAnchor = placement.anchor;
      scrubPlaybackPopupPreferredAnchor = placement.anchor;
      return;
    }
    scrubPlaybackPopupPreferredAnchor = placement.anchor;
    popup.setLngLat(state.coordinate);
  };

  const longestFlightFeatureForTrip = (item) => {
    const features = (tripRouteCollections.routes.features || []).filter(
      (feature) => feature.properties?.slug === item.slug && feature.properties?.mode === "flight",
    );
    return features.reduce(
      (best, feature) => {
        const coordinates = sanitizedCoordinates(feature.geometry?.coordinates);
        const distance = pathDistance(coordinates);
        return distance > best.distance ? { feature, coordinates, distance } : best;
      },
      { feature: null, coordinates: [], distance: 0 },
    );
  };

  const fitLongFlightTrip = (item) => {
    const flight = longestFlightFeatureForTrip(item);
    if (flight.distance < 4500) return false;
    const center = coordinateAtProgress(flight.coordinates, 0.5) || [item.lon, item.lat];
    map.easeTo({
      center,
      zoom: mapElement.clientWidth < 680 ? 0.55 : 1.08,
      bearing: 0,
      pitch: 0,
      duration: 900,
      easing: (time) => 1 - (1 - time) ** 3,
      essential: true,
    });
    return true;
  };

  const isHelicopterSegment = (segment) =>
    /helicopter|heli/.test(String(`${segment?.vehicle || ""} ${segment?.properties?.vehicle || ""} ${segment?.properties?.label || ""}`).toLowerCase());

  const fitTripRouteSegment = (item, routeSegment, placement = null) => {
    const coordinates = sanitizedCoordinates(routeSegment?.coordinates);
    if (!item || coordinates.length < 2) return false;

    const bounds = new mapboxgl.LngLatBounds();
    coordinates.forEach((coordinate) => bounds.extend(coordinate));
    if (bounds.isEmpty()) return false;

    const distance = cachedPathDistance(coordinates);
    const isCompact = mapElement.clientWidth < 680;
    const mode = normalizePlaybackMode(`${routeSegment.vehicle || ""} ${routeSegment.mode || ""}`);
    const helicopter = isHelicopterSegment(routeSegment);
    const maxZoom =
      helicopter
        ? distance < 120 ? (isCompact ? 8.2 : 9.0) : (isCompact ? 7.2 : 8.0)
        : mode === "plane"
          ? distance > 2400
            ? (isCompact ? 1.2 : 1.9)
            : (isCompact ? 3.9 : 4.8)
          : mode === "boat"
            ? routeMaxZoomForDistance(distance, "activity") - 0.35
            : routeMaxZoomForDistance(distance, "activity") - 0.15;

    map.fitBounds(bounds, {
      padding: placement?.padding || (isCompact ? 58 : { top: 104, bottom: 74, left: 86, right: 86 }),
      maxZoom,
      pitch: mode === "plane" && !helicopter ? 0 : isCompact ? 30 : 38,
      duration: 760,
    });
    return true;
  };

  const fitTripRoute = (item, placement = null) => {
    const nodes = tripNodesBySlug.get(item.slug) || [];
    if (nodes.length < 2) return false;

    if (item.travelMode === "flight" && fitLongFlightTrip(item)) return true;

    const bounds = new mapboxgl.LngLatBounds();
    nodes.forEach((node) => bounds.extend([node.lon, node.lat]));
    if (bounds.isEmpty()) return false;

    const isCompact = mapElement.clientWidth < 680;
    map.fitBounds(bounds, {
      padding: placement?.padding || (isCompact ? 58 : { top: 104, bottom: 74, left: 86, right: 86 }),
      maxZoom: item.travelMode === "flight" ? 4.7 : 7,
      pitch: item.travelMode === "flight" ? 0 : isCompact ? 30 : 38,
      duration: 850,
    });
    return true;
  };

  const routeMaxZoomForDistance = (distanceKm, kind = "activity") => {
    const compact = mapElement.clientWidth < 680;
    const distance = Math.max(0, Number(distanceKm) || 0);
    if (distance < 2) return compact ? 15.4 : 16.1;
    if (distance < 7) return compact ? 14.2 : 15.1;
    if (distance < 15) return compact ? 13.2 : 14.1;
    if (distance < 35) return compact ? 12.0 : 12.9;
    if (distance < 85) return compact ? 10.7 : 11.6;
    if (distance < 180) return compact ? 9.4 : 10.2;
    if (kind === "race") return compact ? 8.7 : 9.4;
    return compact ? 8.2 : 9.0;
  };

  const fitRaceRoute = (item, placement = null) => {
    const coordinates = raceRouteCoordinates(item.slug);
    if (coordinates.length < 2) return false;

    const bounds = new mapboxgl.LngLatBounds();
    coordinates.forEach((coordinate) => bounds.extend(coordinate));
    if (bounds.isEmpty()) return false;

    map.fitBounds(bounds, {
      padding: placement?.padding || (mapElement.clientWidth < 680 ? 48 : { top: 92, bottom: 76, left: 82, right: 82 }),
      maxZoom: routeMaxZoomForDistance(cachedPathDistance(coordinates), "race"),
      pitch: mapElement.clientWidth < 680 ? 34 : 42,
      duration: 850,
    });
    return true;
  };

  const fitStravaItemRoute = (item, placement = null) => {
    const coordinates = routeCoordinatesForItem(item);
    if (coordinates.length < 2) return false;

    const bounds = new mapboxgl.LngLatBounds();
    coordinates.forEach((coordinate) => bounds.extend(coordinate));
    if (bounds.isEmpty()) return false;

    map.fitBounds(bounds, {
      padding: placement?.padding || (mapElement.clientWidth < 680 ? 48 : { top: 92, bottom: 76, left: 82, right: 82 }),
      maxZoom: routeMaxZoomForDistance(cachedPathDistance(coordinates), "strava"),
      pitch: mapElement.clientWidth < 680 ? 36 : 46,
      duration: 760,
    });
    return true;
  };

  const fitRoute = (slug) => {
    const item = [...editorData.trips, ...allPoints].find((point) => point.slug === slug);
    return item ? fitTripRoute(item) : false;
  };

  const routeAnchorCoordinate = (slug) => {
    const routeCoordinates = (tripRouteCollections.routes.features || [])
      .filter((feature) => feature.properties?.slug === slug)
      .flatMap((feature) => sanitizedCoordinates(feature.geometry?.coordinates));

    if (routeCoordinates.length) return routeCoordinates[Math.floor(routeCoordinates.length / 2)];

    const nodes = tripNodesBySlug.get(slug) || [];
    const node = nodes[Math.floor(nodes.length / 2)];
    return node ? [node.lon, node.lat] : null;
  };

  const popupCoordinateForItem = (item, preferredCoordinate = null) => {
    if (Array.isArray(preferredCoordinate) && preferredCoordinate.length >= 2) return preferredCoordinate;
    if (item.type === "trip" && hasRoutedTrip(item)) return routeAnchorCoordinate(item.slug) || [item.lon, item.lat];
    if (item.type === "race") return raceRouteAnchorCoordinate(item.slug) || [item.lon, item.lat];
    if (item.type === "strava") return coordinateAtProgress(routeCoordinatesForItem(item), 0.5) || [item.lon, item.lat];
    return [item.lon, item.lat];
  };

  const emptyProgressMarkerData = { type: "FeatureCollection", features: [] };
  const emptyTransitionRouteData = { type: "FeatureCollection", features: [] };
  const scrubberUnitsPerItem = 100;
  const scrubberRoutePortion = 0.82;
  const scrubberMaxValue = Math.max(1, timelineSequence.length * scrubberUnitsPerItem);
  let scrubberValue = Number(timelineRail?.getAttribute("data-initial-scrub-value")) || 0;
  let currentScrubState = null;
  let syncingTimelineScroll = false;
  const timelineStartTime = Number(timelineRail?.getAttribute("data-timeline-start")) || 0;
  const timelineEndTime = Number(timelineRail?.getAttribute("data-timeline-end")) || timelineStartTime + 1;
  const timelineFocusStartTime = Number(timelineRail?.getAttribute("data-timeline-focus-start")) || timelineStartTime;
  const timelineTimeSpan = Math.max(1, timelineEndTime - timelineStartTime);
  const timelineMinZoomWidth = 100;
  const timelineMaxZoomWidth = 2400;
  let timelineZoomWidth = Math.min(
    timelineMaxZoomWidth,
    Math.max(timelineMinZoomWidth, parseFloat(timelineRail?.style.getPropertyValue("--timeline-width")) || timelineMinZoomWidth),
  );

  const updateTimelineDetailDensity = () => {
    if (!timelineRail) return;
    const monthCount = Math.max(1, Math.ceil(timelineTimeSpan / (30.4375 * dayMs)));
    const pixelsPerMonth = timelineAxisWidth() / monthCount;
    timelineRail.classList.toggle("is-month-detail", pixelsPerMonth >= 18);
    timelineRail.classList.toggle("is-full-month-detail", pixelsPerMonth >= 34);
  };

  const setTimelineZoomWidth = (value) => {
    timelineZoomWidth = Math.min(timelineMaxZoomWidth, Math.max(timelineMinZoomWidth, Number(value) || timelineMinZoomWidth));
    if (timelineRail) timelineRail.style.setProperty("--timeline-width", `${timelineZoomWidth}%`);
    window.requestAnimationFrame(updateTimelineDetailDensity);
  };

  const routeCoordinatesForTrip = (slug) => {
    const features = tripRouteFeaturesForSlug(slug);

    const coordinates = [];
    features.forEach((feature) => {
      const segment = sanitizedCoordinates(feature.geometry?.coordinates);
      if (!segment.length) return;
      const nextSegment = coordinates.length && sameLngLat(coordinates[coordinates.length - 1], segment[0])
        ? segment.slice(1)
        : segment;
      coordinates.push(...nextSegment);
    });
    return coordinates;
  };

  const tripRouteFeaturesForSlug = (slug) =>
    (tripRouteCollections.routes.features || [])
      .filter((feature) => feature.properties?.slug === slug)
      .sort((first, second) => Number(first.properties?.segmentIndex ?? 0) - Number(second.properties?.segmentIndex ?? 0));

  const tripRouteFeatureForSegment = (slug, segmentIndex) =>
    tripRouteFeaturesForSlug(slug).find((feature) => Number(feature.properties?.segmentIndex) === Number(segmentIndex)) || null;

  const tripRouteSegmentFromFeature = (feature, clickedCoordinate = null) => {
    const properties = feature?.properties || {};
    const slug = properties.slug || "";
    const segmentIndex = Number(properties.segmentIndex);
    if (!slug || !Number.isFinite(segmentIndex)) return null;
    const fullFeature = tripRouteFeatureForSegment(slug, segmentIndex) || feature;
    const coordinates = sanitizedCoordinates(fullFeature.geometry?.coordinates || feature.geometry?.coordinates);
    if (coordinates.length < 2) return null;
    const nearest = clickedCoordinate
      ? progressForCoordinateInSegments([{ coordinates }], clickedCoordinate)
      : { progress: 0.5, coordinate: coordinateAtProgress(coordinates, 0.5) };
    return {
      slug,
      segmentIndex,
      mode: properties.mode || fullFeature.properties?.mode || "",
      vehicle: properties.vehicle || fullFeature.properties?.vehicle || "",
      startTitle: properties.startTitle || fullFeature.properties?.startTitle || "",
      endTitle: properties.endTitle || fullFeature.properties?.endTitle || "",
      coordinates,
      clickProgress: Math.min(1, Math.max(0, Number(nearest.progress) || 0)),
      clickCoordinate: nearest.coordinate || clickedCoordinate || coordinateAtProgress(coordinates, 0.5),
    };
  };

  const tripRouteSegmentProgress = (item, routeSegment, fallbackCoordinate = null) => {
    if (!item || !routeSegment) return null;
    const baseSegments = playbackBaseSegmentsForTrip(item);
    if (!baseSegments.length) return null;
    const totalDistance = baseSegments.reduce((sum, segment) => sum + cachedPathDistance(segment.coordinates), 0);
    if (!Number.isFinite(totalDistance) || totalDistance <= 0) return null;

    let traversedDistance = 0;
    for (const segment of baseSegments) {
      const distance = cachedPathDistance(segment.coordinates);
      if (Number(segment.segmentIndex) === Number(routeSegment.segmentIndex)) {
        const progress =
          Number.isFinite(Number(routeSegment.clickProgress))
            ? Number(routeSegment.clickProgress)
            : progressForCoordinateInSegments([{ coordinates: segment.coordinates }], fallbackCoordinate).progress;
        return Math.min(1, Math.max(0, (traversedDistance + distance * Math.min(1, Math.max(0, progress))) / totalDistance));
      }
      traversedDistance += Math.max(0, distance || 0);
    }
    return null;
  };

  const playbackBaseSegmentsForTrip = (trip) =>
    tripRouteFeaturesForSlug(trip.slug)
      .map((feature) => ({
        kind: "trip",
        item: trip,
        segmentIndex: Number(feature.properties?.segmentIndex),
        mode: feature.properties?.mode || trip.travelMode || "drive",
        vehicle: feature.properties?.vehicle || "",
        properties: feature.properties || {},
        coordinates: sanitizedCoordinates(feature.geometry?.coordinates),
      }))
      .filter((segment) => segment.coordinates.length >= 2);

  const modeForTripProgress = (trip, progress) => {
    const segments = playbackBaseSegmentsForTrip(trip);
    if (!segments.length) return trip.travelMode || "drive";
    const distances = segments.map((segment) => pathDistance(segment.coordinates));
    const totalDistance = distances.reduce((sum, distance) => sum + distance, 0);
    if (totalDistance <= 0) return segments[0]?.mode || trip.travelMode || "drive";
    const targetDistance = Math.min(Math.max(progress, 0), 1) * totalDistance;
    let cursor = 0;
    for (let index = 0; index < segments.length; index += 1) {
      cursor += distances[index];
      if (targetDistance <= cursor || index === segments.length - 1) return segments[index].mode || trip.travelMode || "drive";
    }
    return trip.travelMode || "drive";
  };

  const baseRouteCoordinatesForItem = (item) => {
    if (!item) return [];
    if (item.type === "trip") {
      const coordinates = routeCoordinatesForTrip(item.slug);
      if (coordinates.length) return coordinates;
    }
    if (item.type === "race") {
      const coordinates = raceRouteCoordinates(item.slug);
      if (coordinates.length) return coordinates;
    }
    if (item.type === "strava") {
      const coordinates = featureCoordinates(stravaFeatureForItem(item));
      if (coordinates.length) return coordinates;
    }
    return Number.isFinite(Number(item.lon)) && Number.isFinite(Number(item.lat)) ? [[item.lon, item.lat]] : [];
  };

  const routeCoordinatesForItem = (item) => {
    if (!item?.slug) return [];
    const cacheKey = `${item.type || "item"}:${item.slug}`;
    const cached = routeCoordinatesCache.get(cacheKey);
    if (cached) return cached;
    const coordinates = flattenPlaybackSegments(playbackSegmentsForItem(item));
    routeCoordinatesCache.set(cacheKey, coordinates);
    return coordinates;
  };

  const haversineDistance = (first, second) => {
    const radiusKm = 6371;
    const lat1 = toRadians(Number(first[1]));
    const lat2 = toRadians(Number(second[1]));
    const deltaLat = toRadians(Number(second[1]) - Number(first[1]));
    const deltaLon = toRadians(Number(second[0]) - Number(first[0]));
    const a =
      Math.sin(deltaLat / 2) ** 2 +
      Math.cos(lat1) * Math.cos(lat2) * Math.sin(deltaLon / 2) ** 2;
    return radiusKm * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  };

  const interpolateLngLat = (first, second, progress) => {
    const clampedProgress = Math.min(1, Math.max(0, Number(progress) || 0));
    const startLon = Number(first[0]);
    const startLat = Number(first[1]);
    let deltaLon = Number(second[0]) - startLon;
    while (deltaLon > 180) deltaLon -= 360;
    while (deltaLon < -180) deltaLon += 360;
    let lon = startLon + deltaLon * clampedProgress;
    while (lon > 180) lon -= 360;
    while (lon < -180) lon += 360;
    return [Number(lon.toFixed(5)), Number((startLat + (Number(second[1]) - startLat) * clampedProgress).toFixed(5))];
  };

  const pathDistance = (coordinates) => {
    let distance = 0;
    for (let index = 1; index < coordinates.length; index += 1) {
      distance += haversineDistance(coordinates[index - 1], coordinates[index]);
    }
    return distance;
  };

  const cachedPathDistance = (coordinates) => {
    if (!Array.isArray(coordinates)) return 0;
    const cached = coordinateDistanceCache.get(coordinates);
    if (cached !== undefined) return cached;
    const distance = pathDistance(coordinates);
    coordinateDistanceCache.set(coordinates, distance);
    return distance;
  };

  const routeMetricsForCoordinates = (coordinates) => {
    const sanitized = sanitizedCoordinates(coordinates);
    if (!sanitized.length) {
      return {
        center: null,
        distanceKm: 0,
        directKm: 0,
        widthKm: 0,
        heightKm: 0,
        diagonalKm: 0,
        compactness: 0,
      };
    }

    let minLon = sanitized[0][0];
    let maxLon = sanitized[0][0];
    let minLat = sanitized[0][1];
    let maxLat = sanitized[0][1];
    sanitized.forEach(([lon, lat]) => {
      minLon = Math.min(minLon, lon);
      maxLon = Math.max(maxLon, lon);
      minLat = Math.min(minLat, lat);
      maxLat = Math.max(maxLat, lat);
    });

    const center = [(minLon + maxLon) / 2, (minLat + maxLat) / 2];
    const widthKm = haversineDistance([minLon, center[1]], [maxLon, center[1]]);
    const heightKm = haversineDistance([center[0], minLat], [center[0], maxLat]);
    const diagonalKm = Math.sqrt(widthKm ** 2 + heightKm ** 2);
    const distanceKm = cachedPathDistance(sanitized);
    const directKm = sanitized.length > 1 ? haversineDistance(sanitized[0], sanitized[sanitized.length - 1]) : 0;
    return {
      center,
      distanceKm,
      directKm,
      widthKm,
      heightKm,
      diagonalKm,
      compactness: distanceKm / Math.max(diagonalKm, 0.03),
    };
  };

  const textForCinematicRouteState = (state) =>
    [
      state?.item?.title,
      state?.item?.detail,
      state?.item?.activityType,
      state?.item?.sportType,
      state?.item?.activityGroup,
      state?.segment?.properties?.name,
      state?.segment?.properties?.type,
      state?.segment?.properties?.sportType,
      state?.segment?.properties?.activityGroup,
      state?.segment?.mode,
      state?.segment?.vehicle,
    ]
      .filter(Boolean)
      .join(" ")
      .toLowerCase();

  const stableAngleForText = (text) => {
    let hash = 0;
    const value = String(text || "");
    for (let index = 0; index < value.length; index += 1) {
      hash = (hash * 31 + value.charCodeAt(index)) % 360;
    }
    return hash;
  };

  const cinematicRouteProfileForState = (state, coordinates) => {
    const metrics = routeMetricsForCoordinates(coordinates);
    if (!state?.item || state.inGap || playbackModeForState(state) === "plane" || metrics.distanceKm <= 0) {
      return { kind: "route", metrics };
    }

    const text = textForCinematicRouteState(state);
    const isCourtSport = /tennis|pickleball|basketball|spikeball/.test(text);
    const isNamedTrack = /\btrack\b|track workout|400m|800m|mile repeat|maf test/.test(text);
    const isWorkout = /workout|interval|repetition|other/.test(text);
    const isCompactWorkout = isWorkout && metrics.diagonalKm < 0.22 && metrics.distanceKm > 0.35;
    const isDenseLoop =
      metrics.distanceKm > 1.2 &&
      metrics.diagonalKm < 0.85 &&
      metrics.compactness > 7 &&
      metrics.directKm < Math.max(0.1, metrics.diagonalKm * 1.8);

    if (isCourtSport || isCompactWorkout) return { kind: "court", metrics };
    if ((isNamedTrack && metrics.diagonalKm < 1.0) || isDenseLoop) return { kind: "track", metrics };
    if (metrics.distanceKm > 2 && metrics.diagonalKm < 1.35 && metrics.compactness > 5 && metrics.directKm < metrics.distanceKm * 0.22) {
      return { kind: "loop", metrics };
    }
    return { kind: "route", metrics };
  };

  const isCompactCinematicProfile = (profile) => ["court", "track", "loop"].includes(profile?.kind);

  const compactRouteCinematicZoom = (profile) => {
    const compact = mapElement.clientWidth < 680;
    const diagonalKm = Math.max(0.03, Number(profile?.metrics?.diagonalKm) || 0.03);
    if (profile?.kind === "court") {
      if (diagonalKm < 0.08) return compact ? 16.9 : 17.35;
      if (diagonalKm < 0.18) return compact ? 16.55 : 17.05;
      return compact ? 16.15 : 16.65;
    }
    if (profile?.kind === "track") {
      if (diagonalKm < 0.35) return compact ? 15.8 : 16.45;
      if (diagonalKm < 0.7) return compact ? 15.35 : 15.95;
      return compact ? 14.85 : 15.45;
    }
    if (profile?.kind === "loop") {
      if (diagonalKm < 0.7) return compact ? 14.95 : 15.55;
      return compact ? 14.35 : 14.95;
    }
    return null;
  };

  const routeEndpointForItem = (item, endpoint = "end") => {
    const coordinates = routeCoordinatesForItem(item);
    if (coordinates.length) return endpoint === "start" ? coordinates[0] : coordinates[coordinates.length - 1];
    return Number.isFinite(Number(item?.lon)) && Number.isFinite(Number(item?.lat)) ? [Number(item.lon), Number(item.lat)] : null;
  };

  const transitionRouteKey = (start, end) =>
    `${Number(start[0]).toFixed(4)},${Number(start[1]).toFixed(4)}>${Number(end[0]).toFixed(4)},${Number(end[1]).toFixed(4)}`;

  const transitionModeForDistance = (distanceKm) => (distanceKm > 2400 ? "plane" : "car");

  const transitionFallbackCoordinates = (start, end, mode) =>
    mode === "plane" ? greatCircleCoordinates(start, end, 96) : [start, end];

  const fallbackTransitionSegment = (cachedSegment, start, end) => {
    const mode = normalizePlaybackMode(cachedSegment?.mode) || "car";
    return {
      ...cachedSegment,
      loading: false,
      mode,
      coordinates: transitionFallbackCoordinates(start, end, mode),
      routeProvider: mode === "plane" ? "great-circle-fallback" : "straight-line-drive-fallback",
    };
  };

  const requestTimelineTransitionRoute = (key, start, end) => {
    const cached = timelineTransitionRouteCache.get(key);
    if (!cached || cached.status !== "loading") return;

    fetchDriveRoute(
      { title: "Timeline transition start", lon: start[0], lat: start[1] },
      { title: "Timeline transition end", lon: end[0], lat: end[1] },
    )
      .then((route) => {
        const coordinates = sanitizedCoordinates(route.coordinates);
        if (coordinates.length >= 2) {
          timelineTransitionRouteCache.set(key, {
            status: "ready",
            segment: {
              ...cached.segment,
              loading: false,
              coordinates,
              routeProvider: "mapbox-directions",
              distanceMeters: route.distanceMeters,
              durationSeconds: route.durationSeconds,
            },
          });
          clearPlaybackRouteCaches();
          return;
        }
        timelineTransitionRouteCache.set(key, {
          status: "fallback",
          segment: fallbackTransitionSegment(cached.segment, start, end),
        });
        clearPlaybackRouteCaches();
      })
      .catch(() => {
        timelineTransitionRouteCache.set(key, {
          status: "fallback",
          segment: fallbackTransitionSegment(cached.segment, start, end),
        });
        clearPlaybackRouteCaches();
      });
  };

  const timelineTransitionSegment = (item, nextItem) => {
    const start = routeEndpointForItem(item, "end");
    const end = routeEndpointForItem(nextItem, "start");
    if (!start || !end) return null;

    const distanceKm = haversineDistance(start, end);
    if (!Number.isFinite(distanceKm) || distanceKm < 1.5) {
      return {
        kind: "transition",
        item,
        nextItem,
        mode: "car",
        coordinates: [start, end],
        distanceKm: Math.max(0, distanceKm || 0),
      };
    }

    const mode = transitionModeForDistance(distanceKm);
    const key = `${mode}:${transitionRouteKey(start, end)}`;
    const cached = timelineTransitionRouteCache.get(key);
    if (cached?.segment) return cached.segment;
    const shouldFetchDriveRoute = mode === "car";

    const segment = {
      kind: "transition",
      item,
      nextItem,
      mode,
      loading: shouldFetchDriveRoute,
      coordinates: transitionFallbackCoordinates(start, end, mode),
      distanceKm,
    };
    timelineTransitionRouteCache.set(key, { status: shouldFetchDriveRoute ? "loading" : "ready", segment });
    if (shouldFetchDriveRoute) requestTimelineTransitionRoute(key, start, end);
    return segment;
  };

  const routedConnectorSegment = (item, start, end) => {
    if (!Array.isArray(start) || !Array.isArray(end)) return null;
    const distanceKm = haversineDistance(start, end);
    if (!Number.isFinite(distanceKm) || distanceKm < 0.08) {
      return { kind: "connector", item, mode: "car", coordinates: [start, end], distanceKm: Math.max(0, distanceKm || 0) };
    }

    const mode = transitionModeForDistance(distanceKm);
    const key = `connector:${mode}:${transitionRouteKey(start, end)}`;
    const cached = timelineTransitionRouteCache.get(key);
    if (cached?.segment) return { ...cached.segment, item };

    const shouldFetchDriveRoute = mode === "car";
    const segment = {
      kind: "connector",
      item,
      mode,
      loading: shouldFetchDriveRoute,
      coordinates: transitionFallbackCoordinates(start, end, mode),
      distanceKm,
    };
    timelineTransitionRouteCache.set(key, { status: shouldFetchDriveRoute ? "loading" : "ready", segment });
    if (shouldFetchDriveRoute) requestTimelineTransitionRoute(key, start, end);
    return segment;
  };

  const prefetchUpcomingTimelineTransition = (state) => {
    if (!state?.item || state.inGap || !state.nextItem || state.routeProgress < 0.55) return;
    timelineTransitionSegment(state.item, state.nextItem);
  };

  const coordinateAtProgress = (coordinates, progress) => {
    if (!coordinates.length) return null;
    if (coordinates.length === 1) return coordinates[0];

    const totalDistance = cachedPathDistance(coordinates);
    if (!Number.isFinite(totalDistance) || totalDistance <= 0) return coordinates[0];

    const targetDistance = totalDistance * Math.min(1, Math.max(0, Number(progress) || 0));
    let traversedDistance = 0;
    for (let index = 1; index < coordinates.length; index += 1) {
      const start = coordinates[index - 1];
      const end = coordinates[index];
      const segmentDistance = haversineDistance(start, end);
      if (!Number.isFinite(segmentDistance) || segmentDistance <= 0) continue;
      if (traversedDistance + segmentDistance >= targetDistance) {
        return interpolateLngLat(start, end, (targetDistance - traversedDistance) / segmentDistance);
      }
      traversedDistance += segmentDistance;
    }
    return coordinates[coordinates.length - 1];
  };

  const coordinateIndexAtProgress = (coordinates, progress) => {
    if (!Array.isArray(coordinates) || coordinates.length < 2) return 0;
    const totalDistance = cachedPathDistance(coordinates);
    if (!Number.isFinite(totalDistance) || totalDistance <= 0) {
      return Math.min(coordinates.length - 1, Math.max(0, Math.round((Number(progress) || 0) * (coordinates.length - 1))));
    }

    const targetDistance = totalDistance * Math.min(1, Math.max(0, Number(progress) || 0));
    let traversedDistance = 0;
    for (let index = 1; index < coordinates.length; index += 1) {
      const segmentDistance = haversineDistance(coordinates[index - 1], coordinates[index]);
      if (!Number.isFinite(segmentDistance) || segmentDistance <= 0) continue;
      if (traversedDistance + segmentDistance >= targetDistance) return index;
      traversedDistance += segmentDistance;
    }
    return coordinates.length - 1;
  };

  const flattenPlaybackSegments = (segments) => {
    const coordinates = [];
    (segments || []).forEach((segment) => {
      const segmentCoordinates = sanitizedCoordinates(segment?.coordinates);
      if (!segmentCoordinates.length) return;
      const nextSegment = coordinates.length && sameLngLat(coordinates[coordinates.length - 1], segmentCoordinates[0])
        ? segmentCoordinates.slice(1)
        : segmentCoordinates;
      coordinates.push(...nextSegment);
    });
    return coordinates;
  };

  const coordinateAtProgressInSegments = (segments, progress) => {
    const usableSegments = (segments || [])
      .map((segment) => ({ ...segment, coordinates: sanitizedCoordinates(segment.coordinates) }))
      .filter((segment) => segment.coordinates.length);
    if (!usableSegments.length) return { coordinate: null, segment: null, segmentProgress: 0 };

    const distances = usableSegments.map((segment) => pathDistance(segment.coordinates));
    const totalDistance = distances.reduce((sum, distance) => sum + Math.max(0, distance), 0);
    if (!Number.isFinite(totalDistance) || totalDistance <= 0) {
      return { coordinate: usableSegments[0].coordinates[0], segment: usableSegments[0], segmentProgress: 0 };
    }

    const targetDistance = totalDistance * Math.min(1, Math.max(0, Number(progress) || 0));
    let traversedDistance = 0;
    for (let index = 0; index < usableSegments.length; index += 1) {
      const segmentDistance = Math.max(0, distances[index]);
      if (traversedDistance + segmentDistance >= targetDistance || index === usableSegments.length - 1) {
        const segmentProgress = segmentDistance > 0 ? (targetDistance - traversedDistance) / segmentDistance : 0;
        return {
          coordinate: coordinateAtProgress(usableSegments[index].coordinates, segmentProgress),
          segment: usableSegments[index],
          segmentIndex: index,
          segmentProgress: Math.min(1, Math.max(0, segmentProgress)),
        };
      }
      traversedDistance += segmentDistance;
    }

    const lastSegment = usableSegments[usableSegments.length - 1];
    return {
      coordinate: lastSegment.coordinates[lastSegment.coordinates.length - 1],
      segment: lastSegment,
      segmentIndex: usableSegments.length - 1,
      segmentProgress: 1,
    };
  };

  const progressForCoordinateInSegments = (segments, targetCoordinate) => {
    const usableSegments = (segments || [])
      .map((segment) => ({ ...segment, coordinates: sanitizedCoordinates(segment.coordinates) }))
      .filter((segment) => segment.coordinates.length >= 2);
    if (!usableSegments.length || !Array.isArray(targetCoordinate) || targetCoordinate.length < 2) {
      return { progress: 0, coordinate: null };
    }

    const targetLon = Number(targetCoordinate[0]);
    const targetLat = Number(targetCoordinate[1]);
    if (!Number.isFinite(targetLon) || !Number.isFinite(targetLat)) return { progress: 0, coordinate: null };

    const latScale = Math.cos(toRadians(targetLat)) || 1;
    const segmentDistances = usableSegments.map((segment) => cachedPathDistance(segment.coordinates));
    const totalDistance = segmentDistances.reduce((sum, distance) => sum + Math.max(0, distance), 0);
    if (!Number.isFinite(totalDistance) || totalDistance <= 0) return { progress: 0, coordinate: usableSegments[0].coordinates[0] };

    let traversedDistance = 0;
    let best = {
      distanceKm: Number.POSITIVE_INFINITY,
      traveledDistance: 0,
      coordinate: usableSegments[0].coordinates[0],
    };

    usableSegments.forEach((segment, segmentIndex) => {
      const coordinates = segment.coordinates;
      let traversedInSegment = 0;
      for (let index = 1; index < coordinates.length; index += 1) {
        const start = coordinates[index - 1];
        const end = coordinates[index];
        const segmentDistance = haversineDistance(start, end);
        if (!Number.isFinite(segmentDistance) || segmentDistance <= 0) continue;

        let deltaLon = Number(end[0]) - Number(start[0]);
        while (deltaLon > 180) deltaLon -= 360;
        while (deltaLon < -180) deltaLon += 360;
        const deltaLat = Number(end[1]) - Number(start[1]);
        const startX = Number(start[0]) * latScale;
        const startY = Number(start[1]);
        const targetX = targetLon * latScale;
        const targetY = targetLat;
        const vectorX = deltaLon * latScale;
        const vectorY = deltaLat;
        const vectorLengthSquared = vectorX * vectorX + vectorY * vectorY;
        const projectedProgress = vectorLengthSquared
          ? Math.min(1, Math.max(0, ((targetX - startX) * vectorX + (targetY - startY) * vectorY) / vectorLengthSquared))
          : 0;
        const candidate = interpolateLngLat(start, end, projectedProgress);
        const distanceKm = haversineDistance(candidate, targetCoordinate);
        if (distanceKm < best.distanceKm) {
          best = {
            distanceKm,
            traveledDistance: traversedDistance + traversedInSegment + segmentDistance * projectedProgress,
            coordinate: candidate,
          };
        }
        traversedInSegment += segmentDistance;
      }
      traversedDistance += Math.max(0, segmentDistances[segmentIndex] || 0);
    });

    return {
      progress: Math.min(1, Math.max(0, best.traveledDistance / totalDistance)),
      coordinate: best.coordinate,
    };
  };

  const dateMonthLookup = {
    jan: 0,
    feb: 1,
    mar: 2,
    apr: 3,
    may: 4,
    jun: 5,
    jul: 6,
    aug: 7,
    sep: 8,
    oct: 9,
    nov: 10,
    dec: 11,
  };
  const dayMs = 24 * 60 * 60 * 1000;

  const dateRangeForItem = (item) => {
    const configuredStart = Date.parse(item?.startDate || "");
    const configuredEnd = Date.parse(item?.endDate || "");
    if (configuredStart && configuredEnd) {
      return {
        start: Math.min(configuredStart, configuredEnd),
        end: Math.max(configuredStart, configuredEnd) + dayMs - 1,
      };
    }

    const normalized = String(item?.date || "").trim();
    const isoMatch = normalized.match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (isoMatch) {
      const [, year, month, day] = isoMatch;
      const time = Date.UTC(Number(year), Number(month) - 1, Number(day));
      return { start: time - 3 * dayMs, end: time + 3 * dayMs };
    }

    const exactMatch = normalized.match(/^([A-Za-z]+)\s+(\d{1,2}),?\s+(\d{4})$/);
    if (exactMatch) {
      const [, month, day, year] = exactMatch;
      const time = Date.UTC(Number(year), dateMonthLookup[month.slice(0, 3).toLowerCase()] ?? 0, Number(day));
      return { start: time - 3 * dayMs, end: time + 3 * dayMs };
    }

    const monthMatch = normalized.match(/^([A-Za-z]+)\s+(\d{4})$/);
    if (monthMatch) {
      const [, month, year] = monthMatch;
      const monthIndex = dateMonthLookup[month.slice(0, 3).toLowerCase()] ?? 0;
      const start = Date.UTC(Number(year), monthIndex, 1);
      const end = Date.UTC(Number(year), monthIndex + 1, 1) - 1;
      return { start, end };
    }

    const year = Number(normalized);
    if (Number.isFinite(year) && year > 1900) {
      return { start: Date.UTC(year, 0, 1), end: Date.UTC(year, 11, 31, 23, 59, 59) };
    }

    return { start: 0, end: 0 };
  };

  const itemDateTime = (item) => {
    const range = dateRangeForItem(item);
    return range.start && range.end ? (range.start + range.end) / 2 : 0;
  };

  const activityStartTime = (feature) => Date.parse(feature?.properties?.startDate || "") || 0;

  const sampleCoordinates = (coordinates, maxSamples = 24) => {
    const sanitized = sanitizedCoordinates(coordinates);
    if (sanitized.length <= maxSamples) return sanitized;
    const step = Math.max(1, Math.floor(sanitized.length / (maxSamples - 1)));
    const sampled = sanitized.filter((_, index) => index % step === 0);
    const last = sanitized[sanitized.length - 1];
    if (!sameLngLat(sampled[sampled.length - 1], last)) sampled.push(last);
    return sampled;
  };

  const featureCoordinates = (feature) => sanitizedCoordinates(feature?.geometry?.coordinates);

  const featureSampleCoordinates = (feature, maxSamples = 12) => sampleCoordinates(featureCoordinates(feature), maxSamples);

  const stravaFeatureForItem = (item) => {
    const id = String(item?.stravaActivityId || item?.id || "").trim();
    return id ? stravaFeatureById.get(id) || null : null;
  };

  const nodeCoordinates = (nodes) =>
    (nodes || []).filter(isFiniteCoordinate).map((node) => [Number(node.lon), Number(node.lat)]);

  const minDistanceBetween = (firstCoordinates, secondCoordinates) => {
    if (!firstCoordinates.length || !secondCoordinates.length) return Number.POSITIVE_INFINITY;
    let bestDistance = Number.POSITIVE_INFINITY;
    firstCoordinates.forEach((first) => {
      secondCoordinates.forEach((second) => {
        bestDistance = Math.min(bestDistance, haversineDistance(first, second));
      });
    });
    return bestDistance;
  };

  const nearestRoutePlacement = (routeCoordinates, coordinates) => {
    const routeSamples = sampleCoordinates(routeCoordinates, 160);
    const targetSamples = sampleCoordinates(coordinates, 10);
    if (!routeSamples.length || !targetSamples.length) {
      return { distanceKm: Number.POSITIVE_INFINITY, progress: 0 };
    }

    let bestDistance = Number.POSITIVE_INFINITY;
    let bestProgress = 0;
    targetSamples.forEach((target) => {
      routeSamples.forEach((routeCoordinate, index) => {
        const distance = haversineDistance(routeCoordinate, target);
        if (distance < bestDistance) {
          bestDistance = distance;
          bestProgress = routeSamples.length > 1 ? index / (routeSamples.length - 1) : 0;
        }
      });
    });
    return { distanceKm: bestDistance, progress: bestProgress };
  };

  const nearestGroundRoutePlacementForTrip = (trip, baseCoordinates, coordinates) => {
    const baseSegments = playbackBaseSegmentsForTrip(trip);
    const totalDistance = baseSegments.reduce((sum, segment) => sum + cachedPathDistance(segment.coordinates), 0);
    if (!baseSegments.length || !Number.isFinite(totalDistance) || totalDistance <= 0) {
      return nearestRoutePlacement(baseCoordinates, coordinates);
    }

    const targetSamples = sampleCoordinates(coordinates, 10);
    if (!targetSamples.length) return nearestRoutePlacement(baseCoordinates, coordinates);

    let traversedDistance = 0;
    let best = {
      distanceKm: Number.POSITIVE_INFINITY,
      progress: 0,
    };

    for (const segment of baseSegments) {
      const segmentDistance = cachedPathDistance(segment.coordinates);
      const segmentMode = String(segment.mode || trip.travelMode || "").toLowerCase();
      const isFlightSegment = segmentMode.includes("flight") || segmentMode.includes("plane");
      if (!isFlightSegment) {
        const routeSamples = sampleCoordinates(segment.coordinates, 96);
        targetSamples.forEach((target) => {
          routeSamples.forEach((routeCoordinate, index) => {
            const distance = haversineDistance(routeCoordinate, target);
            if (distance < best.distanceKm) {
              const segmentProgress = routeSamples.length > 1 ? index / (routeSamples.length - 1) : 0;
              best = {
                distanceKm: distance,
                progress: Math.min(1, Math.max(0, (traversedDistance + segmentDistance * segmentProgress) / totalDistance)),
              };
            }
          });
        });
      }
      traversedDistance += Math.max(0, segmentDistance || 0);
    }

    return Number.isFinite(best.distanceKm) ? best : nearestRoutePlacement(baseCoordinates, coordinates);
  };

  const isHomeLikeNode = (node) => {
    const title = String(node?.title || "").toLowerCase();
    return (
      title.startsWith("return to ") ||
      title.startsWith("back to ") ||
      /\b(san francisco|sfo|san francisco international|santa clara|san luis obispo|slo)\b/.test(title)
    );
  };

  const tripAnchorNodes = (trip) => {
    const nodes = tripNodesBySlug.get(trip.slug) || [];
    const interiorNodes = nodes.filter((node, index) => index > 0 && index < nodes.length - 1 && !isHomeLikeNode(node));
    if (interiorNodes.length) return interiorNodes;
    return nodes.filter((node, index) => index > 0 && index < nodes.length - 1);
  };

  const tripDateContains = (trip, time, padDays = 1) => {
    const range = dateRangeForItem(trip);
    return Boolean(time && range.start && range.end && time >= range.start - padDays * dayMs && time <= range.end + padDays * dayMs);
  };

  const racePlaybackSegmentsForItem = (race) =>
    [...(raceRouteFeaturesBySlug.get(race.slug) || [])]
      .sort((first, second) => Number(first.properties?.segmentIndex || 0) - Number(second.properties?.segmentIndex || 0))
      .map((feature, index) => ({
        kind: "race",
        item: race,
        properties: feature.properties || {},
        coordinates: sanitizedCoordinates(feature.geometry?.coordinates),
        segmentIndex: Number(feature.properties?.segmentIndex ?? index),
      }))
      .filter((segment) => segment.coordinates.length >= 2);

  const raceTripPlacement = (trip, race, baseCoordinates, anchorCoordinates) => {
    const raceTime = itemDateTime(race);
    if (!tripDateContains(trip, raceTime, 2)) return null;
    const raceCoordinate = Number.isFinite(Number(race.lon)) && Number.isFinite(Number(race.lat)) ? [[race.lon, race.lat]] : [];
    const anchorDistance = minDistanceBetween(raceCoordinate, anchorCoordinates);
    const placement = nearestGroundRoutePlacementForTrip(trip, baseCoordinates, raceCoordinate);
    const closeToDestination = anchorDistance <= 45 || (placement.distanceKm <= 24 && placement.progress > 0.06 && placement.progress < 0.94);
    return closeToDestination ? { ...placement, raceTime, anchorDistance } : null;
  };

  const raceCanPlayInsideTrip = (race, trip) => {
    const baseCoordinates = baseRouteCoordinatesForItem(trip);
    if (baseCoordinates.length < 2 || !racePlaybackSegmentsForItem(race).length) return false;
    const anchorCoordinates = nodeCoordinates(tripAnchorNodes(trip));
    return Boolean(anchorCoordinates.length && raceTripPlacement(trip, race, baseCoordinates, anchorCoordinates));
  };

  const raceCanPlayInsideAnyTrip = (race) =>
    Boolean(race?.slug) && timelineSequence.some((item) => item.type === "trip" && raceCanPlayInsideTrip(race, item));

  const associatedRacesForTrip = (trip, baseCoordinates, anchorCoordinates) =>
    allPoints
      .filter((item) => item.type === "race")
      .flatMap((race) => {
        if (timelinePlaybackActive && playbackStandaloneRaceSlugs.has(race.slug)) return [];
        const placement = raceTripPlacement(trip, race, baseCoordinates, anchorCoordinates);
        if (!placement) return [];
        const progress = placement.distanceKm <= placement.anchorDistance ? placement.progress : 0.5;
        return racePlaybackSegmentsForItem(race).map((segment, index) => ({
          ...segment,
          progress,
          startTime: placement.raceTime + index,
        }));
      })
      .filter(Boolean);

  const associatedStravaForTrip = (trip, baseCoordinates, anchorCoordinates, excludedActivityIds) =>
    includeStravaInPlayback ? stravaRouteFeatureList
      .map((feature) => {
        const id = String(feature?.properties?.id || "");
        if (!id || excludedActivityIds.has(id)) return null;
        const startTime = activityStartTime(feature);
        if (!tripDateContains(trip, startTime, 0)) return null;

        const coordinates = featureCoordinates(feature);
        if (coordinates.length < 2) return null;
        const samples = featureSampleCoordinates(feature, 10);
        const anchorDistance = minDistanceBetween(samples, anchorCoordinates);
        const placement = nearestGroundRoutePlacementForTrip(trip, baseCoordinates, samples);
        const activityGroup = String(
          `${feature.properties?.activityGroup || ""} ${feature.properties?.type || ""} ${feature.properties?.sportType || ""}`,
        ).toLowerCase();
        const isBlueActivity = /ride|bike|cycling|ski|snowboard|skate|kayak|canoe|row|paddle|surf|sail|swim|wheelchair|handcycle/.test(activityGroup);
        const anchorThreshold = isBlueActivity ? 85 : 52;
        const routeThreshold = isBlueActivity ? 38 : 22;
        const closeToTrip =
          anchorDistance <= anchorThreshold ||
          (placement.distanceKm <= routeThreshold && placement.progress > 0.06 && placement.progress < 0.94);
        if (!closeToTrip) return null;

        return {
          kind: "strava",
          properties: feature.properties || {},
          coordinates,
          progress: placement.distanceKm <= anchorDistance ? placement.progress : 0.5,
          startTime,
        };
      })
      .filter(Boolean) : [];

  const forwardRouteResumeIndex = (baseCoordinates, startIndex, targetCoordinate) => {
    if (!Array.isArray(targetCoordinate) || targetCoordinate.length < 2 || !baseCoordinates.length) {
      return Math.min(Math.max(0, startIndex), Math.max(0, baseCoordinates.length - 1));
    }
    const safeStartIndex = Math.min(Math.max(0, Number(startIndex) || 0), baseCoordinates.length - 1);
    let bestIndex = safeStartIndex;
    let bestDistance = Number.POSITIVE_INFINITY;
    for (let index = safeStartIndex; index < baseCoordinates.length; index += 1) {
      const distance = haversineDistance(baseCoordinates[index], targetCoordinate);
      if (distance < bestDistance) {
        bestDistance = distance;
        bestIndex = index;
      }
    }
    return bestIndex;
  };

  const sliceCoordinatesByProgressRange = (coordinates, startProgress, endProgress) => {
    const sanitized = sanitizedCoordinates(coordinates);
    if (sanitized.length < 2) return sanitized;
    const start = Math.min(1, Math.max(0, Number(startProgress) || 0));
    const end = Math.min(1, Math.max(start, Number(endProgress) || 0));
    if (end - start <= 0.000001) return [];

    const totalDistance = cachedPathDistance(sanitized);
    if (!Number.isFinite(totalDistance) || totalDistance <= 0) return sanitized;

    const startDistance = totalDistance * start;
    const endDistance = totalDistance * end;
    const sliced = [coordinateAtProgress(sanitized, start)];
    let traversedDistance = 0;

    for (let index = 1; index < sanitized.length - 1; index += 1) {
      traversedDistance += haversineDistance(sanitized[index - 1], sanitized[index]);
      if (traversedDistance > startDistance && traversedDistance < endDistance) {
        sliced.push(sanitized[index]);
      }
    }

    sliced.push(coordinateAtProgress(sanitized, end));
    return sliced.filter((coordinate, index) => coordinate && (index === 0 || !sameLngLat(coordinate, sliced[index - 1])));
  };

  const baseTripSegmentsBetweenProgress = (trip, startProgress, endProgress) => {
    const baseSegments = playbackBaseSegmentsForTrip(trip);
    if (!baseSegments.length) return [];
    const distances = baseSegments.map((segment) => cachedPathDistance(segment.coordinates));
    const totalDistance = distances.reduce((sum, distance) => sum + Math.max(0, distance), 0);
    if (!Number.isFinite(totalDistance) || totalDistance <= 0) return [];

    const startDistance = totalDistance * Math.min(1, Math.max(0, Number(startProgress) || 0));
    const endDistance = totalDistance * Math.min(1, Math.max(startProgress, Number(endProgress) || 0));
    let cursorDistance = 0;
    const slices = [];

    baseSegments.forEach((segment, index) => {
      const segmentDistance = Math.max(0, distances[index] || 0);
      const segmentStartDistance = cursorDistance;
      const segmentEndDistance = cursorDistance + segmentDistance;
      cursorDistance = segmentEndDistance;
      if (segmentDistance <= 0 || segmentEndDistance <= startDistance || segmentStartDistance >= endDistance) return;

      const localStart = Math.max(0, (startDistance - segmentStartDistance) / segmentDistance);
      const localEnd = Math.min(1, (endDistance - segmentStartDistance) / segmentDistance);
      const coordinates = sliceCoordinatesByProgressRange(segment.coordinates, localStart, localEnd);
      if (coordinates.length >= 2) slices.push({ ...segment, coordinates });
    });

    return slices;
  };

  const forwardRouteResumeProgress = (baseCoordinates, startProgress, targetCoordinate) => {
    if (!Array.isArray(targetCoordinate) || targetCoordinate.length < 2 || !baseCoordinates.length) {
      return Math.min(1, Math.max(0, Number(startProgress) || 0));
    }
    const safeStart = Math.min(1, Math.max(0, Number(startProgress) || 0));
    const startIndex = coordinateIndexAtProgress(baseCoordinates, safeStart);
    const resumeIndex = forwardRouteResumeIndex(baseCoordinates, startIndex, targetCoordinate);
    const resumeCoordinate = baseCoordinates[resumeIndex];
    const resume = progressForCoordinateInSegments([{ coordinates: baseCoordinates }], resumeCoordinate).progress;
    return Math.max(safeStart, Math.min(1, Math.max(0, resume)));
  };

  const composeTripPlaybackSegments = (trip, baseCoordinates, associatedSegments) => {
    if (!baseCoordinates.length) return [];
    if (!associatedSegments.length) {
      const baseSegments = playbackBaseSegmentsForTrip(trip);
      return baseSegments.length ? baseSegments : [{ kind: "trip", item: trip, mode: trip.travelMode || "drive", coordinates: baseCoordinates }];
    }

    const sortedSegments = [...associatedSegments].sort(
      (first, second) => first.progress - second.progress || first.startTime - second.startTime,
    );
    const segments = [];
    let cursorProgress = 0;
    let offRouteCoordinate = null;

    const pushSegment = (segment) => {
      if (!segment) return;
      const coordinates = sanitizedCoordinates(segment.coordinates);
      if (coordinates.length >= 2 || (coordinates.length === 1 && !segments.length)) {
        segments.push({ ...segment, coordinates });
      }
    };

    sortedSegments.forEach((associatedSegment) => {
      const insertProgress = Math.max(cursorProgress, Math.min(1, Math.max(0, Number(associatedSegment.progress) || 0)));
      if (!offRouteCoordinate) {
        baseTripSegmentsBetweenProgress(trip, cursorProgress, insertProgress).forEach(pushSegment);
      } else if (insertProgress > cursorProgress) {
        const resumeProgress = forwardRouteResumeProgress(baseCoordinates, cursorProgress, offRouteCoordinate);
        const routeReturnCoordinate = coordinateAtProgress(baseCoordinates, resumeProgress);
        if (routeReturnCoordinate && !sameLngLat(offRouteCoordinate, routeReturnCoordinate)) {
          pushSegment(routedConnectorSegment(trip, offRouteCoordinate, routeReturnCoordinate));
        }
        cursorProgress = Math.max(cursorProgress, resumeProgress);
        baseTripSegmentsBetweenProgress(trip, cursorProgress, insertProgress).forEach(pushSegment);
        offRouteCoordinate = null;
      }

      const routeCoordinate = coordinateAtProgress(baseCoordinates, insertProgress);
      const activityCoordinates = sanitizedCoordinates(associatedSegment.coordinates);
      if (routeCoordinate && activityCoordinates.length) {
        const connectorStart = offRouteCoordinate || routeCoordinate;
        if (connectorStart && !sameLngLat(connectorStart, activityCoordinates[0])) {
          pushSegment(routedConnectorSegment(trip, connectorStart, activityCoordinates[0]));
        }
        pushSegment({ ...associatedSegment, coordinates: activityCoordinates });
        offRouteCoordinate = activityCoordinates[activityCoordinates.length - 1];
      }
      cursorProgress = insertProgress;
    });

    if (offRouteCoordinate) {
      const resumeProgress = forwardRouteResumeProgress(baseCoordinates, cursorProgress, offRouteCoordinate);
      const routeReturnCoordinate = coordinateAtProgress(baseCoordinates, resumeProgress);
      if (routeReturnCoordinate && !sameLngLat(offRouteCoordinate, routeReturnCoordinate)) {
        pushSegment(routedConnectorSegment(trip, offRouteCoordinate, routeReturnCoordinate));
      }
      cursorProgress = Math.max(cursorProgress, resumeProgress);
    }
    baseTripSegmentsBetweenProgress(trip, cursorProgress, 1).forEach(pushSegment);
    return segments.length ? segments : [{ kind: "trip", item: trip, mode: trip.travelMode || "drive", coordinates: baseCoordinates }];
  };

  const playbackSegmentsForItem = (item) => {
    if (!item) return [];
    if (item.type !== "trip") {
      if (item.type === "race") {
        const raceSegments = racePlaybackSegmentsForItem(item);
        if (raceSegments.length) return raceSegments;
      }
      const coordinates = baseRouteCoordinatesForItem(item);
      if (item.type === "strava") {
        return coordinates.length
          ? [{
              kind: "strava",
              item,
              properties: {
                id: item.stravaActivityId,
                name: item.title,
                activityGroup: item.activityGroup,
                sportType: item.sportType,
                type: item.activityType || item.activityGroup,
                startDate: item.startDate || item.date,
                distanceMeters: item.distanceMeters,
                movingTimeSeconds: item.movingTimeSeconds,
                elapsedTimeSeconds: item.elapsedTimeSeconds,
              },
              coordinates,
            }]
          : [];
      }
      return coordinates.length ? [{ kind: item.type || "item", item, coordinates }] : [];
    }

    const playedStandaloneRaceKey =
      timelinePlaybackActive && playbackStandaloneRaceSlugs.size
        ? [...playbackStandaloneRaceSlugs].sort().join("|")
        : "";
    const cacheKey = `${item.slug}:${includeStravaInPlayback ? 1 : 0}:${playedStandaloneRaceKey}:${stravaRouteFeatureList.length}:${raceRouteFeaturesBySlug.size}:${tripRouteCollections.routes.features.length}`;
    const cached = tripPlaybackSegmentsCache.get(cacheKey);
    if (cached) return cached;

    const baseCoordinates = baseRouteCoordinatesForItem(item);
    if (baseCoordinates.length < 2) {
      const fallback = baseCoordinates.length ? [{ kind: "trip", item, coordinates: baseCoordinates }] : [];
      tripPlaybackSegmentsCache.set(cacheKey, fallback);
      return fallback;
    }

    const anchors = tripAnchorNodes(item);
    const anchorCoordinates = nodeCoordinates(anchors);
    if (!anchorCoordinates.length) {
      const fallback = [{ kind: "trip", item, coordinates: baseCoordinates }];
      tripPlaybackSegmentsCache.set(cacheKey, fallback);
      return fallback;
    }

    const raceSegments = associatedRacesForTrip(item, baseCoordinates, anchorCoordinates);
    const excludedRaceActivityIds = new Set(
      raceSegments.flatMap((segment) => (segment.item?.stravaActivityIds || []).map((id) => String(id))),
    );
    const stravaSegments = associatedStravaForTrip(item, baseCoordinates, anchorCoordinates, excludedRaceActivityIds);
    const segments = composeTripPlaybackSegments(item, baseCoordinates, [...raceSegments, ...stravaSegments]);
    tripPlaybackSegmentsCache.set(cacheKey, segments);
    return segments;
  };

  const scrubberStateFromValue = (value) => {
    if (!timelineSequence.length) return null;
    const clampedValue = Math.min(Math.max(Number(value) || 0, 0), timelineSequence.length * scrubberUnitsPerItem);
    const rawIndex = clampedValue / scrubberUnitsPerItem;
    const itemIndex = Math.min(Math.floor(rawIndex), timelineSequence.length - 1);
    const item = timelineSequence[itemIndex];
    const phase = itemIndex === timelineSequence.length - 1 ? Math.min(1, rawIndex - itemIndex) : rawIndex - itemIndex;
    const segments = playbackSegmentsForItem(item);
    const coordinates = flattenPlaybackSegments(segments);
    const nextItem = timelineSequence[itemIndex + 1];
    const routeProgress =
      itemIndex === timelineSequence.length - 1
        ? phase
        : Math.min(1, phase / scrubberRoutePortion);
    const routeSample = coordinateAtProgressInSegments(segments, routeProgress);
    const routeCoordinate = routeSample.coordinate || coordinateAtProgress(coordinates, routeProgress);

    if (nextItem && phase > scrubberRoutePortion) {
      const transitionProgress = (phase - scrubberRoutePortion) / (1 - scrubberRoutePortion);
      const transitionSegment = timelineTransitionSegment(item, nextItem);
      const transitionSegments = transitionSegment ? [transitionSegment] : [];
      const transitionCoordinates = flattenPlaybackSegments(transitionSegments);
      const transitionSample = coordinateAtProgressInSegments(transitionSegments, transitionProgress);
      return {
        itemIndex,
        phase,
        item,
        nextItem,
        coordinate: transitionSample.coordinate || transitionCoordinates[0] || routeCoordinate,
        routeProgress: transitionProgress,
        inGap: true,
        pathDistance: cachedPathDistance(transitionCoordinates),
        segment: transitionSample.segment || transitionSegment || null,
        segmentIndex: Number.isFinite(transitionSample.segmentIndex) ? transitionSample.segmentIndex : 0,
        segmentProgress: transitionSample.segmentProgress || transitionProgress,
        playbackSegments: transitionSegments,
        coordinates: transitionCoordinates,
      };
    }

    return {
      itemIndex,
      phase,
      item,
      nextItem,
      coordinate: routeCoordinate,
      routeProgress,
      inGap: false,
      pathDistance: cachedPathDistance(coordinates),
      segment: routeSample.segment || null,
      segmentIndex: routeSample.segmentIndex,
      segmentProgress: routeSample.segmentProgress || routeProgress,
      playbackSegments: segments,
      coordinates,
    };
  };

  const progressMarkerData = (state) => {
    if (!state?.coordinate) return emptyProgressMarkerData;
    return {
      type: "FeatureCollection",
      features: [
        {
          type: "Feature",
          geometry: { type: "Point", coordinates: state.coordinate },
          properties: {
            slug: state.item.slug,
            type: state.segment?.kind === "race" ? "race" : state.segment?.kind === "strava" ? "strava" : state.item.type,
            progress: state.routeProgress,
          },
        },
      ],
    };
  };

  const progressTransitionRouteData = (state) => {
    const coordinates = sanitizedCoordinates(state?.segment?.coordinates);
    if (!state?.inGap || state.segment?.loading || coordinates.length < 2) return emptyTransitionRouteData;
    return {
      type: "FeatureCollection",
      features: [
        {
          type: "Feature",
          geometry: { type: "LineString", coordinates },
          properties: {
            mode: normalizePlaybackMode(state.segment?.mode) || "car",
          },
        },
      ],
    };
  };

  const photoForPlaybackState = (state) => {
    if (!state?.item || state.inGap || !state.coordinate) return null;
    const stravaId =
      state.segment?.kind === "strava"
        ? String(state.segment.properties?.id || "")
        : state.item.type === "strava"
          ? String(state.item.stravaActivityId || "")
          : "";
    const photos = stravaId
      ? stravaPhotosById.get(stravaId) || []
      : state.item.type === "trip" && (!state.segment?.kind || state.segment.kind === "trip")
        ? tripPhotosBySlug.get(state.item.slug) || []
        : [];
    if (!photos.length) return null;
    const routeProgress = Math.min(
      1,
      Math.max(0, Number(stravaId ? state.segmentProgress : state.routeProgress) || 0),
    );
    const windowSize = Math.max(0.014, Math.min(0.05, 0.32 / (photos.length + 1)));
    let best = null;
    let bestDelta = Number.POSITIVE_INFINITY;

    photos.forEach((photo, index) => {
      const progress = Math.min(1, Math.max(0, Number(photo.progress) || 0));
      const delta = Math.abs(progress - routeProgress);
      if (delta < bestDelta) {
        best = { ...photo, index, progress, delta };
        bestDelta = delta;
      }
    });

    if (!best || bestDelta > windowSize) return null;
    const coordinate =
      Number.isFinite(Number(best.lon)) && Number.isFinite(Number(best.lat))
        ? [Number(best.lon), Number(best.lat)]
        : state.coordinate;
    return {
      ...best,
      key: `${state.item.slug}:${best.index}:${best.src}`,
      coordinate,
    };
  };

  const updatePlaybackPhotoCallout = (state) => {
    const photo = photoForPlaybackState(state);
    if (!photo) {
      activePlaybackPhotoKey = "";
      playbackPhotoMarker.remove();
      playbackPhotoPinMarker.remove();
      return;
    }

    if (activePlaybackPhotoKey !== photo.key) {
      const date = String(photo.capturedAt || "").slice(0, 10);
      playbackPhotoElement.innerHTML = `
        <img src="${escapeHtml(photo.src)}" alt="" loading="eager" />
        ${date ? `<figcaption>${escapeHtml(date)}</figcaption>` : ""}
      `;
      activePlaybackPhotoKey = photo.key;
    }

    const projected = map.project(photo.coordinate);
    const compact = mapElement.clientWidth < 680;
    const cardWidth = playbackPhotoElement.offsetWidth || (compact ? 136 : 178);
    const cardHeight = playbackPhotoElement.offsetHeight || (compact ? 112 : 148);
    const margin = compact ? 10 : 14;
    const logoSafeRight = compact ? 238 : 312;
    const logoSafeBottom = compact ? 76 : 82;
    const topSafe = projected.x < logoSafeRight ? logoSafeBottom : margin;
    const preferredVerticalOffset = -24;
    let horizontalOffset = 0;
    let verticalOffset = preferredVerticalOffset;
    let left = projected.x - cardWidth / 2;
    let right = projected.x + cardWidth / 2;
    let top = projected.y - cardHeight + verticalOffset;
    let bottom = projected.y + verticalOffset;

    if (left < margin) horizontalOffset += margin - left;
    if (right + horizontalOffset > mapElement.clientWidth - margin) {
      horizontalOffset -= right + horizontalOffset - (mapElement.clientWidth - margin);
    }

    left = projected.x + horizontalOffset - cardWidth / 2;
    right = projected.x + horizontalOffset + cardWidth / 2;
    top = projected.y - cardHeight + verticalOffset;
    bottom = projected.y + verticalOffset;

    if (top < topSafe) verticalOffset += topSafe - top;
    if (bottom + verticalOffset - preferredVerticalOffset > mapElement.clientHeight - margin) {
      verticalOffset -= bottom + verticalOffset - preferredVerticalOffset - (mapElement.clientHeight - margin);
    }

    playbackPhotoElement.classList.toggle("is-shifted", Math.abs(horizontalOffset) > 4 || Math.abs(verticalOffset - preferredVerticalOffset) > 4);
    if (typeof playbackPhotoMarker.setOffset === "function") playbackPhotoMarker.setOffset([horizontalOffset, verticalOffset]);
    playbackPhotoPinMarker.setLngLat(photo.coordinate).addTo(map);
    playbackPhotoMarker.setLngLat(photo.coordinate).addTo(map);
  };

  const playbackNodeForState = (state) => {
    if (!state?.item || state.item.type !== "trip" || state.inGap || !state.coordinate) return null;
    if (state.segment?.kind === "strava" || state.segment?.kind === "race") return null;
    const nodes = tripNodesBySlug.get(state.item.slug) || [];
    if (!nodes.length) return null;

    const mode = normalizePlaybackMode(state.segment?.mode || state.item.travelMode) || "car";
      const thresholdKm = mode === "plane" ? 70 : mode === "boat" ? 24 : 13;
    let best = null;
    let bestDistance = Number.POSITIVE_INFINITY;

    nodes.forEach((node, index) => {
      if (!showNodeOnMap(node, true) || !isFiniteCoordinate(node)) return;
      const title = String(node.title || "").trim();
      if (!title || title.toLowerCase().startsWith("return to ")) return;
      const distance = haversineDistance(state.coordinate, [Number(node.lon), Number(node.lat)]);
      if (distance < bestDistance) {
        bestDistance = distance;
        best = { node, index, distance };
      }
    });

    if (!best || bestDistance > thresholdKm) return null;
    return {
      key: `${state.item.slug}:${best.index}`,
      title: best.node.title,
      coordinate: [Number(best.node.lon), Number(best.node.lat)],
    };
  };

  const updatePlaybackNodeTag = (state) => {
    const node = playbackNodeForState(state);
    if (!node) {
      activePlaybackNodeKey = "";
      playbackNodeMarker.remove();
      return;
    }

    if (activePlaybackNodeKey !== node.key) {
      playbackNodeTagElement.textContent = node.title;
      activePlaybackNodeKey = node.key;
    }
    const projected = map.project(node.coordinate);
    const compact = mapElement.clientWidth < 680;
    const horizontalOffset = projected.x < 112 ? 76 : projected.x > mapElement.clientWidth - 112 ? -76 : 0;
    const verticalOffset = compact && projected.y < 64 ? 34 : -18;
    if (typeof playbackNodeMarker.setOffset === "function") playbackNodeMarker.setOffset([horizontalOffset, verticalOffset]);
    playbackNodeMarker.setLngLat(node.coordinate).addTo(map);
  };

  const updateRouteProgressMarker = (state) => {
    currentScrubState = state;
    const source = map.getSource("route-progress-marker");
    if (source && "setData" in source) source.setData(progressMarkerData(state));
    const transitionSource = map.getSource("route-progress-transition");
    if (transitionSource && "setData" in transitionSource) transitionSource.setData(progressTransitionRouteData(state));
    updatePlaybackNodeTag(state);
  };

  const scrubberValueForSlug = (slug) => {
    const index = timelineSequence.findIndex((item) => item.slug === slug);
    return index >= 0 ? index * scrubberUnitsPerItem : 0;
  };

  const scrubberValueForItemProgress = (item, routeProgress = 0) => {
    const index = timelineSequence.findIndex((timelineItem) => timelineItem.slug === item?.slug);
    if (index < 0) return 0;
    const routeUnits = index === timelineSequence.length - 1 ? scrubberUnitsPerItem : scrubberUnitsPerItem * scrubberRoutePortion;
    return index * scrubberUnitsPerItem + Math.min(1, Math.max(0, Number(routeProgress) || 0)) * routeUnits;
  };

  const clampScrubberValue = (value) => Math.min(Math.max(Number(value) || 0, 0), scrubberMaxValue);

  const maxTimelineScroll = () => (timelineRail ? Math.max(1, timelineRail.scrollWidth - timelineRail.clientWidth) : 1);

  const timelineAxisWidth = () =>
    timelineRail?.querySelector(".travel-timeline-rail__axis")?.scrollWidth || timelineRail?.scrollWidth || 1;

  const scrubberValueFromTimelineTime = (time) => {
    if (!timelineSequence.length) return 0;
    const targetTime = Number(time) || timelineStartTime;
    const firstTime = timelineSequence[0].timelineTime || timelineStartTime;
    const lastIndex = timelineSequence.length - 1;
    const lastTime = timelineSequence[lastIndex].timelineTime || timelineEndTime;

    if (targetTime <= firstTime) return 0;
    if (targetTime >= lastTime) return lastIndex * scrubberUnitsPerItem + scrubberUnitsPerItem;

    for (let index = 0; index < lastIndex; index += 1) {
      const itemTime = timelineSequence[index].timelineTime || firstTime;
      const nextTime = timelineSequence[index + 1].timelineTime || itemTime + 1;
      if (targetTime <= nextTime) {
        const dateProgress = (targetTime - itemTime) / Math.max(1, nextTime - itemTime);
        return (index + Math.min(Math.max(dateProgress, 0), 1)) * scrubberUnitsPerItem;
      }
    }

    return scrubberMaxValue;
  };

  const timelineTimeFromScroll = () => {
    if (!timelineRail) return timelineFocusStartTime;
    const viewportCenter = timelineRail.scrollLeft + timelineRail.clientWidth / 2;
    const ratio = Math.min(1, Math.max(0, viewportCenter / Math.max(1, timelineAxisWidth())));
    return timelineStartTime + ratio * timelineTimeSpan;
  };

  const timelineValueFromScroll = () => {
    if (!timelineRail) return scrubberValue;
    return scrubberValueFromTimelineTime(timelineTimeFromScroll());
  };

  const scrollTimelineToTime = (time, behavior = "auto") => {
    if (!timelineRail) return;
    const ratio = Math.min(1, Math.max(0, ((Number(time) || timelineStartTime) - timelineStartTime) / timelineTimeSpan));
    const targetLeft = ratio * timelineAxisWidth() - timelineRail.clientWidth / 2;
    syncingTimelineScroll = true;
    timelineRail.scrollTo({
      left: Math.min(Math.max(0, targetLeft), maxTimelineScroll()),
      behavior,
    });
    window.setTimeout(() => {
      syncingTimelineScroll = false;
    }, behavior === "smooth" ? 1100 : 260);
  };

  const centerTimelineDot = (slug, behavior = "smooth") => {
    if (!timelineRail || !slug) return;
    const dot = timelineDots.find((item) => item.getAttribute("data-map-timeline-item") === slug);
    if (!dot) return;
    const railStyle = window.getComputedStyle(timelineRail);
    const railPaddingLeft = parseFloat(railStyle.paddingLeft) || 0;
    const dotCenter = railPaddingLeft + dot.offsetLeft;
    const targetLeft = dotCenter - timelineRail.clientWidth / 2;
    syncingTimelineScroll = true;
    timelineRail.scrollTo({
      left: Math.min(Math.max(0, targetLeft), maxTimelineScroll()),
      behavior,
    });
    window.setTimeout(() => {
      syncingTimelineScroll = false;
    }, behavior === "smooth" ? 1100 : 260);
  };

  const scrollTimelineToValue = (value, behavior = "auto") => {
    const state = scrubberStateFromValue(value);
    scrollTimelineToTime(state?.item?.timelineTime || timelineFocusStartTime, behavior);
  };

  const syncScrubberToItem = (item, coordinate = null, { centerTimeline = true, behavior = "auto", progressOverride = null } = {}) => {
    if (!item) return;
    const segments = playbackSegmentsForItem(item);
    const clickedProgress = coordinate ? progressForCoordinateInSegments(segments, coordinate) : null;
    const routeProgress = Number(progressOverride);
    const nextValue = clampScrubberValue(
      Number.isFinite(routeProgress)
        ? scrubberValueForItemProgress(item, routeProgress)
        : clickedProgress?.coordinate
        ? scrubberValueForItemProgress(item, clickedProgress.progress)
        : scrubberValueForSlug(item.slug),
    );
    scrubberValue = nextValue;
    updateRouteProgressMarker(scrubberStateFromValue(nextValue));
    if (centerTimeline) centerTimelineDot(item.slug, behavior);
  };

  const syncScrubberToStravaActivity = (activityId, coordinate = null, options = {}) => {
    const item = stravaTimelineItemByActivityId.get(String(activityId || ""));
    if (!item) return null;
    syncScrubberToItem(item, coordinate, options);
    return item;
  };

  const keepTimelineDotVisible = (slug, behavior = "smooth") => {
    centerTimelineDot(slug, behavior);
  };

  const applyScrubFocus = (item, { centerDot = true } = {}) => {
    if (!item) return false;
    const itemChanged = activeTimelineSlug !== item.slug;
    if (!itemChanged) return false;
    activeTimelineSlug = item.slug;
    activeStravaActivityId = item.type === "strava" ? String(item.stravaActivityId || "") : "";
    activeTripRouteSegment = null;
    updateActiveSummary(item);
    setActiveTimelineDot(item.slug);
    if (map.getLayer("map-point-highlight")) {
      map.setFilter("map-point-highlight", ["==", ["get", "slug"], item.slug]);
    }
    clearScheduledPopup();
    popup.remove();
    updateLayerVisibility();
    if (centerDot) keepTimelineDotVisible(item.slug);
    return itemChanged;
  };

  const zoomDistanceForState = (state) => {
    const segmentCoordinates = sanitizedCoordinates(state?.segment?.coordinates);
    if (segmentCoordinates.length >= 2) {
      return Math.max(0, Number(state?.segment?.distanceKm) || 0, cachedPathDistance(segmentCoordinates));
    }
    const stateCoordinates = sanitizedCoordinates(state?.coordinates);
    return Math.max(0, Number(state?.pathDistance) || 0, cachedPathDistance(stateCoordinates));
  };

  const rawScrubZoomForState = (state) => {
    if (!state?.item) return map.getZoom();
    const compact = mapElement.clientWidth < 680;
    const mode = playbackModeForState(state);
    const distance = zoomDistanceForState(state);

    if (mode === "plane") {
      if (distance > 7000) return compact ? 0.95 : 1.45;
      if (distance > 2400) return compact ? 1.75 : 2.35;
      return compact ? 2.55 : 3.2;
    }

    if (mode === "helicopter") {
      if (distance < 90) return compact ? 7.8 : 8.65;
      if (distance < 180) return compact ? 7.1 : 7.95;
      return compact ? 6.2 : 7.0;
    }

    if (state.inGap) {
      if (distance < 25) return compact ? 9.8 : 10.8;
      if (distance < 120) return compact ? 8.3 : 9.2;
      if (distance < 500) return compact ? 6.9 : 7.8;
      if (distance < 1500) return compact ? 5.5 : 6.3;
      return compact ? 4.7 : 5.4;
    }

    if (state.segment?.kind === "strava" || state.item.type === "strava") return routeMaxZoomForDistance(distance, "strava") - 0.1;
    if (state.segment?.kind === "race" || state.item.type === "race") {
      const sportType = String(state.segment?.properties?.activityGroup || state.segment?.properties?.sportType || "").toLowerCase();
      const raceBoost = /ride|bike|cycling/.test(sportType) ? 0.9 : /swim/.test(sportType) ? 0.45 : 0.15;
      return routeMaxZoomForDistance(distance, "race") + raceBoost;
    }

    if (mode === "boat") {
      if (distance < 25) return compact ? 9.3 : 10.1;
      if (distance < 120) return compact ? 8.0 : 8.9;
      if (distance < 450) return compact ? 6.5 : 7.3;
      return compact ? 5.1 : 5.9;
    }

    if (distance > 1200) return compact ? 4.7 : 5.45;
    if (distance < 12) return compact ? 10.9 : 11.8;
    if (distance < 40) return compact ? 9.8 : 10.7;
    if (distance < 120) return compact ? 8.45 : 9.35;
    if (distance < 350) return compact ? 7.15 : 8.0;
    return compact ? 6.35 : 7.2;
  };

  const transitionEase = (value) => {
    const time = Math.min(1, Math.max(0, Number(value) || 0));
    return time * time * (3 - 2 * time);
  };

  const lerp = (start, end, progress) => start + (end - start) * progress;

  const planeGroundBoundaryZoom = (planeZoom, groundZoom) => {
    if (!Number.isFinite(planeZoom) || !Number.isFinite(groundZoom)) return planeZoom;
    const approachDelta = mapElement.clientWidth < 680 ? 1.55 : 1.9;
    return Math.min(groundZoom, planeZoom + approachDelta);
  };

  const stateForNeighborSegment = (state, segmentIndex, segmentProgress) => {
    const segments = state?.playbackSegments || [];
    const segment = segments[segmentIndex];
    if (!segment) return null;
    const coordinates = sanitizedCoordinates(segment.coordinates);
    return {
      ...state,
      inGap: segment.kind === "transition",
      segment,
      segmentIndex,
      segmentProgress,
      coordinates,
      pathDistance: cachedPathDistance(coordinates),
    };
  };

  const smoothedZoomForSegmentBoundary = (state, targetZoom, rawZoomForState) => {
    if (!state?.segment || !Array.isArray(state.playbackSegments) || state.playbackSegments.length < 2) return targetZoom;
    const segmentIndex = Number(state.segmentIndex);
    if (!Number.isFinite(segmentIndex)) return targetZoom;

    const segmentProgress = Math.min(1, Math.max(0, Number(state.segmentProgress ?? state.routeProgress) || 0));
    const currentMode = playbackModeForState(state);
    const previousState = stateForNeighborSegment(state, segmentIndex - 1, 1);
    const nextState = stateForNeighborSegment(state, segmentIndex + 1, 0);
    const previousMode = previousState ? playbackModeForState(previousState) : "";
    const nextMode = nextState ? playbackModeForState(nextState) : "";
    const previousZoom = previousState ? rawZoomForState(previousState) : null;
    const nextZoom = nextState ? rawZoomForState(nextState) : null;

    const longPlaneStartWindow = 0.36;
    const longPlaneEndWindow = 0.42;
    const groundAfterPlaneWindow = 0.62;
    const groundBeforePlaneWindow = 0.36;

    if (currentMode === "plane") {
      if (previousState && previousMode !== "plane" && segmentProgress < longPlaneStartWindow) {
        return lerp(previousZoom, targetZoom, transitionEase(segmentProgress / longPlaneStartWindow));
      }
      if (nextState && nextMode !== "plane" && segmentProgress > 1 - longPlaneEndWindow) {
        const approachZoom = planeGroundBoundaryZoom(targetZoom, nextZoom);
        return lerp(targetZoom, approachZoom, transitionEase((segmentProgress - (1 - longPlaneEndWindow)) / longPlaneEndWindow));
      }
      return targetZoom;
    }

    if (previousState && previousMode === "plane" && segmentProgress < groundAfterPlaneWindow) {
      const approachZoom = planeGroundBoundaryZoom(previousZoom, targetZoom);
      return lerp(approachZoom, targetZoom, transitionEase(segmentProgress / groundAfterPlaneWindow));
    }
    if (nextState && nextMode === "plane" && segmentProgress > 1 - groundBeforePlaneWindow) {
      return lerp(targetZoom, nextZoom, transitionEase((segmentProgress - (1 - groundBeforePlaneWindow)) / groundBeforePlaneWindow));
    }

    if (previousState && Math.abs(previousZoom - targetZoom) > 1.8 && segmentProgress < 0.16) {
      return lerp(previousZoom, targetZoom, transitionEase(segmentProgress / 0.16));
    }
    if (nextState && Math.abs(nextZoom - targetZoom) > 1.8 && segmentProgress > 0.84) {
      return lerp(targetZoom, nextZoom, transitionEase((segmentProgress - 0.84) / 0.16));
    }

    return targetZoom;
  };

  const scrubZoomForState = (state) => smoothedZoomForSegmentBoundary(state, rawScrubZoomForState(state), rawScrubZoomForState);

  const rawCinematicZoomForState = (state) => {
    const baseZoom = rawScrubZoomForState(state);
    const mode = state?.item ? playbackModeForState(state) : "";
    if (!state?.item || state.inGap || mode === "plane") return baseZoom;
    const cinematicCoordinates =
      sanitizedCoordinates(state.segment?.coordinates).length >= 2
        ? sanitizedCoordinates(state.segment.coordinates)
        : state.coordinates?.length
          ? state.coordinates
          : routeCoordinatesForItem(state.item);
    const routeProfile = cinematicRouteProfileForState(state, cinematicCoordinates);
    const compactZoom = compactRouteCinematicZoom(routeProfile);
    if (compactZoom !== null) return compactZoom;
    const terrainProfile = cinematicTerrainProfileForState(state);
    if (terrainProfile === "canyon-race") return mapElement.clientWidth < 680 ? 14.0 : 14.55;
    if (terrainProfile === "trail-race") return mapElement.clientWidth < 680 ? 13.55 : 14.1;
    const isStravaState = state.segment?.kind === "strava" || state.item.type === "strava";
    const activityMode = cinematicActivityModeForState(state);
    const distance = zoomDistanceForState(state);
    if (activityMode === "run" || activityMode === "race") {
      if (distance < 3) return mapElement.clientWidth < 680 ? 15.1 : 15.8;
      if (distance < 10) return mapElement.clientWidth < 680 ? 14.6 : 15.2;
      if (distance < 25) return mapElement.clientWidth < 680 ? 14.0 : 14.65;
      if (distance < 55) return mapElement.clientWidth < 680 ? 13.45 : 14.0;
      return mapElement.clientWidth < 680 ? 12.95 : 13.55;
    }
    if (activityMode === "bike") {
      const raceBoost = state.segment?.kind === "race" ? 0.75 : 0.35;
      if (distance < 15) return (mapElement.clientWidth < 680 ? 14.35 : 14.9) + raceBoost;
      if (distance < 50) return (mapElement.clientWidth < 680 ? 13.55 : 14.15) + raceBoost;
      if (distance < 120) return (mapElement.clientWidth < 680 ? 12.75 : 13.35) + raceBoost;
      return (mapElement.clientWidth < 680 ? 11.95 : 12.6) + raceBoost;
    }
    if (activityMode === "swim") {
      const raceBoost = state.segment?.kind === "race" ? 0.55 : 0.25;
      if (distance < 2.5) return (mapElement.clientWidth < 680 ? 14.65 : 15.25) + raceBoost;
      if (distance < 6) return (mapElement.clientWidth < 680 ? 14.15 : 14.75) + raceBoost;
      if (distance < 15) return (mapElement.clientWidth < 680 ? 13.55 : 14.15) + raceBoost;
      return (mapElement.clientWidth < 680 ? 12.75 : 13.35) + raceBoost;
    }
    if (activityMode === "paddle") {
      if (distance < 6) return mapElement.clientWidth < 680 ? 14.55 : 15.1;
      if (distance < 18) return mapElement.clientWidth < 680 ? 13.9 : 14.45;
      if (distance < 45) return mapElement.clientWidth < 680 ? 12.95 : 13.55;
      return mapElement.clientWidth < 680 ? 12.0 : 12.65;
    }
    const routeBoost =
      distance < 12
        ? 0.8
        : distance < 40
          ? 0.55
          : distance < 120
            ? 0.35
            : 0.18;
    if (isStravaState) {
      const longActivityBoost =
        activityMode === "bike"
          ? distance >= 180
            ? 1.25
            : distance >= 96
              ? 1.08
              : distance >= 56
                ? 0.82
                : 0.48
          : distance >= 85
            ? 1.18
            : distance >= 35
              ? 0.98
              : distance >= 25.5
                ? 0.78
                : 0.48;
      return Math.min(baseZoom + routeBoost + longActivityBoost, mapElement.clientWidth < 680 ? 13.45 : 14.05);
    }
    const activityBoost = state.segment?.kind === "strava" || state.segment?.kind === "race" ? 0.4 : 0;
    return Math.min(baseZoom + routeBoost + activityBoost, mapElement.clientWidth < 680 ? 13.1 : 13.7);
  };

  const cinematicZoomForState = (state) =>
    smoothedZoomForSegmentBoundary(state, rawCinematicZoomForState(state), rawCinematicZoomForState);

  const cinematicActivityModeForState = (state) => {
    if (!state?.item) return "";
    const segment = state.segment || {};
    if (segment.kind === "strava") {
      return normalizePlaybackMode(`${segment.properties?.type || ""} ${segment.properties?.sportType || ""} ${segment.properties?.activityGroup || ""}`) || "run";
    }
    if (state.item.type === "strava") return normalizePlaybackMode(`${state.item.activityType || ""} ${state.item.sportType || ""} ${state.item.activityGroup || ""}`) || "run";
    if (segment.kind === "race") return raceSegmentPlaybackMode(segment);
    if (state.item.type === "race") return "race";
    return playbackModeForState(state);
  };

  const raceTitleForState = (state) =>
    String(
      state?.segment?.item?.title ||
        state?.item?.title ||
        state?.segment?.properties?.name ||
        "",
    ).toLowerCase();

  const raceSlugForState = (state) =>
    String(state?.segment?.item?.slug || state?.item?.slug || state?.segment?.properties?.raceSlug || "").toLowerCase();

  const cinematicTerrainProfileForState = (state) => {
    if (!state || state.inGap) return "";
    const isRaceState = state.segment?.kind === "race" || state.item?.type === "race";
    if (!isRaceState) return "";
    const label = `${raceSlugForState(state)} ${raceTitleForState(state)}`;
    if (/canyons|auburn|deadwood|foresthill|michigan-bluff|american-river/.test(label)) return "canyon-race";
    if (/skyrace|trail|headlands|golden-gate|broken-arrow|50k|100k/.test(label)) return "trail-race";
    return "";
  };

  let activeTerrainExaggeration = 1.35;
  const setTerrainExaggeration = (exaggeration) => {
    const next = Number(exaggeration) || 1.35;
    if (Math.abs(next - activeTerrainExaggeration) < 0.05) return;
    activeTerrainExaggeration = next;
    map.setTerrain({ source: "mapbox-terrain-dem", exaggeration: next });
  };

  const bearingBetweenCoordinates = (start, end) => {
    if (!Array.isArray(start) || !Array.isArray(end)) return map.getBearing();
    const startLat = toRadians(Number(start[1]));
    const endLat = toRadians(Number(end[1]));
    const deltaLon = toRadians(Number(end[0]) - Number(start[0]));
    const y = Math.sin(deltaLon) * Math.cos(endLat);
    const x = Math.cos(startLat) * Math.sin(endLat) - Math.sin(startLat) * Math.cos(endLat) * Math.cos(deltaLon);
    const bearing = (toDegrees(Math.atan2(y, x)) + 360) % 360;
    return Number.isFinite(bearing) ? bearing : map.getBearing();
  };

  let cinematicCameraBearing = null;
  let currentPlaybackCameraBaseTarget = null;
  let currentPlaybackCameraTarget = null;
  const playbackCameraUserOffset = { bearing: 0, pitch: 0, zoom: 0 };
  let playbackCameraOffsetFrame = 0;
  let playbackCameraUserInteracting = false;
  let playbackCameraManualOverride = false;
  let playbackCameraInteractionTimer = 0;
  let playbackCameraOffsetActive = false;

  const shortestBearingDelta = (targetBearing, currentBearing) =>
    ((((targetBearing - currentBearing) % 360) + 540) % 360) - 180;

  const clampPitch = (pitch) => Math.min(82, Math.max(0, Number(pitch) || 0));
  const clampZoom = (zoom) => Math.min(map.getMaxZoom?.() || 18, Math.max(map.getMinZoom?.() || 0, Number(zoom) || 0));

  const renderTimelineCameraResetButton = () => {
    if (!timelineCameraResetButton) return;
    timelineCameraResetButton.hidden = !(timelinePlaybackActive && (playbackCameraOffsetActive || playbackCameraManualOverride));
  };

  const resetPlaybackCameraOffset = () => {
    playbackCameraUserOffset.bearing = 0;
    playbackCameraUserOffset.pitch = 0;
    playbackCameraUserOffset.zoom = 0;
    playbackCameraUserInteracting = false;
    playbackCameraManualOverride = false;
    playbackCameraOffsetActive = false;
    renderTimelineCameraResetButton();
    const state = currentScrubState || scrubberStateFromValue(scrubberValue);
    if (timelinePlaybackActive && state) {
      trackScrubCamera(state, false, cinematicPlaybackCameraEnabled);
      if (!state.inGap) showScrubPlaybackPopup(state);
    }
  };

  const rememberPlaybackCameraOffset = () => {
    if (!timelinePlaybackActive || !currentPlaybackCameraBaseTarget) return;
    playbackCameraUserOffset.bearing = shortestBearingDelta(map.getBearing(), currentPlaybackCameraBaseTarget.bearing || 0);
    playbackCameraUserOffset.pitch = clampPitch(map.getPitch()) - clampPitch(currentPlaybackCameraBaseTarget.pitch);
    playbackCameraUserOffset.zoom = clampZoom(map.getZoom()) - clampZoom(currentPlaybackCameraBaseTarget.zoom);
    playbackCameraOffsetActive =
      Math.abs(playbackCameraUserOffset.bearing) > 1 ||
      Math.abs(playbackCameraUserOffset.pitch) > 1 ||
      Math.abs(playbackCameraUserOffset.zoom) > 0.08;
    renderTimelineCameraResetButton();
  };

  const cameraWithUserOffset = ({ bearing, pitch, zoom }) => {
    currentPlaybackCameraBaseTarget = {
      bearing: Number(bearing || 0),
      pitch: clampPitch(pitch),
      zoom: clampZoom(zoom),
    };
    const nextBearing = Number(bearing || 0) + playbackCameraUserOffset.bearing;
    const nextPitch = clampPitch(Number(pitch || 0) + playbackCameraUserOffset.pitch);
    const nextZoom = clampZoom(Number(zoom || map.getZoom()) + playbackCameraUserOffset.zoom);
    currentPlaybackCameraTarget = { bearing: nextBearing, pitch: nextPitch, zoom: nextZoom };
    return currentPlaybackCameraTarget;
  };

  const smoothedCinematicBearing = (targetBearing, itemChanged) => {
    if (!Number.isFinite(targetBearing)) return Number.isFinite(cinematicCameraBearing) ? cinematicCameraBearing : map.getBearing();
    const currentBearing = Number.isFinite(cinematicCameraBearing) ? cinematicCameraBearing : map.getBearing();
    const delta = ((((targetBearing - currentBearing) % 360) + 540) % 360) - 180;
    cinematicCameraBearing = currentBearing + delta * (itemChanged ? 0.32 : 0.14);
    return cinematicCameraBearing;
  };

  const resetCameraNorthUp = () => {
    cinematicCameraBearing = null;
    setTerrainExaggeration(1.35);
    const state = currentScrubState || scrubberStateFromValue(scrubberValue);
    map.easeTo({
      center: state?.coordinate || map.getCenter(),
      zoom: state ? scrubZoomForState(state) : map.getZoom(),
      bearing: 0,
      pitch: 0,
      duration: 760,
      easing: (time) => 1 - (1 - time) ** 3,
      essential: true,
    });
  };

  const trackCinematicScrubCamera = (state, itemChanged) => {
    if (!state?.coordinate) return;
    const segmentCoordinates = sanitizedCoordinates(state.segment?.coordinates);
    const coordinates =
      segmentCoordinates.length >= 2
        ? segmentCoordinates
        : state.coordinates?.length
          ? state.coordinates
          : routeCoordinatesForItem(state.item);
    const terrainProfile = cinematicTerrainProfileForState(state);
    const routeProfile = cinematicRouteProfileForState(state, coordinates);
    const compactRouteProfile = isCompactCinematicProfile(routeProfile);
    const compact = mapElement.clientWidth < 680;
    const playbackMode = playbackModeForState(state);
    const activityMode = cinematicActivityModeForState(state);
    const isActivity = activityMode === "run" || activityMode === "bike" || activityMode === "race" || activityMode === "swim" || activityMode === "paddle";
    const terrainAware = Boolean(terrainProfile) || isActivity || compactRouteProfile;
    setTerrainExaggeration(
      routeProfile.kind === "court" || routeProfile.kind === "track"
        ? 1.08
        :
      terrainProfile === "canyon-race"
        ? 2.35
        : terrainProfile === "trail-race" || isActivity
          ? 1.85
          : 1.35,
    );
    const segmentProgress = Math.min(1, Math.max(0, Number(state.segmentProgress ?? state.routeProgress) || 0));
    const lookAheadAmount =
      playbackMode === "plane"
        ? 0.08
        : activityMode === "run" || activityMode === "race"
          ? 0.012
          : activityMode === "bike"
            ? 0.018
            : playbackMode === "car"
              ? 0.045
              : 0.035;
    const lookBackAmount = Math.max(0.006, lookAheadAmount * 0.62);
    const lookAhead = coordinateAtProgress(coordinates, Math.min(1, segmentProgress + lookAheadAmount));
    const lookBack = coordinateAtProgress(coordinates, Math.max(0, segmentProgress - lookBackAmount));
    const longPlaneRoute = playbackMode === "plane" && zoomDistanceForState(state) > 3000;
    const shouldFollowRouteBearing = Boolean(lookAhead) && Boolean(lookBack) && !state.inGap && !longPlaneRoute && !compactRouteProfile;
    const orbitSeed = stableAngleForText(`${state.item?.slug || ""} ${textForCinematicRouteState(state)}`);
    const orbitSweep =
      routeProfile.kind === "court"
        ? 250
        : routeProfile.kind === "track"
          ? 180
          : 120;
    const targetBearing = compactRouteProfile
      ? (orbitSeed + segmentProgress * orbitSweep) % 360
      : shouldFollowRouteBearing
        ? bearingBetweenCoordinates(lookBack, lookAhead)
        : 0;
    const routeBearing = compactRouteProfile || shouldFollowRouteBearing
      ? smoothedCinematicBearing(targetBearing, itemChanged)
      : 0;
    const basePitch = state.inGap
      ? compact ? 20 : 32
      : routeProfile.kind === "court"
        ? compact ? 34 : 42
      : routeProfile.kind === "track"
        ? compact ? 40 : 48
      : routeProfile.kind === "loop"
        ? compact ? 42 : 52
      : terrainProfile === "canyon-race"
        ? compact ? 54 : 62
      : terrainProfile === "trail-race"
        ? compact ? 52 : 60
      : isActivity
        ? compact ? 50 : 58
      : playbackMode === "car"
        ? compact ? 44 : 52
        : compact ? 38 : 50;
    const camera = cameraWithUserOffset({
      bearing: routeBearing,
      pitch: basePitch,
      zoom: cinematicZoomForState(state),
    });
    const compactProfileCenter =
      compactRouteProfile && routeProfile.metrics?.center
        ? interpolateLngLat(
            routeProfile.metrics.center,
            state.coordinate,
            routeProfile.kind === "court"
              ? 0.08
              : routeProfile.kind === "track"
                ? 0.14
                : 0.2,
          )
        : null;
    const center =
      compactProfileCenter ||
      (shouldFollowRouteBearing && lookAhead
        ? interpolateLngLat(
            state.coordinate,
            lookAhead,
            activityMode === "bike"
              ? (compact ? 0.42 : 0.5)
              : isActivity
                ? (compact ? 0.3 : 0.36)
                : playbackMode === "car" ? (compact ? 0.22 : 0.3) : compact ? 0.12 : 0.18,
          )
        : state.coordinate);
    const cameraDuration =
      compactRouteProfile
        ? itemChanged ? 960 : 520
        : playbackMode === "plane"
        ? (itemChanged ? 360 : 70)
        : activityMode === "bike"
        ? itemChanged ? 620 : 220
        : isActivity
          ? itemChanged ? 820 : 300
          : terrainAware
            ? itemChanged ? 1020 : 520
            : compact ? (itemChanged ? 820 : 360) : (itemChanged ? 1120 : 520);
    map.easeTo({
      center,
      zoom: camera.zoom,
      bearing: camera.bearing,
      pitch: camera.pitch,
      offset: compactRouteProfile
        ? routeProfile.kind === "court"
          ? compact ? [0, 34] : [0, 54]
          : compact ? [0, 58] : [0, 88]
        : shouldFollowRouteBearing
        ? isActivity
          ? activityMode === "bike"
            ? compact ? [0, 82] : [0, 132]
            : compact ? [0, 104] : [0, 164]
          : playbackMode === "car"
            ? compact ? [0, 92] : [0, 142]
            : compact ? [0, 54] : [0, 82]
        : compact ? [0, -4] : [0, -18],
      duration: cameraDuration,
      easing: (time) => terrainAware ? 1 - (1 - time) ** 3 : time * time * (3 - 2 * time),
      essential: true,
    });
  };

  const trackScrubCamera = (state, itemChanged, cinematic = false) => {
    if (!state?.coordinate) return;
    if (cinematic) {
      trackCinematicScrubCamera(state, itemChanged);
      return;
    }
    const playbackMode = playbackModeForState(state);
    const basePitch = state.item?.type === "race" ? (mapElement.clientWidth < 680 ? 34 : 42) : mapElement.clientWidth < 680 ? 28 : 36;
    const camera = cameraWithUserOffset({
      bearing: 0,
      pitch: basePitch,
      zoom: scrubZoomForState(state),
    });
    const cameraDuration =
      timelinePlaybackActive
        ? itemChanged
          ? (playbackMode === "plane" ? 260 : 220)
          : playbackMode === "plane"
            ? 55
            : playbackMode === "car"
              ? 80
              : 95
        : itemChanged ? 320 : 120;
    map.easeTo({
      center: state.coordinate,
      zoom: camera.zoom,
      bearing: camera.bearing,
      pitch: camera.pitch,
      duration: cameraDuration,
      essential: true,
    });
  };

  const setScrubberProgress = (value, { trackCamera = false, syncRail = false, centerDot = true, showPopup = false } = {}) => {
    const clampedValue = clampScrubberValue(value);
    scrubberValue = clampedValue;
    const state = scrubberStateFromValue(clampedValue);
    if (!state?.item) return;
    const itemChanged = applyScrubFocus(state.item, { centerDot });
    prefetchUpcomingTimelineTransition(state);
    updateRouteProgressMarker(state);
    updatePlaybackPhotoCallout(showPopup ? state : null);
    if (syncRail && itemChanged) scrollTimelineToValue(clampedValue, "smooth");
    if (showPopup) updatePlaybackSegmentHighlight(state);
    if (trackCamera && !(timelinePlaybackActive && (playbackCameraManualOverride || playbackCameraUserInteracting))) {
      trackScrubCamera(state, itemChanged, cinematicPlaybackCameraEnabled);
    }
    if (showPopup && !(timelinePlaybackActive && (playbackCameraManualOverride || playbackCameraUserInteracting))) showScrubPlaybackPopup(state);
  };

  let timelinePlaybackFrame = 0;
  let timelinePlaybackLastTime = 0;
  let timelinePlaybackActive = false;
  let cinematicPlaybackCameraEnabled = false;
  let includeStravaInPlayback = true;
  let timelinePlaybackStartSlug = "";
  let playbackStandaloneRaceSlugs = new Set();
  const timelinePlaybackSpeeds = [1, 1.5, 2, 3, 5, 10];
  let timelinePlaybackSpeedIndex = 0;
  const kilometersPerMile = 1.609344;
  const nineMinuteMileKilometersPerSecond = kilometersPerMile / (9 * 60);
  const playbackKilometersPerSecondAtNineMinuteMile = 0.9;
  const playbackKilometersPerSecondByMode = {
    race: playbackKilometersPerSecondAtNineMinuteMile,
    swim: 0.34,
    run: 0.9,
    bike: 2.35,
    paddle: 0.78,
    car: 32.4,
    boat: 3.4,
    helicopter: 7.2,
    plane: 1215,
  };
  const activityPaceScaleLimitsByMode = {
    race: [0.3, 2.4],
    swim: [0.12, 1.05],
    run: [0.3, 2.4],
    bike: [0.65, 5.8],
    paddle: [0.12, 1.5],
  };
  const playbackGapUnitsPerSecond = 5;

  const formatPlaybackSpeed = (speed) => `${Number.isInteger(speed) ? speed.toFixed(0) : speed}x`;

  const renderTimelineSpeedButton = () => {
    const speed = timelinePlaybackSpeeds[timelinePlaybackSpeedIndex] || 1;
    const label = formatPlaybackSpeed(speed);
    if (timelineSpeedLabel) timelineSpeedLabel.textContent = label;
    if (timelineSpeedButton) timelineSpeedButton.setAttribute("aria-label", `Playback speed ${label}`);
  };

  const normalizePlaybackMode = (mode) => {
    const value = String(mode || "").toLowerCase();
    if (/helicopter|heli/.test(value)) return "helicopter";
    if (value.includes("flight") || value.includes("plane")) return "plane";
    if (value.includes("drive") || value.includes("car")) return "car";
    if (/swim/.test(value)) return "swim";
    if (/kayak|canoe|row|paddle/.test(value)) return "paddle";
    if (value.includes("sail") || value.includes("boat") || value.includes("ferry") || value.includes("cruise")) return "boat";
    if (/run|walk|hike|foot|snowshoe|tennis|pickleball|basketball|spikeball/.test(value)) return "run";
    if (/ride|bike|cycling|ski|snowboard|skate|surf|wheelchair|handcycle/.test(value)) return "bike";
    return "";
  };

  const raceSegmentPlaybackMode = (segment) => {
    const sportText = [
      segment?.properties?.activityGroup,
      segment?.properties?.sportType,
      segment?.properties?.type,
      segment?.properties?.name,
      segment?.properties?.sourcePath,
    ].filter(Boolean).join(" ");
    const normalized = normalizePlaybackMode(sportText);
    if (["swim", "bike", "paddle", "run"].includes(normalized)) return normalized;
    return "race";
  };

  const dominantTripPlaybackMode = (item) => {
    if (!item) return "car";
    const modes = [
      ...(Array.isArray(item.routeSegments) ? item.routeSegments.map((segment) => segment?.mode) : []),
      ...((tripRouteCollections.routes.features || [])
        .filter((feature) => feature.properties?.slug === item.slug)
        .map((feature) => feature.properties?.mode)),
      item.travelMode,
    ].map(normalizePlaybackMode).filter(Boolean);
    if (!modes.length) return "car";
    if (modes.includes("car")) return "car";
    if (modes.includes("boat")) return "boat";
    if (modes.includes("plane")) return "plane";
    return modes[0] || "car";
  };

  const playbackModeForState = (state) => {
    const segment = state?.segment || {};
    if (state?.inGap) return normalizePlaybackMode(segment.mode) || "plane";
    if (segment.kind === "strava") {
      return normalizePlaybackMode(`${segment.properties?.type || ""} ${segment.properties?.sportType || ""} ${segment.properties?.activityGroup || ""}`) || "run";
    }
    if (segment.kind === "race") return raceSegmentPlaybackMode(segment);
    if (state?.item?.type === "race") return "race";
    if (segment.kind === "connector" || segment.kind === "transition") return normalizePlaybackMode(segment.mode) || dominantTripPlaybackMode(state?.item);
    return normalizePlaybackMode(`${segment.vehicle || ""} ${segment.properties?.vehicle || ""} ${segment.mode || ""}`) || dominantTripPlaybackMode(state?.item);
  };

  const segmentActualKilometersPerSecond = (state, mode) => {
    const properties = state?.segment?.properties || {};
    const distanceMeters =
      Number(properties.distanceMeters) ||
      Number(state?.item?.distanceMeters) ||
      Number(state?.segment?.distanceMeters) ||
      0;
    const durationSeconds =
      Number(properties.movingTimeSeconds) ||
      Number(state?.item?.movingTimeSeconds) ||
      Number(properties.elapsedTimeSeconds) ||
      Number(state?.item?.elapsedTimeSeconds) ||
      0;
    if (!Number.isFinite(distanceMeters) || !Number.isFinite(durationSeconds) || distanceMeters <= 0 || durationSeconds <= 0) {
      return 0;
    }

    const actualKilometersPerSecond = distanceMeters / 1000 / durationSeconds;
    if (!Number.isFinite(actualKilometersPerSecond) || actualKilometersPerSecond <= 0) return 0;

    const paceScale = actualKilometersPerSecond / nineMinuteMileKilometersPerSecond;
    const [minScale, maxScale] = activityPaceScaleLimitsByMode[mode] || activityPaceScaleLimitsByMode.run;
    const clampedScale = Math.min(maxScale, Math.max(minScale, paceScale));
    const scaledSpeed = playbackKilometersPerSecondAtNineMinuteMile * clampedScale;
    return mode === "bike" ? Math.max(scaledSpeed, playbackKilometersPerSecondByMode.bike) : scaledSpeed;
  };

  const playbackKilometersPerSecondForState = (state, mode) => {
    if (state?.segment?.kind === "connector" || state?.segment?.kind === "transition") {
      const baseSpeed = playbackKilometersPerSecondByMode[mode] || playbackKilometersPerSecondByMode.car;
      return mode === "car" ? baseSpeed * 2.2 : baseSpeed;
    }
    if (state?.segment?.kind === "strava" || state?.item?.type === "strava" || state?.segment?.kind === "race") {
      return segmentActualKilometersPerSecond(state, mode) || playbackKilometersPerSecondByMode[mode] || playbackKilometersPerSecondByMode.run;
    }
    const baseSpeed = playbackKilometersPerSecondByMode[mode] || playbackKilometersPerSecondByMode.car;
    return baseSpeed;
  };

  const playbackRouteUnitsForState = (state) =>
    state?.inGap
      ? scrubberUnitsPerItem * (1 - scrubberRoutePortion)
      : state?.itemIndex === timelineSequence.length - 1
        ? scrubberUnitsPerItem
        : scrubberUnitsPerItem * scrubberRoutePortion;

  const scrubberValueForState = (state) =>
    state?.item
      ? state.itemIndex * scrubberUnitsPerItem + Math.min(1, Math.max(0, Number(state.phase) || 0)) * scrubberUnitsPerItem
      : scrubberValue;

  const routeProgressAtSegmentEnd = (segments = [], segmentIndex = 0) => {
    if (!Array.isArray(segments) || !segments.length) return 1;
    const distances = segments.map((segment) => Math.max(0, cachedPathDistance(segment.coordinates || [])));
    const totalDistance = distances.reduce((sum, distance) => sum + distance, 0);
    if (!Number.isFinite(totalDistance) || totalDistance <= 0) return 1;
    const endDistance = distances
      .slice(0, Math.min(segments.length, Math.max(0, Number(segmentIndex) || 0) + 1))
      .reduce((sum, distance) => sum + distance, 0);
    return Math.min(1, Math.max(0, endDistance / totalDistance));
  };

  const clampPlaybackDeltaToModeBoundary = (state, delta) => {
    const attemptedDelta = Math.max(0, Number(delta) || 0);
    if (!state?.item || attemptedDelta <= 0) return attemptedDelta;

    if (state.inGap && state.nextItem) {
      const nextSegments = playbackSegmentsForItem(state.nextItem);
      const nextCoordinates = flattenPlaybackSegments(nextSegments);
      const nextState = {
        ...state,
        item: state.nextItem,
        nextItem: timelineSequence[state.itemIndex + 2] || null,
        itemIndex: state.itemIndex + 1,
        phase: 0,
        routeProgress: 0,
        inGap: false,
        pathDistance: cachedPathDistance(nextCoordinates),
        segment: nextSegments[0] || null,
        segmentIndex: 0,
        segmentProgress: 0,
        playbackSegments: nextSegments,
        coordinates: nextCoordinates,
      };
      if (playbackModeForState(state) !== playbackModeForState(nextState) || (state.segment?.kind || "") !== (nextState.segment?.kind || "")) {
        const boundaryValue = (state.itemIndex + 1) * scrubberUnitsPerItem;
        const remainingToBoundary = boundaryValue - scrubberValueForState(state);
        if (remainingToBoundary >= 0 && attemptedDelta > remainingToBoundary) {
          return Math.max(0, remainingToBoundary) + 0.0001;
        }
      }
      return attemptedDelta;
    }

    const segmentIndex = Number(state.segmentIndex);
    const segments = Array.isArray(state.playbackSegments) ? state.playbackSegments : [];
    if (!Number.isFinite(segmentIndex) || segmentIndex < 0 || segmentIndex >= segments.length - 1) return attemptedDelta;

    const nextState = stateForNeighborSegment(state, segmentIndex + 1, 0);
    if (!nextState) return attemptedDelta;

    const currentMode = playbackModeForState(state);
    const nextMode = playbackModeForState(nextState);
    const currentKind = state.segment?.kind || "";
    const nextKind = nextState.segment?.kind || "";
    if (currentMode === nextMode && currentKind === nextKind) return attemptedDelta;

    const boundaryProgress = routeProgressAtSegmentEnd(segments, segmentIndex);
    const boundaryValue = state.itemIndex * scrubberUnitsPerItem + boundaryProgress * playbackRouteUnitsForState(state);
    const remainingToBoundary = boundaryValue - scrubberValueForState(state);
    if (remainingToBoundary < 0 || attemptedDelta <= remainingToBoundary) return attemptedDelta;

    return Math.max(0, remainingToBoundary) + 0.0001;
  };

  const playbackValueDeltaForState = (state, elapsedSeconds) => {
    const elapsed = Math.max(0, Number(elapsedSeconds) || 0);
    if (!state?.item) return elapsed * playbackGapUnitsPerSecond;
    const mode = playbackModeForState(state);
    const speed = timelinePlaybackSpeeds[timelinePlaybackSpeedIndex] || 1;

    const routeDistance = Math.max(0.08, Number(state.pathDistance) || cachedPathDistance(state.coordinates || []));
    const routeUnits = playbackRouteUnitsForState(state);
    const kilometersPerSecond = playbackKilometersPerSecondForState(state, mode);
    const photoMultiplier = photoForPlaybackState(state) ? 0.34 : 1;
    const delta = (elapsed * kilometersPerSecond * speed * photoMultiplier * routeUnits) / routeDistance;
    return clampPlaybackDeltaToModeBoundary(state, delta);
  };

  const renderTimelinePlaybackButton = () => {
    if (!timelinePlayButton) return;
    document.body.classList.toggle("is-travel-playing", timelinePlaybackActive);
    timelinePlayButton.classList.toggle("is-playing", timelinePlaybackActive);
    timelinePlayButton.setAttribute("aria-pressed", String(timelinePlaybackActive));
    timelinePlayButton.setAttribute("aria-label", timelinePlaybackActive ? "Pause timeline" : "Play timeline");
    if (timelinePlayLabel) timelinePlayLabel.textContent = timelinePlaybackActive ? "Pause" : "Play";
  };

  const renderTimelineCameraButton = () => {
    if (!timelineCameraButton) return;
    timelineCameraButton.classList.toggle("is-active", cinematicPlaybackCameraEnabled);
    timelineCameraButton.setAttribute("aria-pressed", String(cinematicPlaybackCameraEnabled));
    timelineCameraButton.setAttribute("aria-label", cinematicPlaybackCameraEnabled ? "Disable cinematic camera" : "Enable cinematic camera");
    if (timelineCameraLabel) timelineCameraLabel.textContent = cinematicPlaybackCameraEnabled ? "Cinematic" : "Camera";
  };

  const toggleTimelineCamera = () => {
    cinematicPlaybackCameraEnabled = !cinematicPlaybackCameraEnabled;
    renderTimelineCameraButton();
    if (!cinematicPlaybackCameraEnabled) {
      resetPlaybackCameraOffset();
      resetCameraNorthUp();
    }
  };

  const cycleTimelineSpeed = () => {
    timelinePlaybackSpeedIndex = (timelinePlaybackSpeedIndex + 1) % timelinePlaybackSpeeds.length;
    renderTimelineSpeedButton();
  };

  const stopTimelinePlayback = () => {
    timelinePlaybackActive = false;
    timelinePlaybackLastTime = 0;
    timelinePlaybackStartSlug = "";
    playbackStandaloneRaceSlugs = new Set();
    tripPlaybackSegmentsCache.clear();
    if (timelinePlaybackFrame) window.cancelAnimationFrame(timelinePlaybackFrame);
    timelinePlaybackFrame = 0;
    renderTimelinePlaybackButton();
    renderTimelineCameraResetButton();
    updatePlaybackSegmentHighlight(null);
    updatePlaybackPhotoCallout(null);
  };

  const skipExcludedPlaybackItems = () => {
    let skipped = false;
    for (let guard = 0; guard < timelineSequence.length; guard += 1) {
      const state = scrubberStateFromValue(scrubberValue);
      const shouldSkipStrava = state?.item?.type === "strava" && !includeStravaInPlayback;
      const shouldSkipEmbeddedRace =
        state?.item?.type === "race" &&
        state.item.slug !== timelinePlaybackStartSlug &&
        raceCanPlayInsideAnyTrip(state.item);
      if (!shouldSkipStrava && !shouldSkipEmbeddedRace) break;
      const nextValue = (state.itemIndex + 1) * scrubberUnitsPerItem;
      scrubberValue = Math.min(scrubberMaxValue, nextValue);
      skipped = true;
      if (nextValue >= scrubberMaxValue) {
        stopTimelinePlayback();
        break;
      }
      if (scrubberValue >= scrubberMaxValue) break;
    }
    if (skipped) {
      setScrubberProgress(scrubberValue, {
        trackCamera: true,
        syncRail: true,
        centerDot: true,
        showPopup: false,
      });
    }
    return skipped;
  };

  const runTimelinePlayback = (timestamp) => {
    if (!timelinePlaybackActive) return;
    if (skipExcludedPlaybackItems()) {
      if (timelinePlaybackActive) timelinePlaybackFrame = window.requestAnimationFrame(runTimelinePlayback);
      return;
    }
    if (!timelinePlaybackLastTime) timelinePlaybackLastTime = timestamp;
    const elapsedSeconds = Math.min(0.08, Math.max(0, (timestamp - timelinePlaybackLastTime) / 1000));
    timelinePlaybackLastTime = timestamp;
    const state = scrubberStateFromValue(scrubberValue);
    if (state?.item?.type === "race") playbackStandaloneRaceSlugs.add(state.item.slug);
    const nextValue = clampScrubberValue(scrubberValue + playbackValueDeltaForState(state, elapsedSeconds));
    setScrubberProgress(nextValue, {
      trackCamera: true,
      syncRail: true,
      centerDot: true,
      showPopup: true,
    });
    if (nextValue >= scrubberMaxValue) {
      stopTimelinePlayback();
      return;
    }
    timelinePlaybackFrame = window.requestAnimationFrame(runTimelinePlayback);
  };

  renderTimelineSpeedButton();

  const startTimelinePlayback = () => {
    if (!timelineSequence.length || timelinePlaybackActive) return;
    if (scrubberValue >= scrubberMaxValue - 0.01) scrubberValue = 0;
    const startState = scrubberStateFromValue(scrubberValue);
    timelinePlaybackStartSlug = startState?.item?.slug || "";
    playbackStandaloneRaceSlugs = new Set();
    if (startState?.item?.type === "race") playbackStandaloneRaceSlugs.add(startState.item.slug);
    tripPlaybackSegmentsCache.clear();
    timelinePlaybackActive = true;
    timelinePlaybackLastTime = 0;
    renderTimelinePlaybackButton();
    renderTimelineCameraResetButton();
    timelinePlaybackFrame = window.requestAnimationFrame(runTimelinePlayback);
  };

  const toggleTimelinePlayback = () => {
    if (timelinePlaybackActive) {
      stopTimelinePlayback();
      return;
    }
    startTimelinePlayback();
  };

  const fitOverview = () => {
    map.easeTo({
      center: mapElement.clientWidth < 680 ? [-90, 28] : [-54, 28],
      zoom: mapElement.clientWidth < 680 ? 0.2 : 0.92,
      bearing: -8,
      pitch: 0,
      duration: 0,
    });
  };

  const selectItem = (slug, shouldScroll = false, preferredCoordinate = null, routeSegment = null) => {
    const item = allPointsBySlug.get(slug);
    if (!item) return;

    activeTimelineSlug = slug;
    activeStravaActivityId = item.type === "strava" ? String(item.stravaActivityId || "") : "";
    activeTripRouteSegment = item.type === "trip" && routeSegment ? { ...routeSegment, slug } : null;
    playbackStravaActivityId = "";
    playbackRaceSlug = "";
    updateActiveSummary(item);
    setActiveTimelineDot(slug);
    if (map.getLayer("map-point-highlight")) {
      map.setFilter("map-point-highlight", ["==", ["get", "slug"], slug]);
    }
    setRouteHighlight(item.type === "trip" ? slug : "", activeTripRouteSegment?.segmentIndex);
    setRaceRouteHighlight(item.type === "race" ? slug : "");
    setStravaRouteHighlight(item.type === "strava" ? activeStravaActivityId : "");
    updateLayerVisibility();

    const popupCoordinate = popupCoordinateForItem(item, preferredCoordinate);
    const popupPlacement = routePopupPlacement(popupCoordinate);
    const routeFit =
      item.type === "race"
        ? fitRaceRoute(item, popupPlacement)
        : item.type === "strava"
          ? fitStravaItemRoute(item, popupPlacement)
          : activeTripRouteSegment
            ? fitTripRouteSegment(item, activeTripRouteSegment, popupPlacement)
            : fitTripRoute(item, popupPlacement);
    if (!routeFit) {
      map.flyTo({ center: [item.lon, item.lat], zoom: item.type === "race" || item.type === "strava" ? 9.2 : 4.8, duration: 850 });
    }
    syncScrubberToItem(item, popupCoordinate, {
      behavior: shouldScroll ? "smooth" : "auto",
      progressOverride: activeTripRouteSegment ? tripRouteSegmentProgress(item, activeTripRouteSegment, popupCoordinate) : null,
    });
    showPopup(item, popupCoordinate, popupPlacement.anchor, true);
  };

  const clearSelection = () => {
    activeTimelineSlug = "";
    activeStravaActivityId = "";
    activeTripRouteSegment = null;
    playbackStravaActivityId = "";
    playbackRaceSlug = "";
    setActiveTimelineDot("");
    if (map.getLayer("map-point-highlight")) {
      map.setFilter("map-point-highlight", ["==", ["get", "slug"], ""]);
    }
    setRouteHighlight("");
    setRaceRouteHighlight("");
    setStravaRouteHighlight("");
    clearScheduledPopup();
    popup.remove();
    updateRouteProgressMarker(null);
    updateLayerVisibility();
  };

  const setVisibility = (layerIds, visible) => {
    layerIds.forEach((layerId) => {
      if (map.getLayer(layerId)) map.setLayoutProperty(layerId, "visibility", visible ? "visible" : "none");
    });
  };

  const visibleRouteModesForSlug = (slug) => {
    const features = (tripRouteCollections.routes.features || []).filter((feature) => feature.properties?.slug === slug);
    if (!features.length) return true;
    return features.some((feature) => layerVisibility[feature.properties?.mode || "drive"] !== false);
  };

  const updateLayerVisibility = () => {
    const activeItem = allPointsBySlug.get(activeTimelineSlug);
    const highlightedRaceSlug = activeItem?.type === "race" ? activeTimelineSlug : playbackRaceSlug;
    const highlightedStravaActivityId = activeStravaActivityId || playbackStravaActivityId;
    const highlightedTripSegment =
      activeItem?.type === "trip" && activeTripRouteSegment?.slug === activeTimelineSlug
        ? activeTripRouteSegment.segmentIndex
        : null;
    setRouteHighlight(activeItem?.type === "trip" ? activeTimelineSlug : "", highlightedTripSegment);
    setRaceRouteHighlight(highlightedRaceSlug);
    setMapPointLabelFilter(activeItem);
    setStravaRouteHighlight(highlightedStravaActivityId);

    setVisibility(["trip-routes-flight"], layerVisibility.flight);
    setVisibility(["trip-routes-drive-casing", "trip-routes-drive"], layerVisibility.drive);
    setVisibility(["trip-routes-sail"], layerVisibility.sail);
    setVisibility(["trip-route-nodes"], layerVisibility.dots);
    setVisibility(["strava-routes-heat-overview", "strava-routes-heat", "strava-routes", "strava-route-highlight-casing", "strava-route-highlight"], layerVisibility.strava);
    setVisibility(["map-points", "map-point-labels"], layerVisibility.dots);
    setVisibility(["race-routes-base-casing", "race-routes-base"], layerVisibility.race);
    setVisibility(["map-point-highlight"], layerVisibility.dots && Boolean(activeTimelineSlug));
    setVisibility(["trip-route-highlight-casing", "trip-route-highlight"], Boolean(activeTimelineSlug) && visibleRouteModesForSlug(activeTimelineSlug));
    setVisibility(["trip-route-node-highlight"], layerVisibility.dots && Boolean(activeTimelineSlug));
    setVisibility(
      ["race-route-highlight-casing", "race-route-highlight"],
      layerVisibility.race && Boolean(highlightedRaceSlug) && raceRouteFeaturesBySlug.has(highlightedRaceSlug),
    );

    layerToggleButtons.forEach((button) => {
      const key = button.getAttribute("data-map-layer-toggle");
      const visible = layerVisibility[key] !== false;
      button.setAttribute("aria-pressed", String(visible));
      button.classList.toggle("is-muted", !visible);
    });

    if (map.getSource("strava-line-heatmap")) void updateStravaHeatTileSource();
  };

  const updatePlaybackSegmentHighlight = (state = null) => {
    const segment = state?.segment || {};
    const nextStravaActivityId = segment.kind === "strava" ? String(segment.properties?.id || "") : "";
    const nextRaceSlug = segment.kind === "race" ? String(segment.item?.slug || "") : "";
    if (nextStravaActivityId === playbackStravaActivityId && nextRaceSlug === playbackRaceSlug) return;
    playbackStravaActivityId = nextStravaActivityId;
    playbackRaceSlug = nextRaceSlug;
    updateLayerVisibility();
  };

  const bindPointerLayer = (layerId) => {
    map.on("mouseenter", layerId, () => {
      map.getCanvas().style.cursor = "pointer";
    });
    map.on("mouseleave", layerId, () => {
      map.getCanvas().style.cursor = "";
    });
  };

  const interactiveFeatureLayers = () =>
    [
      "map-points",
      "map-point-highlight",
      "trip-routes-flight",
      "trip-routes-drive-casing",
      "trip-routes-drive",
      "trip-routes-sail",
      "trip-route-nodes",
      "trip-route-highlight",
      "trip-route-highlight-casing",
      "trip-route-node-highlight",
      "race-routes-base",
      "race-routes-base-casing",
      "race-route-highlight",
      "race-route-highlight-casing",
      "strava-routes",
      "strava-route-highlight",
      "strava-route-highlight-casing",
      "route-progress-marker",
      "route-progress-marker-halo",
    ].filter((layerId) => map.getLayer(layerId));

  const choiceFromRenderedFeature = (feature, clickCoordinate = null) => {
    const layerId = feature?.layer?.id || "";
    const properties = feature?.properties || {};

    if (layerId.startsWith("strava-route") || layerId === "strava-routes") {
      const activityId = properties.id;
      if (!activityId) return null;
      return {
        key: `strava:${activityId}`,
        kind: "strava",
        properties,
      };
    }

    if (layerId.startsWith("race-route")) {
      const race = allPointsBySlug.get(properties.raceSlug);
      return race ? { key: `item:${race.slug}`, kind: "item", item: race } : null;
    }

    if (layerId.startsWith("trip-route") || layerId.startsWith("map-point") || layerId.startsWith("route-progress")) {
      const slug = properties.slug || activeTimelineSlug;
      const item = allPointsBySlug.get(slug);
      const routeSegment = layerId.startsWith("trip-route")
        ? tripRouteSegmentFromFeature(feature, clickCoordinate)
        : null;
      return item ? { key: `item:${item.slug}`, kind: "item", item, routeSegment } : null;
    }

    return null;
  };

  const choiceClickScore = (choice, clickCoordinate = null) => {
    const routeSegment = choice?.routeSegment;
    if (routeSegment?.coordinates?.length && clickCoordinate) {
      const nearest = progressForCoordinateInSegments([{ coordinates: routeSegment.coordinates }], clickCoordinate);
      const distance = nearest.coordinate ? haversineDistance(nearest.coordinate, clickCoordinate) : Number.POSITIVE_INFINITY;
      const overlapAdjustedDistance = distance < 0.08 ? 0 : distance;
      const casingPenalty = String(choice.layerId || "").includes("casing") ? 0.02 : 0;
      return overlapAdjustedDistance + casingPenalty + Math.max(0, Number(routeSegment.segmentIndex) || 0) * 0.000001;
    }
    return 999;
  };

  const popupChoicesAtPoint = (point, clickCoordinate = null) => {
    if (!point) return [];
    const layers = interactiveFeatureLayers();
    if (!layers.length) return [];
    const hitbox = [
      [point.x - 10, point.y - 10],
      [point.x + 10, point.y + 10],
    ];
    const choicesByKey = new Map();
    map
      .queryRenderedFeatures(hitbox, { layers })
      .map((feature) => {
        const choice = choiceFromRenderedFeature(feature, clickCoordinate);
        if (choice) choice.layerId = feature?.layer?.id || "";
        return choice;
      })
      .filter(Boolean)
      .forEach((choice) => {
        const existing = choicesByKey.get(choice.key);
        if (!existing || choiceClickScore(choice, clickCoordinate) < choiceClickScore(existing, clickCoordinate)) {
          choicesByKey.set(choice.key, choice);
        }
      });
    return [...choicesByKey.values()];
  };

  const stravaFeatureForChoice = (choice) => {
    if (choice.kind !== "strava") return null;
    const id = String(choice.properties?.id || "");
    return stravaFeatureById.get(id) || null;
  };

  const routeCoordinatesForChoice = (choice) => {
    if (choice.kind === "strava") return featureCoordinates(stravaFeatureForChoice(choice));
    if (choice.item?.type === "race") return raceRouteCoordinates(choice.item.slug);
    if (choice.item?.type === "trip" && choice.routeSegment?.coordinates?.length) return choice.routeSegment.coordinates;
    if (choice.item) return routeCoordinatesForItem(choice.item);
    return [];
  };

  const popupCoordinateForChoice = (choice, fallbackCoordinate = null) => {
    if (choice.routeSegment?.clickCoordinate) return choice.routeSegment.clickCoordinate;
    const coordinates = routeCoordinatesForChoice(choice);
    return coordinateAtProgress(coordinates, 0.5) || fallbackCoordinate;
  };

  const fitStravaChoiceRoute = (choice, placement = null) => {
    const coordinates = routeCoordinatesForChoice(choice);
    if (coordinates.length < 2) return false;

    const bounds = new mapboxgl.LngLatBounds();
    coordinates.forEach((coordinate) => bounds.extend(coordinate));
    if (bounds.isEmpty()) return false;

    map.fitBounds(bounds, {
      padding: placement?.padding || (mapElement.clientWidth < 680 ? 52 : { top: 94, bottom: 78, left: 86, right: 86 }),
      maxZoom: routeMaxZoomForDistance(cachedPathDistance(coordinates), "strava"),
      pitch: mapElement.clientWidth < 680 ? 34 : 42,
      duration: 650,
    });
    return true;
  };

  const focusPopupChoiceRoute = (choice, fallbackCoordinate = activePopupCoordinate) => {
    const coordinate = popupCoordinateForChoice(choice, fallbackCoordinate) || fallbackCoordinate;
    const placement = routePopupPlacement(coordinate);
    if (choice.kind === "strava") {
      fitStravaChoiceRoute(choice, placement);
    } else if (choice.item?.type === "race") {
      fitRaceRoute(choice.item, placement);
    } else if (choice.item?.type === "trip" && choice.routeSegment) {
      fitTripRouteSegment(choice.item, choice.routeSegment, placement);
    } else if (choice.item) {
      fitTripRoute(choice.item, placement);
    }
    return { coordinate, placement };
  };

  const renderStackedPopup = (coordinate, placement) => {
    popup.remove();
    popup = createPopup(placement.anchor);
    popup.setLngLat(coordinate).setHTML(stackedPopupHtml(activePopupChoices, activePopupChoiceIndex)).addTo(map);
    requestPopupBoundsCheck(popup);
  };

  const scheduleStackedPopupReflow = (coordinate = activePopupCoordinate) => {
    const sequence = popupSequence;
    const choiceIndex = activePopupChoiceIndex;
    const refresh = () => {
      if (sequence !== popupSequence || choiceIndex !== activePopupChoiceIndex || !popup?.isOpen?.()) return;
      const nextCoordinate = activePopupCoordinate || coordinate;
      if (!nextCoordinate) return;
      renderStackedPopup(nextCoordinate, routePopupPlacement(nextCoordinate));
    };

    map.once("moveend", refresh);
    window.setTimeout(refresh, 220);
    window.setTimeout(refresh, 860);
  };

  const activatePopupChoice = (index, { render = true } = {}) => {
    if (!activePopupChoices.length) return;
    const nextIndex = (index + activePopupChoices.length) % activePopupChoices.length;
    const choice = activePopupChoices[nextIndex];
    activePopupChoiceIndex = nextIndex;

    if (choice.kind === "strava") {
      activeStravaActivityId = String(choice.properties.id || "");
      activeTripRouteSegment = null;
      const stravaItem = syncScrubberToStravaActivity(activeStravaActivityId, activePopupCoordinate, {
        behavior: "smooth",
      });
      activeTimelineSlug = stravaItem?.slug || "";
      playbackStravaActivityId = "";
      playbackRaceSlug = "";
      setActiveTimelineDot(activeTimelineSlug);
      if (map.getLayer("map-point-highlight")) {
        map.setFilter("map-point-highlight", ["==", ["get", "slug"], ""]);
      }
      setRouteHighlight("");
      setRaceRouteHighlight("");
      setStravaRouteHighlight(activeStravaActivityId);
      if (!stravaItem) updateRouteProgressMarker(null);
      updateActiveSummary({
        title: stravaItem?.title || choiceTitle(choice),
        date: stravaItem?.date || String(choice.properties.startDate || "").slice(0, 10),
      });
      updateLayerVisibility();
    } else if (choice.item) {
      activeTimelineSlug = choice.item.slug;
      activeStravaActivityId = "";
      activeTripRouteSegment = choice.item.type === "trip" && choice.routeSegment ? { ...choice.routeSegment, slug: choice.item.slug } : null;
      playbackStravaActivityId = "";
      playbackRaceSlug = "";
      updateActiveSummary(choice.item);
      setActiveTimelineDot(choice.item.slug);
      if (map.getLayer("map-point-highlight")) {
        map.setFilter("map-point-highlight", ["==", ["get", "slug"], choice.item.slug]);
      }
      setStravaRouteHighlight("");
      updateLayerVisibility();
      syncScrubberToItem(choice.item, activePopupCoordinate, {
        behavior: "smooth",
        progressOverride: activeTripRouteSegment ? tripRouteSegmentProgress(choice.item, activeTripRouteSegment, activePopupCoordinate) : null,
      });
    }

    if (render && popup?.isOpen?.()) {
      const { coordinate, placement } = focusPopupChoiceRoute(choice);
      if (coordinate) activePopupCoordinate = coordinate;
      renderStackedPopup(coordinate || activePopupCoordinate, placement);
      scheduleStackedPopupReflow(coordinate || activePopupCoordinate);
    }
  };

  const showStackedPopup = (choices, coordinate, activeIndex = 0) => {
    clearScheduledPopup();
    popup.remove();
    activePopupChoices = choices;
    activePopupChoiceIndex = activeIndex;
    activePopupCoordinate = coordinate;
    activatePopupChoice(activeIndex, { render: false });
    const { coordinate: focusedCoordinate, placement } = focusPopupChoiceRoute(choices[activePopupChoiceIndex], coordinate);
    activePopupCoordinate = focusedCoordinate || coordinate;
    popup = createPopup(placement.anchor);
    popup.setLngLat(activePopupCoordinate).setHTML(stackedPopupHtml(choices, activePopupChoiceIndex)).addTo(map);
    requestPopupBoundsCheck(popup);
    scheduleStackedPopupReflow(activePopupCoordinate);
  };

  const showStravaPopup = (properties, lngLat) => {
    clearScheduledPopup();
    popup.remove();
    activeStravaActivityId = String(properties.id || "");
    const stravaItem = syncScrubberToStravaActivity(activeStravaActivityId, lngLat, {
      behavior: "smooth",
    });
    activeTimelineSlug = stravaItem?.slug || "";
    activeTripRouteSegment = null;
    playbackStravaActivityId = "";
    playbackRaceSlug = "";
    setActiveTimelineDot(activeTimelineSlug);
    if (map.getLayer("map-point-highlight")) {
      map.setFilter("map-point-highlight", ["==", ["get", "slug"], ""]);
    }
    setRouteHighlight("");
    setRaceRouteHighlight("");
    setStravaRouteHighlight(activeStravaActivityId);
    if (!stravaItem) updateRouteProgressMarker(null);
    updateLayerVisibility();
    updateActiveSummary({
      title: stravaItem?.title || properties.name || "Strava route",
      date: stravaItem?.date || String(properties.startDate || "").slice(0, 10),
    });
    popup = createPopup();
    popup.setLngLat(lngLat).setHTML(stravaPopupHtml(properties || {})).addTo(map);
  };

  const selectPopupChoice = (choice, coordinate) => {
    if (choice.kind === "strava") {
      showStravaPopup(choice.properties, coordinate);
      return;
    }
    if (choice.item) selectItem(choice.item.slug, false, coordinate, choice.routeSegment || null);
  };

  const handleInteractiveMapClick = (event, { markHandled = true } = {}) => {
    const coordinate = event.lngLat ? [event.lngLat.lng, event.lngLat.lat] : null;
    const choices = popupChoicesAtPoint(event.point, coordinate);
    if (!choices.length || !coordinate) return false;
    if (markHandled) handledInteractiveClick = true;
    if (choices.length === 1) {
      selectPopupChoice(choices[0], coordinate);
      return true;
    }
    showStackedPopup(choices, coordinate);
    return true;
  };

  mapElement.addEventListener("click", (event) => {
    const stepButton = event.target?.closest?.("[data-popup-stack-step]");
    if (stepButton) {
      event.preventDefault();
      event.stopPropagation();
      stopTimelinePlayback();
      activatePopupChoice(activePopupChoiceIndex + Number(stepButton.getAttribute("data-popup-stack-step") || 0));
      return;
    }

    const choiceButton = event.target?.closest?.("[data-popup-choice-index]");
    if (choiceButton) {
      event.preventDefault();
      event.stopPropagation();
      stopTimelinePlayback();
      activatePopupChoice(Number(choiceButton.getAttribute("data-popup-choice-index") || 0));
      return;
    }

    if (!event.target?.closest?.(".mapboxgl-canvas")) return;
    stopTimelinePlayback();
