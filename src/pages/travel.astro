---
import BaseLayout from "../layouts/BaseLayout.astro";
import mapData from "../data/travel-map.json";

const monthLookup: Record<string, number> = {
  jan: 0,
  feb: 1,
  mar: 2,
  apr: 3,
  may: 4,
  jun: 5,
  jul: 6,
  aug: 7,
  sep: 8,
  oct: 9,
  nov: 10,
  dec: 11,
};
const sortDate = (date: string) => {
  const [month, year] = date.split(/\s+/);
  const numericYear = Number(year || month) || 0;
  const monthIndex = monthLookup[(month || "").slice(0, 3).toLowerCase()] ?? 0;
  return new Date(Date.UTC(numericYear, monthIndex, 15)).getTime();
};
const timelineItems = [...mapData.trips, ...mapData.races].sort((a, b) => sortDate(a.date) - sortDate(b.date));
const serializedMapData = JSON.stringify(mapData).replace(/</g, "\\u003c");
---

<BaseLayout title="Travel">
  <section class="map-page" aria-labelledby="travel-title">
    <header class="map-page__header">
      <p class="eyebrow">travel / races</p>
      <h1 id="travel-title">Map</h1>
    </header>

    <section class="map-frame" aria-label="Travel and race map">
      <div id="travel-map" class="travel-map"></div>
      <div class="map-toolbar" aria-label="Map layers">
        <button type="button" data-map-filter="all" class="is-active">All</button>
        <button type="button" data-map-filter="trip">Trips</button>
        <button type="button" data-map-filter="race">Races</button>
        <button type="button" data-drive-toggle hidden>Drives</button>
        <button type="button" data-heatmap-toggle hidden>Strava heat</button>
      </div>
    </section>

    <section class="map-timeline" aria-label="Travel timeline">
      <div id="travel-timeline" class="travel-timeline-rail"></div>
      <div class="map-timeline__list">
      {
        timelineItems.map((trip) => (
          <article id={trip.slug} class="map-timeline__row" data-map-item={trip.slug} data-map-kind={trip.type}>
            <div>
              <p>{trip.title}</p>
              <small>{trip.detail}</small>
            </div>
            <span>{trip.date}</span>
          </article>
        ))
      }
      </div>
    </section>
  </section>

  <script type="application/json" id="travel-map-data" set:html={serializedMapData} />
</BaseLayout>

<script>
  import mapboxgl from "mapbox-gl";
  import "mapbox-gl/dist/mapbox-gl.css";
  import { DataSet, Timeline } from "vis-timeline/standalone";
  import "vis-timeline/styles/vis-timeline-graph2d.min.css";
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const dataElement = document.getElementById("travel-map-data");
  const mapElement = document.getElementById("travel-map");
  const timelineElement = document.getElementById("travel-timeline");
  const toolbarButtons = Array.from(document.querySelectorAll("[data-map-filter]"));
  const heatmapButton = document.querySelector("[data-heatmap-toggle]");
  const driveButton = document.querySelector("[data-drive-toggle]");
  const rows = Array.from(document.querySelectorAll("[data-map-item]"));
  const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || "";

  if (!mapElement || !mapboxToken) {
    if (mapElement) mapElement.setAttribute("data-map-empty", "true");
    throw new Error("Travel map needs PUBLIC_MAPBOX_TOKEN.");
  }

  mapboxgl.accessToken = mapboxToken;

  const mapData = JSON.parse(dataElement?.textContent || "{\"trips\":[],\"races\":[]}");
  const allPoints = [...mapData.trips, ...mapData.races];
  const driveRoutes = Array.isArray(mapData.driveRoutes) ? mapData.driveRoutes : [];
  const featureCollection = {
    type: "FeatureCollection",
    features: allPoints.map((item) => ({
      type: "Feature",
      geometry: { type: "Point", coordinates: [item.lon, item.lat] },
      properties: item,
    })),
  };

  const map = new mapboxgl.Map({
    container: mapElement,
    style: "mapbox://styles/mapbox/outdoors-v12",
    center: [-121.5, 38.6],
    zoom: 1.65,
    pitch: 0,
    projection: "globe",
    attributionControl: false,
  });

  map.addControl(new mapboxgl.NavigationControl({ visualizePitch: true }), "top-right");

  const popup = new mapboxgl.Popup({
    closeButton: false,
    closeOnClick: true,
    offset: 16,
    className: "map-popup",
  });

  const popupHtml = (item) => {
    const meta = item.type === "race" ? [item.result, item.rank].filter(Boolean).join("<br>") : item.detail;
    const title = item.href ? `<a href="${item.href}">${item.title}</a>` : item.title;
    return `<strong>${title}</strong><span>${item.date}</span><small>${meta}</small>`;
  };

  const parseTimelineDate = (date) => {
    const months = {
      jan: 0,
      feb: 1,
      mar: 2,
      apr: 3,
      may: 4,
      jun: 5,
      jul: 6,
      aug: 7,
      sep: 8,
      oct: 9,
      nov: 10,
      dec: 11,
    };
    const [first, second] = String(date || "").split(/\s+/);
    const year = Number(second || first) || new Date().getUTCFullYear();
    const month = months[String(first || "").slice(0, 3).toLowerCase()] ?? 0;
    return new Date(Date.UTC(year, month, 15));
  };

  const sortedPoints = [...allPoints].sort((a, b) => parseTimelineDate(a.date) - parseTimelineDate(b.date));
  const timeline =
    timelineElement && sortedPoints.length
      ? new Timeline(
          timelineElement,
          new DataSet(
            sortedPoints.map((item) => ({
              id: item.slug,
              content: item.title,
              start: parseTimelineDate(item.date),
              title: `${item.title} (${item.date})`,
              className: `travel-node travel-node--${item.type}`,
            })),
          ),
          {
            stack: false,
            showCurrentTime: false,
            selectable: true,
            zoomKey: "metaKey",
            orientation: { axis: "bottom", item: "top" },
            margin: { axis: 14, item: { horizontal: 10, vertical: 18 } },
            height: "154px",
            min: new Date(Date.UTC(2023, 0, 1)),
            max: new Date(Date.UTC(2026, 5, 1)),
          },
        )
      : null;

  const selectItem = (slug, shouldScroll = true) => {
    const item = allPoints.find((point) => point.slug === slug);
    if (!item) return;

    rows.forEach((row) => row.classList.toggle("is-active", row.getAttribute("data-map-item") === slug));
    if (map.getLayer("map-point-highlight")) {
      map.setFilter("map-point-highlight", ["==", ["get", "slug"], slug]);
    }

    map.flyTo({ center: [item.lon, item.lat], zoom: item.type === "race" ? 4.2 : 4.8, duration: 850 });
    popup.setLngLat([item.lon, item.lat]).setHTML(popupHtml(item)).addTo(map);
    if (timeline) {
      timeline.setSelection(slug);
      timeline.focus(slug, { animation: { duration: 650, easingFunction: "easeInOutQuad" } });
    }

    if (shouldScroll) {
      document.getElementById(slug)?.scrollIntoView({ block: "center", behavior: "smooth" });
    }
  };

  const setFilter = (kind) => {
    toolbarButtons.forEach((button) => {
      button.classList.toggle("is-active", button.getAttribute("data-map-filter") === kind);
    });
    const filter = kind === "all" ? null : ["==", ["get", "type"], kind];
    if (map.getLayer("map-points")) map.setFilter("map-points", filter);
    if (map.getLayer("map-point-labels")) map.setFilter("map-point-labels", filter);
  };

  const loadDriveRoutes = () => {
    const features = driveRoutes
      .filter((route) => Array.isArray(route.coordinates) && route.coordinates.length > 1)
      .map((route) => ({
        type: "Feature",
        geometry: { type: "LineString", coordinates: route.coordinates },
        properties: { slug: route.slug, title: route.title || route.slug || "Drive" },
      }));

    if (!features.length) return;

    map.addSource("drive-routes", { type: "geojson", data: { type: "FeatureCollection", features } });
    map.addLayer(
      {
        id: "drive-routes",
        type: "line",
        source: "drive-routes",
        layout: { visibility: "none", "line-cap": "round", "line-join": "round" },
        paint: {
          "line-color": "#f4d35e",
          "line-width": ["interpolate", ["linear"], ["zoom"], 2, 1.8, 7, 5.5],
          "line-opacity": 0.68,
          "line-blur": 0.5,
        },
      },
      "map-points"
    );

    driveButton.hidden = false;
    driveButton.addEventListener("click", () => {
      const visible = map.getLayoutProperty("drive-routes", "visibility") !== "none";
      map.setLayoutProperty("drive-routes", "visibility", visible ? "none" : "visible");
      driveButton.classList.toggle("is-active", !visible);
    });
  };

  const loadHeatmap = async () => {
    const response = await fetch("/data/strava-heatmap.geojson", { cache: "no-store" }).catch(() => null);
    if (!response?.ok) return;
    const heatmap = await response.json();
    if (!heatmap.features?.length) return;

    map.addSource("strava-heatmap", { type: "geojson", data: heatmap });
    map.addLayer(
      {
        id: "strava-heatmap",
        type: "heatmap",
        source: "strava-heatmap",
        maxzoom: 11,
        paint: {
          "heatmap-weight": ["interpolate", ["linear"], ["get", "weight"], 0, 0, 6, 1],
          "heatmap-intensity": ["interpolate", ["linear"], ["zoom"], 1, 0.6, 9, 2.6],
          "heatmap-radius": ["interpolate", ["linear"], ["zoom"], 1, 3, 9, 22],
          "heatmap-opacity": 0.72,
          "heatmap-color": [
            "interpolate",
            ["linear"],
            ["heatmap-density"],
            0,
            "rgba(159,183,125,0)",
            0.35,
            "rgba(159,183,125,0.45)",
            0.7,
            "rgba(181,130,70,0.75)",
            1,
            "rgba(241,234,223,0.92)",
          ],
        },
      },
      "map-points"
    );

    heatmapButton.hidden = false;
    heatmapButton.classList.add("is-active");
    heatmapButton.addEventListener("click", () => {
      const visible = map.getLayoutProperty("strava-heatmap", "visibility") !== "none";
      map.setLayoutProperty("strava-heatmap", "visibility", visible ? "none" : "visible");
      heatmapButton.classList.toggle("is-active", !visible);
    });
  };

  map.on("style.load", () => {
    map.setFog({
      color: "rgb(14, 13, 10)",
      "high-color": "rgb(36, 47, 43)",
      "horizon-blend": 0.18,
      "space-color": "rgb(7, 8, 9)",
      "star-intensity": 0.18,
    });
    map.addSource("map-points", { type: "geojson", data: featureCollection });
    map.addLayer({
      id: "map-points",
      type: "circle",
      source: "map-points",
      paint: {
        "circle-radius": ["case", ["==", ["get", "type"], "race"], 5.5, 4.8],
        "circle-color": ["case", ["==", ["get", "type"], "race"], "#b58246", "#9fb77d"],
        "circle-stroke-color": "#0e0d0a",
        "circle-stroke-width": 1.7,
        "circle-opacity": 0.92,
      },
    });
    map.addLayer({
      id: "map-point-highlight",
      type: "circle",
      source: "map-points",
      filter: ["==", ["get", "slug"], ""],
      paint: {
        "circle-radius": 10,
        "circle-color": "rgba(241,234,223,0.1)",
        "circle-stroke-color": "#f1eadf",
        "circle-stroke-width": 2,
      },
    });
    map.addLayer({
      id: "map-point-labels",
      type: "symbol",
      source: "map-points",
      minzoom: 3,
      layout: {
        "text-field": ["get", "title"],
        "text-size": 12,
        "text-offset": [0, 1.25],
        "text-anchor": "top",
        "text-allow-overlap": false,
      },
      paint: {
        "text-color": "#f1eadf",
        "text-halo-color": "#0e0d0a",
        "text-halo-width": 1.4,
      },
    });

    loadDriveRoutes();
    loadHeatmap();
  });

  map.on("click", "map-points", (event) => {
    const feature = event.features?.[0];
    const slug = feature?.properties?.slug;
    if (slug) selectItem(slug);
  });

  map.on("mouseenter", "map-points", () => {
    map.getCanvas().style.cursor = "pointer";
  });

  map.on("mouseleave", "map-points", () => {
    map.getCanvas().style.cursor = "";
  });

  toolbarButtons.forEach((button) => {
    button.addEventListener("click", () => setFilter(button.getAttribute("data-map-filter") || "all"));
  });

  rows.forEach((row) => {
    row.addEventListener("click", () => selectItem(row.getAttribute("data-map-item"), false));
  });

  if (timeline) {
    timeline.on("select", (event) => {
      const slug = event.items?.[0];
      if (slug) selectItem(slug);
    });
  }

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    rows.forEach((row) => {
      const slug = row.getAttribute("data-map-item");
      if (!slug) return;
      ScrollTrigger.create({
        trigger: row,
        start: "top 72%",
        end: "bottom 34%",
        onEnter: () => selectItem(slug, false),
        onEnterBack: () => selectItem(slug, false),
      });
    });
  }
</script>
