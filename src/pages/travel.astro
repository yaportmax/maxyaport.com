    const previewingSlug = previewSlug && editorDirty ? previewSlug : "";
    const generatedFeatures = generatedTripRoutes.features.filter(
      (feature) => feature.properties?.slug !== previewingSlug,
    );
    const generatedKeys = new Set(generatedFeatures.map(routeFeatureKey));
    const fallbackFeatures = fallbackRoutes.features.filter(
      (feature) => feature.properties?.slug === previewingSlug || !generatedKeys.has(routeFeatureKey(feature)),
