---
import BaseLayout from "../layouts/BaseLayout.astro";
import mapData from "../data/travel-map.json";

const monthLookup: Record<string, number> = {
  jan: 0,
  feb: 1,
  mar: 2,
  apr: 3,
  may: 4,
  jun: 5,
  jul: 6,
  aug: 7,
  sep: 8,
  oct: 9,
  nov: 10,
  dec: 11,
};
const sortDate = (date: string) => {
  const normalized = String(date || "").trim();
  const isoMatch = normalized.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (isoMatch) {
    const [, year, month, day] = isoMatch;
    return Date.UTC(Number(year), Number(month) - 1, Number(day));
  }

  const exactMatch = normalized.match(/^([A-Za-z]+)\s+(\d{1,2}),?\s+(\d{4})$/);
  if (exactMatch) {
    const [, month, day, year] = exactMatch;
    const monthIndex = monthLookup[month.slice(0, 3).toLowerCase()] ?? 0;
    return Date.UTC(Number(year), monthIndex, Number(day));
  }

  const monthMatch = normalized.match(/^([A-Za-z]+)\s+(\d{4})$/);
  if (monthMatch) {
    const [, month, year] = monthMatch;
    const monthIndex = monthLookup[month.slice(0, 3).toLowerCase()] ?? 0;
    return Date.UTC(Number(year), monthIndex, 15);
  }

  const year = Number(normalized) || 0;
  return Date.UTC(year, 6, 1);
};
const mapItems = [...mapData.trips, ...mapData.races].sort((a, b) => sortDate(a.date) - sortDate(b.date));
const timelineStart = mapItems.length ? sortDate(mapItems[0].date) : Date.UTC(2020, 0, 1);
const timelineEnd = Math.max(
  mapItems.length ? sortDate(mapItems[mapItems.length - 1].date) : Date.UTC(2026, 0, 1),
  Date.now(),
);
const timelineSpan = Math.max(1, timelineEnd - timelineStart);
const timelinePosition = (date: string) => Math.min(98.75, Math.max(1.25, ((sortDate(date) - timelineStart) / timelineSpan) * 100));
const startYear = new Date(timelineStart).getUTCFullYear();
const endYear = new Date(timelineEnd).getUTCFullYear();
const timelineYears = Array.from({ length: endYear - startYear + 1 }, (_, index) => startYear + index);
const timelineFocusStart = Date.UTC(2020, 0, 1);
const timelineFocusSpan = Math.max(1, timelineEnd - timelineFocusStart);
const timelineWidth = Math.max(100, Math.min(720, (timelineSpan / timelineFocusSpan) * 180));
const timelineScrollStart = ((timelineFocusStart - timelineStart) / timelineSpan) * timelineWidth;
const firstFocusedTimelineIndex = mapItems.findIndex((item) => sortDate(item.date) >= timelineFocusStart);
const initialTimelineIndex =
  firstFocusedTimelineIndex >= 0 ? firstFocusedTimelineIndex : Math.max(0, mapItems.length - 1);
const timelineUnit = 100;
const initialTimelineValue = initialTimelineIndex * timelineUnit;
const serializedMapData = JSON.stringify(mapData).replace(/</g, "\\u003c");
---

<BaseLayout title="Travel" bodyClass="travel-app">
  <section class="map-page" aria-label="Travel and race map">
    <section class="map-stage">
      <div class="map-stage__content">
        <div class="map-legend" aria-label="Map key">
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="flight" aria-pressed="true">
            <i class="map-key-line map-key-line--flight"></i>Plane
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="drive" aria-pressed="true">
            <i class="map-key-line map-key-line--drive"></i>Car
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="sail" aria-pressed="true">
            <i class="map-key-line map-key-line--sail"></i>Boat
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="train" aria-pressed="true">
            <i class="map-key-line map-key-line--train"></i>Train
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="strava" aria-pressed="true">
            <i class="map-key-line map-key-line--strava"></i>Strava
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="race" aria-pressed="true">
            <i class="map-key-dot map-key-dot--race"></i>Races
          </button>
          <button type="button" class="map-legend__toggle" data-map-layer-toggle="stop" aria-pressed="true">
            <i class="map-key-dot map-key-dot--stop"></i>Stops
          </button>
        </div>
        <section class="map-frame" aria-label="Travel and race map">
          <div id="travel-map" class="travel-map"></div>
        </section>

        <section class="map-timeline" aria-label="Travel timeline">
          <div class="map-playback">
            <button type="button" class="map-playback__button" data-timeline-play aria-pressed="false">
              <span class="map-playback__icon" aria-hidden="true"></span>
              <span data-timeline-play-label>Play</span>
            </button>
            <button type="button" class="map-playback__button map-playback__button--camera" data-timeline-camera aria-pressed="false">
              <span class="map-playback__camera-icon" aria-hidden="true"></span>
              <span data-timeline-camera-label>Camera</span>
            </button>
          </div>
          <div
            class="travel-timeline-rail"
            aria-label="Trip and race years"
            data-travel-timeline-rail
            data-initial-scrub-value={initialTimelineValue}
            data-timeline-start={timelineStart}
            data-timeline-end={timelineEnd}
            data-timeline-focus-start={timelineFocusStart}
            style={`--timeline-width: ${timelineWidth}%; --timeline-scroll-start: ${timelineScrollStart}%;`}
          >
            <div class="travel-timeline-rail__axis">
              {
                timelineYears.map((year) => (
                  <span class="travel-timeline-rail__year" style={`--x: ${timelinePosition(`Jan ${year}`)}%`}>
                    {year}
                  </span>
                ))
              }
              {
                mapItems.map((item) => (
                  <button
                    type="button"
                    class={`travel-timeline-rail__dot travel-timeline-rail__dot--${item.type}`}
                    style={`--x: ${timelinePosition(item.date)}%`}
                    data-map-timeline-item={item.slug}
                    data-map-timeline-time={sortDate(item.date)}
                    aria-label={`${item.title}, ${item.date}`}
                  />
                ))
              }
            </div>
          </div>
          <output class="sr-only" data-travel-scrubber-title aria-live="polite"></output>
        </section>
      </div>

      <section id="route-editor" class="route-editor" aria-label="Route editor" hidden>
        <header class="route-editor__header">
          <div>
            <p class="route-editor__kicker">route editor</p>
            <h2>Trip routes</h2>
          </div>
          <div class="route-editor__actions">
            <button type="button" id="route-editor-close">Close</button>
            <button type="button" id="route-editor-reset">Reset</button>
            <button type="button" id="route-editor-recalculate">Recalculate route</button>
            <button type="button" id="route-editor-save">Save routes</button>
          </div>
        </header>
        <div class="route-editor__status" id="route-editor-status" aria-live="polite"></div>
        <div class="route-editor__grid">
          <div class="route-editor__panel">
            <label class="route-editor__field">
              <span>Trip</span>
              <select id="route-editor-trip"></select>
            </label>
            <form class="route-editor__search" id="route-editor-search">
              <label class="route-editor__field">
                <span>Destination search</span>
                <input id="route-editor-query" type="search" placeholder="Search destination" autocomplete="off" />
              </label>
              <label class="route-editor__field">
                <span>Insert</span>
                <select id="route-editor-insert"></select>
              </label>
              <button type="submit">Find</button>
            </form>
            <div class="route-editor__results" id="route-editor-results"></div>
          </div>
          <div class="route-editor__panel">
            <div class="route-editor__stops-header">
              <span>Stops</span>
              <button type="button" id="route-editor-fit">Fit route</button>
            </div>
            <div class="route-editor__stops" id="route-editor-stops"></div>
          </div>
        </div>
      </section>

    </section>
  </section>

  <script type="application/json" id="travel-map-data" set:html={serializedMapData} />
</BaseLayout>

<script>
  import mapboxgl from "mapbox-gl";
  import "mapbox-gl/dist/mapbox-gl.css";

  const dataElement = document.getElementById("travel-map-data");
  const mapElement = document.getElementById("travel-map");
  const timelineRail = document.querySelector("[data-travel-timeline-rail]");
  const timelineDots = Array.from(document.querySelectorAll("[data-map-timeline-item]"));
  const scrubberTitleElement = document.querySelector("[data-travel-scrubber-title]");
  const timelinePlayButton = document.querySelector("[data-timeline-play]");
  const timelinePlayLabel = document.querySelector("[data-timeline-play-label]");
  const timelineCameraButton = document.querySelector("[data-timeline-camera]");
  const timelineCameraLabel = document.querySelector("[data-timeline-camera-label]");
  const routeEditorToggle = document.querySelector("[data-route-editor-toggle]");
  const routeEditor = document.getElementById("route-editor");
  const routeEditorTrip = document.getElementById("route-editor-trip");
  const routeEditorStops = document.getElementById("route-editor-stops");
  const routeEditorInsert = document.getElementById("route-editor-insert");
  const routeEditorSearch = document.getElementById("route-editor-search");
  const routeEditorQuery = document.getElementById("route-editor-query");
  const routeEditorResults = document.getElementById("route-editor-results");
  const routeEditorStatus = document.getElementById("route-editor-status");
  const routeEditorSave = document.getElementById("route-editor-save");
  const routeEditorReset = document.getElementById("route-editor-reset");
  const routeEditorClose = document.getElementById("route-editor-close");
  const routeEditorRecalculate = document.getElementById("route-editor-recalculate");
  const routeEditorFit = document.getElementById("route-editor-fit");
  const layerToggleButtons = Array.from(document.querySelectorAll("[data-map-layer-toggle]"));
  const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || "";

  if (!mapElement) {
    if (mapElement) mapElement.setAttribute("data-map-empty", "true");
    throw new Error("Travel map needs a map container.");
  }

  if (!mapboxToken) {
    mapElement.setAttribute("data-map-empty", "true");
    throw new Error("Travel map needs PUBLIC_MAPBOX_TOKEN.");
  }

  mapboxgl.accessToken = mapboxToken;

  const cloneData = (value) => JSON.parse(JSON.stringify(value));
  const mapData = JSON.parse(dataElement?.textContent || "{\"trips\":[],\"races\":[]}");
  let editorData = cloneData(mapData);
  const allPoints = [...mapData.trips, ...mapData.races];
  const allPointsBySlug = new Map(allPoints.map((point) => [point.slug, point]));
  const timelineSequence = timelineDots
    .map((dot) => {
      const item = allPointsBySlug.get(dot.getAttribute("data-map-timeline-item"));
      if (item) item.timelineTime = Number(dot.getAttribute("data-map-timeline-time")) || 0;
      return item;
    })
    .filter(Boolean);
  let activeTimelineSlug = "";
  let activeStravaActivityId = "";
  let stopLookupTimeout = 0;
  let stopLookupRequestId = 0;
  let editorDirty = false;
  let editorSaving = false;
  let generatedTripRoutes = null;
  let raceRouteFeaturesBySlug = new Map();
  let stravaRouteFeatureList = [];
  let tripPlaybackSegmentsCache = new Map();
  const layerVisibility = {
    flight: true,
    drive: true,
    sail: true,
    train: true,
    strava: true,
    race: true,
    stop: true,
  };
  let playbackStravaActivityId = "";
  let playbackRaceSlug = "";

  const isFiniteCoordinate = (node) =>
    Number.isFinite(Number(node?.lat)) && Number.isFinite(Number(node?.lon));

  const showNodeOnMap = (node, defaultValue = true) => {
    if (node?.showOnMap === false) return false;
    if (node?.showOnMap === true) return true;
    return defaultValue;
  };

  const routeNodeFrom = (node, index) => {
    const routeNode = {
      title: node.title || `Stop ${index + 1}`,
      lat: Number(node.lat),
      lon: Number(node.lon),
    };
    if (node.showOnMap === false || node.showOnMap === true) routeNode.showOnMap = node.showOnMap;
    return routeNode;
  };

  const sameRouteCoordinate = (first, second) =>
    isFiniteCoordinate(first) &&
    isFiniteCoordinate(second) &&
    Math.abs(Number(first.lat) - Number(second.lat)) < 0.00001 &&
    Math.abs(Number(first.lon) - Number(second.lon)) < 0.00001;

  const sameLngLat = (first, second) =>
    Array.isArray(first) &&
    Array.isArray(second) &&
    Math.abs(Number(first[0]) - Number(second[0])) < 0.00001 &&
    Math.abs(Number(first[1]) - Number(second[1])) < 0.00001;

  const returnNodeForStart = (start, existing = {}) => ({
    title: `Return to ${start.title || "start"}`,
    lat: Number(start.lat),
    lon: Number(start.lon),
    showOnMap: showNodeOnMap(existing, false),
  });

  const routeNodesReturningToStart = (nodes) => {
    if (nodes.length < 2) return nodes;
    const start = nodes[0];
    const finalNode = nodes[nodes.length - 1];
    if (sameRouteCoordinate(start, finalNode)) {
      return [...nodes.slice(0, -1), returnNodeForStart(start, finalNode)];
    }
    return [...nodes, returnNodeForStart(start)];
  };

  const isReturnNode = (trip, index) =>
    Array.isArray(trip?.routeNodes) &&
    trip.routeNodes.length > 2 &&
    index === trip.routeNodes.length - 1 &&
    sameRouteCoordinate(trip.routeNodes[0], trip.routeNodes[index]);

  const hasRoutedTrip = (item) =>
    item.type === "trip" && Array.isArray(item.routeNodes) && item.routeNodes.filter(isFiniteCoordinate).length >= 2;

  const pointProperties = (item) => ({
    type: item.type,
    slug: item.slug,
    title: item.title,
    detail: item.detail,
    date: item.date,
    result: item.result || "",
    rank: item.rank || "",
    href: item.href || "",
    travelMode: item.travelMode || "",
  });

  const visibleMapPoints = allPoints.filter((item) => !hasRoutedTrip(item));

  const featureCollection = {
    type: "FeatureCollection",
    features: visibleMapPoints.map((item) => ({
      type: "Feature",
      geometry: { type: "Point", coordinates: [item.lon, item.lat] },
      properties: pointProperties(item),
    })),
  };

  const normalizedTripNodes = (trip) => {
    const nodes = Array.isArray(trip.routeNodes) ? trip.routeNodes.filter(isFiniteCoordinate) : [];
    if (nodes.length) {
      return routeNodesReturningToStart(
        nodes.map((node, index) => ({
          ...routeNodeFrom(node, index),
          title: node.title || (index === nodes.length - 1 ? trip.title : `Node ${index + 1}`),
        })),
      );
    }
    if (isFiniteCoordinate(trip)) {
      return [{ title: trip.title, lat: Number(trip.lat), lon: Number(trip.lon) }];
    }
    return [];
  };

  const tripNodeMap = (sourceData) =>
    new Map((sourceData.trips || []).map((trip) => [trip.slug, normalizedTripNodes(trip)]));
  let tripNodesBySlug = tripNodeMap(mapData);

  const sanitizedCoordinates = (coordinates) => {
    if (!Array.isArray(coordinates)) return [];
    return coordinates
      .filter((coord) => Array.isArray(coord) && Number.isFinite(Number(coord[0])) && Number.isFinite(Number(coord[1])))
      .map((coord) => [Number(coord[0]), Number(coord[1])]);
  };

  const toRadians = (degrees) => (degrees * Math.PI) / 180;
  const toDegrees = (radians) => (radians * 180) / Math.PI;

  const greatCircleCoordinates = (start, end, steps = 72) => {
    const lng1 = toRadians(start[0]);
    const lat1 = toRadians(start[1]);
    const lng2 = toRadians(end[0]);
    const lat2 = toRadians(end[1]);
    const delta =
      2 *
      Math.asin(
        Math.sqrt(
          Math.sin((lat2 - lat1) / 2) ** 2 +
            Math.cos(lat1) * Math.cos(lat2) * Math.sin((lng2 - lng1) / 2) ** 2,
        ),
      );

    if (!Number.isFinite(delta) || delta === 0) return [start, end];

    const coordinates = [];
    for (let index = 0; index <= steps; index += 1) {
      const fraction = index / steps;
      const a = Math.sin((1 - fraction) * delta) / Math.sin(delta);
      const b = Math.sin(fraction * delta) / Math.sin(delta);
      const x = a * Math.cos(lat1) * Math.cos(lng1) + b * Math.cos(lat2) * Math.cos(lng2);
      const y = a * Math.cos(lat1) * Math.sin(lng1) + b * Math.cos(lat2) * Math.sin(lng2);
      const z = a * Math.sin(lat1) + b * Math.sin(lat2);
      let lon = toDegrees(Math.atan2(y, x));
      const lat = toDegrees(Math.atan2(z, Math.sqrt(x * x + y * y)));

      const previous = coordinates[coordinates.length - 1]?.[0];
      if (Number.isFinite(previous)) {
        while (lon - previous > 180) lon -= 360;
        while (lon - previous < -180) lon += 360;
      }

      coordinates.push([Number(lon.toFixed(5)), Number(lat.toFixed(5))]);
    }
    return coordinates;
  };

  const segmentConfigForTrip = (trip, index) =>
    Array.isArray(trip.routeSegments) && trip.routeSegments[index] ? trip.routeSegments[index] : {};

  const segmentModeForTrip = (trip, index) => {
    const configuredMode = segmentConfigForTrip(trip, index).mode || trip.travelMode || "drive";
    if (configuredMode === "flight" || configuredMode === "sail" || configuredMode === "train") return configuredMode;
    return "drive";
  };

  const segmentCoordinates = (trip, nodes, index) => {
    const config = segmentConfigForTrip(trip, index);
    const configuredCoordinates = sanitizedCoordinates(config.coordinates);
    if (configuredCoordinates.length > 1) return configuredCoordinates;

    const start = [nodes[index].lon, nodes[index].lat];
    const end = [nodes[index + 1].lon, nodes[index + 1].lat];
    return ["flight", "sail", "train"].includes(segmentModeForTrip(trip, index))
      ? greatCircleCoordinates(start, end)
      : [start, end];
  };

  const createTripRouteCollections = (sourceData = mapData) => {
    const routeFeatures = [];
    const nodeFeatures = [];

    for (const trip of sourceData.trips || []) {
      const nodes = normalizedTripNodes(trip);
      const baseMode = trip.travelMode === "flight" ? "flight" : "drive";

      nodes.forEach((node, index) => {
        if (!showNodeOnMap(node)) return;
        nodeFeatures.push({
          type: "Feature",
          geometry: { type: "Point", coordinates: [node.lon, node.lat] },
          properties: {
            slug: trip.slug,
            title: trip.title,
            nodeTitle: node.title,
            nodeIndex: index,
            mode: index > 0 ? segmentModeForTrip(trip, index - 1) : baseMode,
            showOnMap: true,
          },
        });
      });

      for (let index = 0; index < nodes.length - 1; index += 1) {
        const mode = segmentModeForTrip(trip, index);
        const coordinates = segmentCoordinates(trip, nodes, index);
        if (coordinates.length < 2) continue;

        routeFeatures.push({
          type: "Feature",
          geometry: { type: "LineString", coordinates },
          properties: {
            slug: trip.slug,
            title: trip.title,
            mode,
            segmentIndex: index,
          },
        });
      }
    }

    return {
      routes: { type: "FeatureCollection", features: routeFeatures },
      nodes: { type: "FeatureCollection", features: nodeFeatures },
    };
  };

  let tripRouteCollections = createTripRouteCollections(editorData);
  const satelliteGlobeStyle = {
    version: 8,
    sources: {
      "esri-satellite": {
        type: "raster",
        tiles: ["https://services.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}"],
        tileSize: 256,
        maxzoom: 19,
        attribution: "Satellite imagery © Esri",
      },
      "mapbox-terrain-dem": {
        type: "raster-dem",
        url: "mapbox://mapbox.mapbox-terrain-dem-v1",
        tileSize: 512,
        maxzoom: 14,
      },
    },
    layers: [
      {
        id: "satellite",
        type: "raster",
        source: "esri-satellite",
        paint: {
          "raster-saturation": -0.08,
          "raster-contrast": 0.05,
          "raster-brightness-min": 0.03,
          "raster-brightness-max": 0.84,
        },
      },
    ],
  };

  const map = new mapboxgl.Map({
    container: mapElement,
    style: satelliteGlobeStyle,
    center: [-54, 28],
    zoom: mapElement.clientWidth < 680 ? 0.18 : 0.92,
    pitch: 0,
    projection: "globe",
    attributionControl: false,
    scrollZoom: true,
    antialias: true,
    minZoom: 0,
    maxZoom: 18,
  });

  map.scrollZoom.enable();

  map.addControl(new mapboxgl.NavigationControl({ visualizePitch: true }), "top-right");

  const popupOffset = {
    top: [0, 18],
    bottom: [0, -18],
    left: [18, 0],
    right: [-18, 0],
    "top-left": [14, 14],
    "top-right": [-14, 14],
    "bottom-left": [14, -14],
    "bottom-right": [-14, -14],
  };

  const createPopup = (anchor = undefined) =>
    new mapboxgl.Popup({
      anchor,
      closeButton: false,
      closeOnClick: false,
      offset: popupOffset,
      className: "map-popup",
    });

  let popup = createPopup();
  let popupTimer = 0;
  let popupSequence = 0;
  let activePopupChoices = [];
  let activePopupChoiceIndex = 0;
  let activePopupCoordinate = null;
  let handledInteractiveClick = false;
  let scrubPlaybackPopupSlug = "";

  const escapeHtml = (value) =>
    String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");

  const updateActiveSummary = (item) => {
    if (!item) return;
    if (scrubberTitleElement) scrubberTitleElement.textContent = `${item.title || "Timeline item"}, ${item.date || ""}`;
  };

  const popupHtml = (item) => {
    const meta =
      item.type === "race"
        ? [item.result, item.rank].filter(Boolean).map(escapeHtml).join("<br>")
        : escapeHtml(item.detail);
    const title = item.href
      ? `<a href="${escapeHtml(item.href)}">${escapeHtml(item.title)}</a>`
      : escapeHtml(item.title);
    return `<strong>${title}</strong><span>${escapeHtml(item.date)}</span><small>${meta}</small>`;
  };

  const stravaActivityUrl = (id) => {
    const activityId = String(id || "").trim();
    return activityId ? `https://www.strava.com/activities/${encodeURIComponent(activityId)}` : "";
  };

  const linkedTitleHtml = (title, href) =>
    href
      ? `<a href="${escapeHtml(href)}" target="_blank" rel="noreferrer">${escapeHtml(title)}</a>`
      : escapeHtml(title);

  const choiceLabel = (choice) => {
    if (choice.kind === "strava") return choice.properties.activityGroup || choice.properties.type || "Strava";
    return choice.item?.type === "race" ? "Race" : "Trip";
  };

  const choiceTitle = (choice) =>
    choice.kind === "strava" ? choice.properties.name || "Strava route" : choice.item?.title || "Route";

  const choiceDetails = (choice) => {
    if (choice.kind === "strava") {
      const miles = Number(choice.properties.distanceMeters || 0) / 1609.344;
      const distance = miles > 0 ? `${miles.toFixed(1)} mi` : "";
      return [choice.properties.activityGroup, distance, String(choice.properties.startDate || "").slice(0, 10)]
        .filter(Boolean)
        .join(" / ");
    }
    if (choice.item?.type === "race") return [choice.item.date, choice.item.result].filter(Boolean).join(" / ");
    return [choice.item?.date, choice.item?.detail].filter(Boolean).join(" / ");
  };

  const popupChoicePanelHtml = (choice) => {
    const title = choiceTitle(choice);
    const href = choice.kind === "strava" ? stravaActivityUrl(choice.properties.id) : choice.item?.href;
    const detail = choiceDetails(choice);
    const helper =
      choice.kind === "strava"
        ? "Open activity on Strava"
        : choice.item?.type === "race"
          ? "Selected race route"
          : "Selected trip route";
    return `
      <div class="map-popup-stack__panel">
        <span>${escapeHtml(choiceLabel(choice))}</span>
        <strong>${linkedTitleHtml(title, href)}</strong>
        <small>${escapeHtml(detail)}</small>
        ${href ? `<a class="map-popup-stack__link" href="${escapeHtml(href)}" target="_blank" rel="noreferrer">${escapeHtml(helper)}</a>` : ""}
      </div>
    `;
  };

  const stackedPopupHtml = (choices, activeIndex = 0) => `
    <div class="map-popup-stack" data-map-popup-stack>
      <div class="map-popup-stack__header">
        <span>${choices.length} options here</span>
        <div class="map-popup-stack__controls" aria-label="Overlapping route controls">
          <button type="button" data-popup-stack-step="-1" aria-label="Previous route">‹</button>
          <button type="button" data-popup-stack-step="1" aria-label="Next route">›</button>
        </div>
      </div>
      <div class="map-popup-stack__rail" data-popup-stack-rail aria-label="Overlapping route options">
        ${choices
          .map(
            (choice, index) => `
              <button
                type="button"
                class="map-popup-stack__choice${index === activeIndex ? " is-active" : ""}"
                data-popup-choice-index="${index}"
              >
                <span>${escapeHtml(choiceLabel(choice))}</span>
                <strong>${escapeHtml(choiceTitle(choice))}</strong>
              </button>
            `,
          )
          .join("")}
      </div>
      <div data-popup-stack-panel>${popupChoicePanelHtml(choices[activeIndex])}</div>
    </div>
  `;

  const setRouteHighlight = (slug) => {
    const visibleModes = ["flight", "drive", "sail", "train"].filter((mode) => layerVisibility[mode]);
    const filter =
      slug && visibleModes.length
        ? ["all", ["==", ["get", "slug"], slug], ["in", ["get", "mode"], ["literal", visibleModes]]]
        : ["==", ["get", "slug"], ""];
    for (const layerId of ["trip-route-highlight-casing", "trip-route-highlight", "trip-route-node-highlight"]) {
      if (map.getLayer(layerId)) map.setFilter(layerId, filter);
    }
  };

  const setRaceRouteHighlight = (slug) => {
    const filter =
      slug && raceRouteFeaturesBySlug.has(slug)
        ? ["==", ["get", "raceSlug"], slug]
        : ["==", ["get", "raceSlug"], ""];
    for (const layerId of ["race-route-highlight-casing", "race-route-highlight"]) {
      if (map.getLayer(layerId)) map.setFilter(layerId, filter);
    }
  };

  const setMapPointLabelFilter = (activeItem = null) => {
    if (!map.getLayer("map-point-labels")) return;
    const selectedRaceSlug = activeItem?.type === "race" ? activeItem.slug : "";
    map.setFilter("map-point-labels", [
      "any",
      ["!=", ["get", "type"], "race"],
      ["==", ["get", "slug"], selectedRaceSlug],
    ]);
  };

  const setStravaRouteHighlight = (activityId) => {
    const id = Number(activityId);
    const filter = Number.isFinite(id) && id > 0 ? ["==", ["get", "id"], id] : ["==", ["get", "id"], ""];
    for (const layerId of ["strava-route-highlight-casing", "strava-route-highlight"]) {
      if (map.getLayer(layerId)) map.setFilter(layerId, filter);
    }
  };

  const raceRouteCoordinates = (slug) =>
    (raceRouteFeaturesBySlug.get(slug) || []).flatMap((feature) =>
      sanitizedCoordinates(feature.geometry?.coordinates),
    );

  const raceRouteAnchorCoordinate = (slug) => {
    const coordinates = raceRouteCoordinates(slug);
    return coordinates.length ? coordinates[Math.floor(coordinates.length / 2)] : null;
  };

  const routePopupPlacement = (coordinate = null) => {
    const compact = mapElement.clientWidth < 680;
    const longitude = Array.isArray(coordinate) && Number.isFinite(Number(coordinate[0])) ? Number(coordinate[0]) : 0;
    const panelSide = longitude < -30 ? "left" : "right";
    const sidePadding = Math.round(Math.min(mapElement.clientWidth * (compact ? 0.62 : 0.3), compact ? 236 : 340));
    const baseX = compact ? 30 : 82;
    const top = compact ? 56 : 92;
    const bottom = compact ? 48 : 76;

    return {
      anchor: panelSide === "left" ? "right" : "left",
      padding:
        panelSide === "left"
          ? { top, bottom, left: Math.max(baseX, sidePadding), right: baseX }
          : { top, bottom, left: baseX, right: Math.max(baseX, sidePadding) },
    };
  };

  const clearScheduledPopup = () => {
    popupSequence += 1;
    if (popupTimer) window.clearTimeout(popupTimer);
    popupTimer = 0;
    scrubPlaybackPopupSlug = "";
  };

  const showPopup = (item, coordinate, anchor = undefined, waitForMove = false) => {
    clearScheduledPopup();
    popup.remove();
    const sequence = popupSequence;

    const renderPopup = () => {
      if (sequence !== popupSequence) return;
      popup.remove();
      popup = createPopup(anchor);
      popup.setLngLat(coordinate).setHTML(popupHtml(item)).addTo(map);
    };

    if (!waitForMove) {
      renderPopup();
      return;
    }

    let rendered = false;
    let timerId = 0;
    const renderOnce = () => {
      if (rendered) return;
      rendered = true;
      map.off("moveend", renderOnce);
      if (sequence !== popupSequence) return;
      if (popupTimer === timerId) {
        window.clearTimeout(popupTimer);
        popupTimer = 0;
      }
      renderPopup();
    };

    map.once("moveend", renderOnce);
    timerId = window.setTimeout(renderOnce, 980);
    popupTimer = timerId;
  };

  const showScrubPlaybackPopup = (state) => {
    if (!state?.item || !state.coordinate) return;
    const placement = routePopupPlacement(state.coordinate);
    const segment = state.segment || {};
    const popupKey =
      segment.kind === "strava"
        ? `strava:${segment.properties?.id || ""}`
        : segment.kind === "race"
          ? `race:${segment.item?.slug || ""}`
          : `item:${state.item.slug}`;
    const html =
      segment.kind === "strava"
        ? stravaPopupHtml(segment.properties || {})
        : popupHtml(segment.kind === "race" && segment.item ? segment.item : state.item);
    const shouldCreate = !popup?.isOpen?.() || scrubPlaybackPopupSlug !== popupKey;
    if (shouldCreate) {
      clearScheduledPopup();
      popup.remove();
      popup = createPopup(placement.anchor);
      popup.setLngLat(state.coordinate).setHTML(html).addTo(map);
      scrubPlaybackPopupSlug = popupKey;
      return;
    }
    popup.setLngLat(state.coordinate);
  };

  const fitTripRoute = (item, placement = null) => {
    const nodes = tripNodesBySlug.get(item.slug) || [];
    if (nodes.length < 2) return false;

    const bounds = new mapboxgl.LngLatBounds();
    nodes.forEach((node) => bounds.extend([node.lon, node.lat]));
    if (bounds.isEmpty()) return false;

    const isCompact = mapElement.clientWidth < 680;
    map.fitBounds(bounds, {
      padding: placement?.padding || (isCompact ? 58 : { top: 104, bottom: 74, left: 86, right: 86 }),
      maxZoom: item.travelMode === "flight" ? 4.7 : 7,
      pitch: item.travelMode === "flight" ? 0 : isCompact ? 30 : 38,
      duration: 850,
    });
    return true;
  };

  const fitRaceRoute = (item, placement = null) => {
    const coordinates = raceRouteCoordinates(item.slug);
    if (coordinates.length < 2) return false;

    const bounds = new mapboxgl.LngLatBounds();
    coordinates.forEach((coordinate) => bounds.extend(coordinate));
    if (bounds.isEmpty()) return false;

    map.fitBounds(bounds, {
      padding: placement?.padding || (mapElement.clientWidth < 680 ? 48 : { top: 92, bottom: 76, left: 82, right: 82 }),
      maxZoom: 11,
      pitch: mapElement.clientWidth < 680 ? 34 : 42,
      duration: 850,
    });
    return true;
  };

  const fitRoute = (slug) => {
    const item = [...editorData.trips, ...allPoints].find((point) => point.slug === slug);
    return item ? fitTripRoute(item) : false;
  };

  const routeAnchorCoordinate = (slug) => {
    const routeCoordinates = (tripRouteCollections.routes.features || [])
      .filter((feature) => feature.properties?.slug === slug)
      .flatMap((feature) => sanitizedCoordinates(feature.geometry?.coordinates));

    if (routeCoordinates.length) return routeCoordinates[Math.floor(routeCoordinates.length / 2)];

    const nodes = tripNodesBySlug.get(slug) || [];
    const node = nodes[Math.floor(nodes.length / 2)];
    return node ? [node.lon, node.lat] : null;
  };

  const popupCoordinateForItem = (item, preferredCoordinate = null) => {
    if (Array.isArray(preferredCoordinate) && preferredCoordinate.length >= 2) return preferredCoordinate;
    if (item.type === "trip" && hasRoutedTrip(item)) return routeAnchorCoordinate(item.slug) || [item.lon, item.lat];
    if (item.type === "race") return raceRouteAnchorCoordinate(item.slug) || [item.lon, item.lat];
    return [item.lon, item.lat];
  };

  const emptyProgressMarkerData = { type: "FeatureCollection", features: [] };
  const scrubberUnitsPerItem = 100;
  const scrubberRoutePortion = 0.82;
  const scrubberMaxValue = Math.max(1, timelineSequence.length * scrubberUnitsPerItem);
  let scrubberValue = Number(timelineRail?.getAttribute("data-initial-scrub-value")) || 0;
  let currentScrubState = null;
  let syncingTimelineScroll = false;
  const timelineStartTime = Number(timelineRail?.getAttribute("data-timeline-start")) || 0;
  const timelineEndTime = Number(timelineRail?.getAttribute("data-timeline-end")) || timelineStartTime + 1;
  const timelineFocusStartTime = Number(timelineRail?.getAttribute("data-timeline-focus-start")) || timelineStartTime;
  const timelineTimeSpan = Math.max(1, timelineEndTime - timelineStartTime);

  const routeCoordinatesForTrip = (slug) => {
    const features = (tripRouteCollections.routes.features || [])
      .filter((feature) => feature.properties?.slug === slug)
      .sort((first, second) => Number(first.properties?.segmentIndex ?? 0) - Number(second.properties?.segmentIndex ?? 0));

    const coordinates = [];
    features.forEach((feature) => {
      const segment = sanitizedCoordinates(feature.geometry?.coordinates);
      if (!segment.length) return;
      const nextSegment = coordinates.length && sameLngLat(coordinates[coordinates.length - 1], segment[0])
        ? segment.slice(1)
        : segment;
      coordinates.push(...nextSegment);
    });
    return coordinates;
  };

  const baseRouteCoordinatesForItem = (item) => {
    if (!item) return [];
    if (item.type === "trip") {
      const coordinates = routeCoordinatesForTrip(item.slug);
      if (coordinates.length) return coordinates;
    }
    if (item.type === "race") {
      const coordinates = raceRouteCoordinates(item.slug);
      if (coordinates.length) return coordinates;
    }
    return Number.isFinite(Number(item.lon)) && Number.isFinite(Number(item.lat)) ? [[item.lon, item.lat]] : [];
  };

  const routeCoordinatesForItem = (item) => flattenPlaybackSegments(playbackSegmentsForItem(item));

  const haversineDistance = (first, second) => {
    const radiusKm = 6371;
    const lat1 = toRadians(Number(first[1]));
    const lat2 = toRadians(Number(second[1]));
    const deltaLat = toRadians(Number(second[1]) - Number(first[1]));
    const deltaLon = toRadians(Number(second[0]) - Number(first[0]));
    const a =
      Math.sin(deltaLat / 2) ** 2 +
      Math.cos(lat1) * Math.cos(lat2) * Math.sin(deltaLon / 2) ** 2;
    return radiusKm * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  };

  const interpolateLngLat = (first, second, progress) => {
    const clampedProgress = Math.min(1, Math.max(0, Number(progress) || 0));
    const startLon = Number(first[0]);
    const startLat = Number(first[1]);
    let deltaLon = Number(second[0]) - startLon;
    while (deltaLon > 180) deltaLon -= 360;
    while (deltaLon < -180) deltaLon += 360;
    let lon = startLon + deltaLon * clampedProgress;
    while (lon > 180) lon -= 360;
    while (lon < -180) lon += 360;
    return [Number(lon.toFixed(5)), Number((startLat + (Number(second[1]) - startLat) * clampedProgress).toFixed(5))];
  };

  const pathDistance = (coordinates) => {
    let distance = 0;
    for (let index = 1; index < coordinates.length; index += 1) {
      distance += haversineDistance(coordinates[index - 1], coordinates[index]);
    }
    return distance;
  };

  const coordinateAtProgress = (coordinates, progress) => {
    if (!coordinates.length) return null;
    if (coordinates.length === 1) return coordinates[0];

    const totalDistance = pathDistance(coordinates);
    if (!Number.isFinite(totalDistance) || totalDistance <= 0) return coordinates[0];

    const targetDistance = totalDistance * Math.min(1, Math.max(0, Number(progress) || 0));
    let traversedDistance = 0;
    for (let index = 1; index < coordinates.length; index += 1) {
      const start = coordinates[index - 1];
      const end = coordinates[index];
      const segmentDistance = haversineDistance(start, end);
      if (!Number.isFinite(segmentDistance) || segmentDistance <= 0) continue;
      if (traversedDistance + segmentDistance >= targetDistance) {
        return interpolateLngLat(start, end, (targetDistance - traversedDistance) / segmentDistance);
      }
      traversedDistance += segmentDistance;
    }
    return coordinates[coordinates.length - 1];
  };

  const flattenPlaybackSegments = (segments) => {
    const coordinates = [];
    (segments || []).forEach((segment) => {
      const segmentCoordinates = sanitizedCoordinates(segment?.coordinates);
      if (!segmentCoordinates.length) return;
      const nextSegment = coordinates.length && sameLngLat(coordinates[coordinates.length - 1], segmentCoordinates[0])
        ? segmentCoordinates.slice(1)
        : segmentCoordinates;
      coordinates.push(...nextSegment);
    });
    return coordinates;
  };

  const coordinateAtProgressInSegments = (segments, progress) => {
    const usableSegments = (segments || [])
      .map((segment) => ({ ...segment, coordinates: sanitizedCoordinates(segment.coordinates) }))
      .filter((segment) => segment.coordinates.length);
    if (!usableSegments.length) return { coordinate: null, segment: null, segmentProgress: 0 };

    const distances = usableSegments.map((segment) => pathDistance(segment.coordinates));
    const totalDistance = distances.reduce((sum, distance) => sum + Math.max(0, distance), 0);
    if (!Number.isFinite(totalDistance) || totalDistance <= 0) {
      return { coordinate: usableSegments[0].coordinates[0], segment: usableSegments[0], segmentProgress: 0 };
    }

    const targetDistance = totalDistance * Math.min(1, Math.max(0, Number(progress) || 0));
    let traversedDistance = 0;
    for (let index = 0; index < usableSegments.length; index += 1) {
      const segmentDistance = Math.max(0, distances[index]);
      if (traversedDistance + segmentDistance >= targetDistance || index === usableSegments.length - 1) {
        const segmentProgress = segmentDistance > 0 ? (targetDistance - traversedDistance) / segmentDistance : 0;
        return {
          coordinate: coordinateAtProgress(usableSegments[index].coordinates, segmentProgress),
          segment: usableSegments[index],
          segmentProgress: Math.min(1, Math.max(0, segmentProgress)),
        };
      }
      traversedDistance += segmentDistance;
    }

    const lastSegment = usableSegments[usableSegments.length - 1];
    return {
      coordinate: lastSegment.coordinates[lastSegment.coordinates.length - 1],
      segment: lastSegment,
      segmentProgress: 1,
    };
  };

  const dateMonthLookup = {
    jan: 0,
    feb: 1,
    mar: 2,
    apr: 3,
    may: 4,
    jun: 5,
    jul: 6,
    aug: 7,
    sep: 8,
    oct: 9,
    nov: 10,
    dec: 11,
  };
  const dayMs = 24 * 60 * 60 * 1000;

  const dateRangeForItem = (item) => {
    const normalized = String(item?.date || "").trim();
    const isoMatch = normalized.match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (isoMatch) {
      const [, year, month, day] = isoMatch;
      const time = Date.UTC(Number(year), Number(month) - 1, Number(day));
      return { start: time - 3 * dayMs, end: time + 3 * dayMs };
    }

    const exactMatch = normalized.match(/^([A-Za-z]+)\s+(\d{1,2}),?\s+(\d{4})$/);
    if (exactMatch) {
      const [, month, day, year] = exactMatch;
      const time = Date.UTC(Number(year), dateMonthLookup[month.slice(0, 3).toLowerCase()] ?? 0, Number(day));
      return { start: time - 3 * dayMs, end: time + 3 * dayMs };
    }

    const monthMatch = normalized.match(/^([A-Za-z]+)\s+(\d{4})$/);
    if (monthMatch) {
      const [, month, year] = monthMatch;
      const monthIndex = dateMonthLookup[month.slice(0, 3).toLowerCase()] ?? 0;
      const start = Date.UTC(Number(year), monthIndex, 1);
      const end = Date.UTC(Number(year), monthIndex + 1, 1) - 1;
      return { start, end };
    }

    const year = Number(normalized);
    if (Number.isFinite(year) && year > 1900) {
      return { start: Date.UTC(year, 0, 1), end: Date.UTC(year, 11, 31, 23, 59, 59) };
    }

    return { start: 0, end: 0 };
  };

  const itemDateTime = (item) => {
    const range = dateRangeForItem(item);
    return range.start && range.end ? (range.start + range.end) / 2 : 0;
  };

  const activityStartTime = (feature) => Date.parse(feature?.properties?.startDate || "") || 0;

  const sampleCoordinates = (coordinates, maxSamples = 24) => {
    const sanitized = sanitizedCoordinates(coordinates);
    if (sanitized.length <= maxSamples) return sanitized;
    const step = Math.max(1, Math.floor(sanitized.length / (maxSamples - 1)));
    const sampled = sanitized.filter((_, index) => index % step === 0);
    const last = sanitized[sanitized.length - 1];
    if (!sameLngLat(sampled[sampled.length - 1], last)) sampled.push(last);
    return sampled;
  };

  const featureCoordinates = (feature) => sanitizedCoordinates(feature?.geometry?.coordinates);

  const featureSampleCoordinates = (feature, maxSamples = 12) => sampleCoordinates(featureCoordinates(feature), maxSamples);

  const nodeCoordinates = (nodes) =>
    (nodes || []).filter(isFiniteCoordinate).map((node) => [Number(node.lon), Number(node.lat)]);

  const minDistanceBetween = (firstCoordinates, secondCoordinates) => {
    if (!firstCoordinates.length || !secondCoordinates.length) return Number.POSITIVE_INFINITY;
    let bestDistance = Number.POSITIVE_INFINITY;
    firstCoordinates.forEach((first) => {
      secondCoordinates.forEach((second) => {
        bestDistance = Math.min(bestDistance, haversineDistance(first, second));
      });
    });
    return bestDistance;
  };

  const nearestRoutePlacement = (routeCoordinates, coordinates) => {
    const routeSamples = sampleCoordinates(routeCoordinates, 160);
    const targetSamples = sampleCoordinates(coordinates, 10);
    if (!routeSamples.length || !targetSamples.length) {
      return { distanceKm: Number.POSITIVE_INFINITY, progress: 0 };
    }

    let bestDistance = Number.POSITIVE_INFINITY;
    let bestProgress = 0;
    targetSamples.forEach((target) => {
      routeSamples.forEach((routeCoordinate, index) => {
        const distance = haversineDistance(routeCoordinate, target);
        if (distance < bestDistance) {
          bestDistance = distance;
          bestProgress = routeSamples.length > 1 ? index / (routeSamples.length - 1) : 0;
        }
      });
    });
    return { distanceKm: bestDistance, progress: bestProgress };
  };

  const isHomeLikeNode = (node) => {
    const title = String(node?.title || "").toLowerCase();
    return (
      title.startsWith("return to ") ||
      title.startsWith("back to ") ||
      /\b(san francisco|sfo|san francisco international|santa clara|san luis obispo|slo)\b/.test(title)
    );
  };

  const tripAnchorNodes = (trip) => {
    const nodes = tripNodesBySlug.get(trip.slug) || [];
    const interiorNodes = nodes.filter((node, index) => index > 0 && index < nodes.length - 1 && !isHomeLikeNode(node));
    if (interiorNodes.length) return interiorNodes;
    return nodes.filter((node, index) => index > 0 && index < nodes.length - 1);
  };

  const tripDateContains = (trip, time, padDays = 1) => {
    const range = dateRangeForItem(trip);
    return Boolean(time && range.start && range.end && time >= range.start - padDays * dayMs && time <= range.end + padDays * dayMs);
  };

  const associatedRacesForTrip = (trip, baseCoordinates, anchorCoordinates) =>
    allPoints
      .filter((item) => item.type === "race")
      .map((race) => {
        const raceTime = itemDateTime(race);
        if (!tripDateContains(trip, raceTime, 2)) return null;
        const raceCoordinate = Number.isFinite(Number(race.lon)) && Number.isFinite(Number(race.lat)) ? [[race.lon, race.lat]] : [];
        const anchorDistance = minDistanceBetween(raceCoordinate, anchorCoordinates);
        const placement = nearestRoutePlacement(baseCoordinates, raceCoordinate);
        const closeToDestination = anchorDistance <= 45 || (placement.distanceKm <= 24 && placement.progress > 0.06 && placement.progress < 0.94);
        if (!closeToDestination) return null;
        const coordinates = raceRouteCoordinates(race.slug);
        if (coordinates.length < 2) return null;
        return {
          kind: "race",
          item: race,
          coordinates,
          progress: placement.distanceKm <= anchorDistance ? placement.progress : 0.5,
          startTime: raceTime,
        };
      })
      .filter(Boolean);

  const associatedStravaForTrip = (trip, baseCoordinates, anchorCoordinates, excludedActivityIds) =>
    stravaRouteFeatureList
      .map((feature) => {
        const id = String(feature?.properties?.id || "");
        if (!id || excludedActivityIds.has(id)) return null;
        const startTime = activityStartTime(feature);
        if (!tripDateContains(trip, startTime, 0)) return null;

        const coordinates = featureCoordinates(feature);
        if (coordinates.length < 2) return null;
        const samples = featureSampleCoordinates(feature, 10);
        const anchorDistance = minDistanceBetween(samples, anchorCoordinates);
        const placement = nearestRoutePlacement(baseCoordinates, samples);
        const activityGroup = String(feature.properties?.activityGroup || feature.properties?.type || "").toLowerCase();
        const anchorThreshold = activityGroup.includes("ride") ? 85 : activityGroup.includes("swim") ? 24 : 52;
        const routeThreshold = activityGroup.includes("ride") ? 38 : 22;
        const closeToTrip =
          anchorDistance <= anchorThreshold ||
          (placement.distanceKm <= routeThreshold && placement.progress > 0.06 && placement.progress < 0.94);
        if (!closeToTrip) return null;

        return {
          kind: "strava",
          properties: feature.properties || {},
          coordinates,
          progress: placement.distanceKm <= anchorDistance ? placement.progress : 0.5,
          startTime,
        };
      })
      .filter(Boolean);

  const composeTripPlaybackSegments = (trip, baseCoordinates, associatedSegments) => {
    if (!baseCoordinates.length) return [];
    if (!associatedSegments.length) return [{ kind: "trip", item: trip, coordinates: baseCoordinates }];

    const sortedSegments = [...associatedSegments].sort(
      (first, second) => first.progress - second.progress || first.startTime - second.startTime,
    );
    const segments = [];
    let cursorIndex = 0;

    const pushSegment = (segment) => {
      const coordinates = sanitizedCoordinates(segment.coordinates);
      if (coordinates.length >= 2 || (coordinates.length === 1 && !segments.length)) {
        segments.push({ ...segment, coordinates });
      }
    };

    sortedSegments.forEach((associatedSegment) => {
      const insertIndex = Math.max(
        cursorIndex,
        Math.min(baseCoordinates.length - 1, Math.round(associatedSegment.progress * (baseCoordinates.length - 1))),
      );
      const tripLeg = baseCoordinates.slice(cursorIndex, insertIndex + 1);
      pushSegment({ kind: "trip", item: trip, coordinates: tripLeg });

      const routeCoordinate = baseCoordinates[insertIndex];
      const activityCoordinates = sanitizedCoordinates(associatedSegment.coordinates);
      if (routeCoordinate && activityCoordinates.length) {
        if (!sameLngLat(routeCoordinate, activityCoordinates[0])) {
          pushSegment({ kind: "connector", item: trip, coordinates: [routeCoordinate, activityCoordinates[0]] });
        }
        pushSegment({ ...associatedSegment, coordinates: activityCoordinates });
        const lastActivityCoordinate = activityCoordinates[activityCoordinates.length - 1];
        if (!sameLngLat(lastActivityCoordinate, routeCoordinate)) {
          pushSegment({ kind: "connector", item: trip, coordinates: [lastActivityCoordinate, routeCoordinate] });
        }
      }
      cursorIndex = insertIndex;
    });

    pushSegment({ kind: "trip", item: trip, coordinates: baseCoordinates.slice(cursorIndex) });
    return segments.length ? segments : [{ kind: "trip", item: trip, coordinates: baseCoordinates }];
  };

  const playbackSegmentsForItem = (item) => {
    if (!item) return [];
    if (item.type !== "trip") {
      const coordinates = baseRouteCoordinatesForItem(item);
      return coordinates.length ? [{ kind: item.type || "item", item, coordinates }] : [];
    }

    const cacheKey = `${item.slug}:${stravaRouteFeatureList.length}:${raceRouteFeaturesBySlug.size}:${tripRouteCollections.routes.features.length}`;
    const cached = tripPlaybackSegmentsCache.get(cacheKey);
    if (cached) return cached;

    const baseCoordinates = baseRouteCoordinatesForItem(item);
    if (baseCoordinates.length < 2) {
      const fallback = baseCoordinates.length ? [{ kind: "trip", item, coordinates: baseCoordinates }] : [];
      tripPlaybackSegmentsCache.set(cacheKey, fallback);
      return fallback;
    }

    const anchors = tripAnchorNodes(item);
    const anchorCoordinates = nodeCoordinates(anchors);
    if (!anchorCoordinates.length) {
      const fallback = [{ kind: "trip", item, coordinates: baseCoordinates }];
      tripPlaybackSegmentsCache.set(cacheKey, fallback);
      return fallback;
    }

    const raceSegments = associatedRacesForTrip(item, baseCoordinates, anchorCoordinates);
    const excludedRaceActivityIds = new Set(
      raceSegments.flatMap((segment) => (segment.item?.stravaActivityIds || []).map((id) => String(id))),
    );
    const stravaSegments = associatedStravaForTrip(item, baseCoordinates, anchorCoordinates, excludedRaceActivityIds);
    const segments = composeTripPlaybackSegments(item, baseCoordinates, [...raceSegments, ...stravaSegments]);
    tripPlaybackSegmentsCache.set(cacheKey, segments);
    return segments;
  };

  const scrubberStateFromValue = (value) => {
    if (!timelineSequence.length) return null;
    const clampedValue = Math.min(Math.max(Number(value) || 0, 0), timelineSequence.length * scrubberUnitsPerItem);
    const rawIndex = clampedValue / scrubberUnitsPerItem;
    const itemIndex = Math.min(Math.floor(rawIndex), timelineSequence.length - 1);
    const item = timelineSequence[itemIndex];
    const phase = itemIndex === timelineSequence.length - 1 ? Math.min(1, rawIndex - itemIndex) : rawIndex - itemIndex;
    const segments = playbackSegmentsForItem(item);
    const coordinates = flattenPlaybackSegments(segments);
    const nextItem = timelineSequence[itemIndex + 1];
    const routeProgress =
      itemIndex === timelineSequence.length - 1
        ? phase
        : Math.min(1, phase / scrubberRoutePortion);
    const routeSample = coordinateAtProgressInSegments(segments, routeProgress);
    const routeCoordinate = routeSample.coordinate || coordinateAtProgress(coordinates, routeProgress);

    if (nextItem && phase > scrubberRoutePortion) {
      const nextCoordinates = routeCoordinatesForItem(nextItem);
      const start = coordinates[coordinates.length - 1] || routeCoordinate;
      const end = nextCoordinates[0] || [nextItem.lon, nextItem.lat];
      return {
        item,
        coordinate: start && end ? interpolateLngLat(start, end, (phase - scrubberRoutePortion) / (1 - scrubberRoutePortion)) : routeCoordinate,
        routeProgress: 1,
        inGap: true,
        pathDistance: pathDistance(coordinates),
        segment: routeSample.segment || null,
        segmentProgress: routeSample.segmentProgress || 1,
        coordinates,
      };
    }

    return {
      item,
      coordinate: routeCoordinate,
      routeProgress,
      inGap: false,
      pathDistance: pathDistance(coordinates),
      segment: routeSample.segment || null,
      segmentProgress: routeSample.segmentProgress || routeProgress,
      coordinates,
    };
  };

  const progressMarkerData = (state) => {
    if (!state?.coordinate) return emptyProgressMarkerData;
    return {
      type: "FeatureCollection",
      features: [
        {
          type: "Feature",
          geometry: { type: "Point", coordinates: state.coordinate },
          properties: {
            slug: state.item.slug,
            type: state.segment?.kind === "race" ? "race" : state.segment?.kind === "strava" ? "strava" : state.item.type,
            progress: state.routeProgress,
          },
        },
      ],
    };
  };

  const updateRouteProgressMarker = (state) => {
    currentScrubState = state;
    const source = map.getSource("route-progress-marker");
    if (source && "setData" in source) source.setData(progressMarkerData(state));
  };

  const scrubberValueForSlug = (slug) => {
    const index = timelineSequence.findIndex((item) => item.slug === slug);
    return index >= 0 ? index * scrubberUnitsPerItem : 0;
  };

  const clampScrubberValue = (value) => Math.min(Math.max(Number(value) || 0, 0), scrubberMaxValue);

  const maxTimelineScroll = () => (timelineRail ? Math.max(1, timelineRail.scrollWidth - timelineRail.clientWidth) : 1);

  const timelineAxisWidth = () =>
    timelineRail?.querySelector(".travel-timeline-rail__axis")?.scrollWidth || timelineRail?.scrollWidth || 1;

  const scrubberValueFromTimelineTime = (time) => {
    if (!timelineSequence.length) return 0;
    const targetTime = Number(time) || timelineStartTime;
    const firstTime = timelineSequence[0].timelineTime || timelineStartTime;
    const lastIndex = timelineSequence.length - 1;
    const lastTime = timelineSequence[lastIndex].timelineTime || timelineEndTime;

    if (targetTime <= firstTime) return 0;
    if (targetTime >= lastTime) return lastIndex * scrubberUnitsPerItem + scrubberUnitsPerItem;

    for (let index = 0; index < lastIndex; index += 1) {
      const itemTime = timelineSequence[index].timelineTime || firstTime;
      const nextTime = timelineSequence[index + 1].timelineTime || itemTime + 1;
      if (targetTime <= nextTime) {
        const dateProgress = (targetTime - itemTime) / Math.max(1, nextTime - itemTime);
        return (index + Math.min(Math.max(dateProgress, 0), 1)) * scrubberUnitsPerItem;
      }
    }

    return scrubberMaxValue;
  };

  const timelineTimeFromScroll = () => {
    if (!timelineRail) return timelineFocusStartTime;
    const viewportCenter = timelineRail.scrollLeft + timelineRail.clientWidth / 2;
    const ratio = Math.min(1, Math.max(0, viewportCenter / Math.max(1, timelineAxisWidth())));
    return timelineStartTime + ratio * timelineTimeSpan;
  };

  const timelineValueFromScroll = () => {
    if (!timelineRail) return scrubberValue;
    return scrubberValueFromTimelineTime(timelineTimeFromScroll());
  };

  const scrollTimelineToTime = (time, behavior = "auto") => {
    if (!timelineRail) return;
    const ratio = Math.min(1, Math.max(0, ((Number(time) || timelineStartTime) - timelineStartTime) / timelineTimeSpan));
    const targetLeft = ratio * timelineAxisWidth() - timelineRail.clientWidth / 2;
    syncingTimelineScroll = true;
    timelineRail.scrollTo({
      left: Math.min(Math.max(0, targetLeft), maxTimelineScroll()),
      behavior,
    });
    window.setTimeout(() => {
      syncingTimelineScroll = false;
    }, behavior === "smooth" ? 1100 : 260);
  };

  const centerTimelineDot = (slug, behavior = "smooth") => {
    if (!timelineRail || !slug) return;
    const dot = timelineDots.find((item) => item.getAttribute("data-map-timeline-item") === slug);
    if (!dot) return;
    const railStyle = window.getComputedStyle(timelineRail);
    const railPaddingLeft = parseFloat(railStyle.paddingLeft) || 0;
    const dotCenter = railPaddingLeft + dot.offsetLeft;
    const targetLeft = dotCenter - timelineRail.clientWidth / 2;
    syncingTimelineScroll = true;
    timelineRail.scrollTo({
      left: Math.min(Math.max(0, targetLeft), maxTimelineScroll()),
      behavior,
    });
    window.setTimeout(() => {
      syncingTimelineScroll = false;
    }, behavior === "smooth" ? 1100 : 260);
  };

  const scrollTimelineToValue = (value, behavior = "auto") => {
    const state = scrubberStateFromValue(value);
    scrollTimelineToTime(state?.item?.timelineTime || timelineFocusStartTime, behavior);
  };

  const syncScrubberToItem = (item, coordinate = null, { centerTimeline = true, behavior = "auto" } = {}) => {
    if (!item) return;
    scrubberValue = clampScrubberValue(scrubberValueForSlug(item.slug));
    updateRouteProgressMarker({
      item,
      coordinate: coordinate || coordinateAtProgress(routeCoordinatesForItem(item), 0) || [item.lon, item.lat],
      routeProgress: 0,
      inGap: false,
      pathDistance: pathDistance(routeCoordinatesForItem(item)),
    });
    if (centerTimeline) centerTimelineDot(item.slug, behavior);
  };

  const keepTimelineDotVisible = (slug, behavior = "smooth") => {
    centerTimelineDot(slug, behavior);
  };

  const applyScrubFocus = (item, { centerDot = true } = {}) => {
    if (!item) return false;
    const itemChanged = activeTimelineSlug !== item.slug;
    activeTimelineSlug = item.slug;
    activeStravaActivityId = "";
    updateActiveSummary(item);
    timelineDots.forEach((dot) =>
      dot.classList.toggle("is-active", dot.getAttribute("data-map-timeline-item") === item.slug),
    );
    if (map.getLayer("map-point-highlight")) {
      map.setFilter("map-point-highlight", ["==", ["get", "slug"], item.slug]);
    }
    if (itemChanged) {
      clearScheduledPopup();
      popup.remove();
    }
    updateLayerVisibility();
    if (centerDot && itemChanged) keepTimelineDotVisible(item.slug);
    return itemChanged;
  };

  const scrubZoomForState = (state) => {
    if (!state?.item) return map.getZoom();
    if (state.inGap) return mapElement.clientWidth < 680 ? 3.3 : 4.2;
    if (state.segment?.kind === "strava") return mapElement.clientWidth < 680 ? 9.9 : 10.7;
    if (state.segment?.kind === "race") return mapElement.clientWidth < 680 ? 9.7 : 10.4;
    if (state.item.type === "race") return mapElement.clientWidth < 680 ? 8.8 : 9.6;
    if (state.item.travelMode === "flight") return mapElement.clientWidth < 680 ? 2.5 : 3.1;
    if (state.pathDistance > 1200) return mapElement.clientWidth < 680 ? 4.4 : 5.1;
    return mapElement.clientWidth < 680 ? 5.9 : 6.7;
  };

  const bearingBetweenCoordinates = (start, end) => {
    if (!Array.isArray(start) || !Array.isArray(end)) return map.getBearing();
    const startLat = toRadians(Number(start[1]));
    const endLat = toRadians(Number(end[1]));
    const deltaLon = toRadians(Number(end[0]) - Number(start[0]));
    const y = Math.sin(deltaLon) * Math.cos(endLat);
    const x = Math.cos(startLat) * Math.sin(endLat) - Math.sin(startLat) * Math.cos(endLat) * Math.cos(deltaLon);
    const bearing = (toDegrees(Math.atan2(y, x)) + 360) % 360;
    return Number.isFinite(bearing) ? bearing : map.getBearing();
  };

  const trackCinematicScrubCamera = (state, itemChanged) => {
    if (!state?.coordinate) return;
    const coordinates = state.coordinates?.length ? state.coordinates : routeCoordinatesForItem(state.item);
    const lookAhead = coordinateAtProgress(coordinates, Math.min(1, (state.routeProgress || 0) + 0.045));
    const routeBearing = lookAhead ? bearingBetweenCoordinates(state.coordinate, lookAhead) : map.getBearing();
    const compact = mapElement.clientWidth < 680;
    const segmentBoost = state.segment?.kind === "strava" || state.segment?.kind === "race" ? 0.35 : 0;
    const zoomPulse = Math.sin(Math.min(1, Math.max(0, state.routeProgress || 0)) * Math.PI * 2) * 0.16;
    map.easeTo({
      center: state.coordinate,
      zoom: scrubZoomForState(state) + segmentBoost + zoomPulse,
      bearing: routeBearing,
      pitch: state.inGap ? (compact ? 24 : 32) : state.segment?.kind === "strava" || state.segment?.kind === "race" ? (compact ? 52 : 58) : compact ? 42 : 50,
      offset: compact ? [0, -16] : [0, -26],
      duration: itemChanged ? 860 : 360,
      easing: (time) => 1 - (1 - time) ** 3,
      essential: true,
    });
  };

  const trackScrubCamera = (state, itemChanged, cinematic = false) => {
    if (!state?.coordinate) return;
    if (cinematic) {
      trackCinematicScrubCamera(state, itemChanged);
      return;
    }
    map.easeTo({
      center: state.coordinate,
      zoom: scrubZoomForState(state),
      pitch: state.item?.type === "race" ? (mapElement.clientWidth < 680 ? 34 : 42) : mapElement.clientWidth < 680 ? 28 : 36,
      duration: itemChanged ? 320 : 120,
      essential: true,
    });
  };

  const setScrubberProgress = (value, { trackCamera = false, syncRail = false, centerDot = true, showPopup = false } = {}) => {
    const clampedValue = clampScrubberValue(value);
    scrubberValue = clampedValue;
    const state = scrubberStateFromValue(clampedValue);
    if (!state?.item) return;
    const itemChanged = applyScrubFocus(state.item, { centerDot });
    updateRouteProgressMarker(state);
    if (syncRail && itemChanged) scrollTimelineToValue(clampedValue, "smooth");
    if (showPopup) updatePlaybackSegmentHighlight(state);
    if (trackCamera) trackScrubCamera(state, itemChanged, showPopup && cinematicPlaybackCameraEnabled);
    if (showPopup) showScrubPlaybackPopup(state);
  };

  let timelinePlaybackFrame = 0;
  let timelinePlaybackLastTime = 0;
  let timelinePlaybackActive = false;
  let cinematicPlaybackCameraEnabled = false;
  const timelinePlaybackUnitsPerSecond = 8;

  const renderTimelinePlaybackButton = () => {
    if (!timelinePlayButton) return;
    timelinePlayButton.classList.toggle("is-playing", timelinePlaybackActive);
    timelinePlayButton.setAttribute("aria-pressed", String(timelinePlaybackActive));
    timelinePlayButton.setAttribute("aria-label", timelinePlaybackActive ? "Pause timeline" : "Play timeline");
    if (timelinePlayLabel) timelinePlayLabel.textContent = timelinePlaybackActive ? "Pause" : "Play";
  };

  const renderTimelineCameraButton = () => {
    if (!timelineCameraButton) return;
    timelineCameraButton.classList.toggle("is-active", cinematicPlaybackCameraEnabled);
    timelineCameraButton.setAttribute("aria-pressed", String(cinematicPlaybackCameraEnabled));
    timelineCameraButton.setAttribute("aria-label", cinematicPlaybackCameraEnabled ? "Disable cinematic camera" : "Enable cinematic camera");
    if (timelineCameraLabel) timelineCameraLabel.textContent = cinematicPlaybackCameraEnabled ? "Cinematic" : "Camera";
  };

  const toggleTimelineCamera = () => {
    cinematicPlaybackCameraEnabled = !cinematicPlaybackCameraEnabled;
    renderTimelineCameraButton();
  };

  const stopTimelinePlayback = () => {
    timelinePlaybackActive = false;
    timelinePlaybackLastTime = 0;
    if (timelinePlaybackFrame) window.cancelAnimationFrame(timelinePlaybackFrame);
    timelinePlaybackFrame = 0;
    renderTimelinePlaybackButton();
    updatePlaybackSegmentHighlight(null);
  };

  const runTimelinePlayback = (timestamp) => {
    if (!timelinePlaybackActive) return;
    if (!timelinePlaybackLastTime) timelinePlaybackLastTime = timestamp;
    const elapsedSeconds = Math.min(0.08, Math.max(0, (timestamp - timelinePlaybackLastTime) / 1000));
    timelinePlaybackLastTime = timestamp;
    const nextValue = clampScrubberValue(scrubberValue + elapsedSeconds * timelinePlaybackUnitsPerSecond);
    setScrubberProgress(nextValue, {
      trackCamera: true,
      syncRail: true,
      centerDot: true,
      showPopup: true,
    });
    if (nextValue >= scrubberMaxValue) {
      stopTimelinePlayback();
      return;
    }
    timelinePlaybackFrame = window.requestAnimationFrame(runTimelinePlayback);
  };

  const startTimelinePlayback = () => {
    if (!timelineSequence.length || timelinePlaybackActive) return;
    if (scrubberValue >= scrubberMaxValue - 0.01) scrubberValue = 0;
    timelinePlaybackActive = true;
    timelinePlaybackLastTime = 0;
    renderTimelinePlaybackButton();
    timelinePlaybackFrame = window.requestAnimationFrame(runTimelinePlayback);
  };

  const toggleTimelinePlayback = () => {
    if (timelinePlaybackActive) {
      stopTimelinePlayback();
      return;
    }
    startTimelinePlayback();
  };

  const fitOverview = () => {
    map.easeTo({
      center: mapElement.clientWidth < 680 ? [-90, 28] : [-54, 28],
      zoom: mapElement.clientWidth < 680 ? 0.2 : 0.92,
      bearing: -8,
      pitch: 0,
      duration: 0,
    });
  };

  const selectItem = (slug, shouldScroll = false, preferredCoordinate = null) => {
    const item = allPoints.find((point) => point.slug === slug);
    if (!item) return;

    activeTimelineSlug = slug;
    activeStravaActivityId = "";
    playbackStravaActivityId = "";
    playbackRaceSlug = "";
    updateActiveSummary(item);
    timelineDots.forEach((dot) =>
      dot.classList.toggle("is-active", dot.getAttribute("data-map-timeline-item") === slug),
    );
    if (map.getLayer("map-point-highlight")) {
      map.setFilter("map-point-highlight", ["==", ["get", "slug"], slug]);
    }
    setRouteHighlight(item.type === "trip" ? slug : "");
    setRaceRouteHighlight(item.type === "race" ? slug : "");
    setStravaRouteHighlight("");
    updateLayerVisibility();

    const popupCoordinate = popupCoordinateForItem(item, preferredCoordinate);
    const popupPlacement = routePopupPlacement(popupCoordinate);
    const routeFit =
      item.type === "race" ? fitRaceRoute(item, popupPlacement) : fitTripRoute(item, popupPlacement);
    if (!routeFit) {
      map.flyTo({ center: [item.lon, item.lat], zoom: item.type === "race" ? 4.2 : 4.8, duration: 850 });
    }
    syncScrubberToItem(item, popupCoordinate, { behavior: shouldScroll ? "smooth" : "auto" });
    showPopup(item, popupCoordinate, popupPlacement.anchor, false);
  };

  const clearSelection = () => {
    activeTimelineSlug = "";
    activeStravaActivityId = "";
    playbackStravaActivityId = "";
    playbackRaceSlug = "";
    timelineDots.forEach((dot) => dot.classList.remove("is-active"));
    if (map.getLayer("map-point-highlight")) {
      map.setFilter("map-point-highlight", ["==", ["get", "slug"], ""]);
    }
    setRouteHighlight("");
    setRaceRouteHighlight("");
    setStravaRouteHighlight("");
    clearScheduledPopup();
    popup.remove();
    updateRouteProgressMarker(null);
    updateLayerVisibility();
  };

  const setVisibility = (layerIds, visible) => {
    layerIds.forEach((layerId) => {
      if (map.getLayer(layerId)) map.setLayoutProperty(layerId, "visibility", visible ? "visible" : "none");
    });
  };

  const visibleRouteModesForSlug = (slug) => {
    const features = (tripRouteCollections.routes.features || []).filter((feature) => feature.properties?.slug === slug);
    if (!features.length) return true;
    return features.some((feature) => layerVisibility[feature.properties?.mode || "drive"] !== false);
  };

  const updateLayerVisibility = () => {
    const activeItem = allPoints.find((point) => point.slug === activeTimelineSlug);
    const highlightedRaceSlug = activeItem?.type === "race" ? activeTimelineSlug : playbackRaceSlug;
    const highlightedStravaActivityId = activeStravaActivityId || playbackStravaActivityId;
    setRouteHighlight(activeItem?.type === "trip" ? activeTimelineSlug : "");
    setRaceRouteHighlight(highlightedRaceSlug);
    setMapPointLabelFilter(activeItem);
    setStravaRouteHighlight(highlightedStravaActivityId);

    setVisibility(["trip-routes-flight"], layerVisibility.flight);
    setVisibility(["trip-routes-drive"], layerVisibility.drive);
    setVisibility(["trip-routes-sail"], layerVisibility.sail);
    setVisibility(["trip-routes-train"], layerVisibility.train);
    setVisibility(["trip-route-nodes"], layerVisibility.stop);
    setVisibility(["strava-routes-heat", "strava-routes", "strava-route-highlight-casing", "strava-route-highlight"], layerVisibility.strava);
    setVisibility(["map-points", "map-point-labels"], layerVisibility.race);
    setVisibility(["map-point-highlight"], layerVisibility.race && Boolean(activeTimelineSlug));
    setVisibility(["trip-route-highlight-casing", "trip-route-highlight"], Boolean(activeTimelineSlug) && visibleRouteModesForSlug(activeTimelineSlug));
    setVisibility(["trip-route-node-highlight"], layerVisibility.stop && Boolean(activeTimelineSlug));
    setVisibility(
      ["race-route-highlight-casing", "race-route-highlight"],
      layerVisibility.race && Boolean(highlightedRaceSlug) && raceRouteFeaturesBySlug.has(highlightedRaceSlug),
    );

    layerToggleButtons.forEach((button) => {
      const key = button.getAttribute("data-map-layer-toggle");
      const visible = layerVisibility[key] !== false;
      button.setAttribute("aria-pressed", String(visible));
      button.classList.toggle("is-muted", !visible);
    });
  };

  const updatePlaybackSegmentHighlight = (state = null) => {
    const segment = state?.segment || {};
    playbackStravaActivityId = segment.kind === "strava" ? String(segment.properties?.id || "") : "";
    playbackRaceSlug = segment.kind === "race" ? String(segment.item?.slug || "") : "";
    updateLayerVisibility();
  };

  const bindPointerLayer = (layerId) => {
    map.on("mouseenter", layerId, () => {
      map.getCanvas().style.cursor = "pointer";
    });
    map.on("mouseleave", layerId, () => {
      map.getCanvas().style.cursor = "";
    });
  };

  const interactiveFeatureLayers = () =>
    [
      "map-points",
      "map-point-highlight",
      "trip-routes-flight",
      "trip-routes-drive",
      "trip-routes-sail",
      "trip-routes-train",
      "trip-route-nodes",
      "trip-route-highlight",
      "trip-route-highlight-casing",
      "trip-route-node-highlight",
      "race-route-highlight",
      "race-route-highlight-casing",
      "strava-routes",
      "strava-route-highlight",
      "strava-route-highlight-casing",
      "route-progress-marker",
      "route-progress-marker-halo",
    ].filter((layerId) => map.getLayer(layerId));

  const choiceFromRenderedFeature = (feature) => {
    const layerId = feature?.layer?.id || "";
    const properties = feature?.properties || {};

    if (layerId.startsWith("strava-route") || layerId === "strava-routes") {
      const activityId = properties.id;
      if (!activityId) return null;
      return {
        key: `strava:${activityId}`,
        kind: "strava",
        properties,
      };
    }

    if (layerId.startsWith("race-route")) {
      const race = allPointsBySlug.get(properties.raceSlug);
      return race ? { key: `item:${race.slug}`, kind: "item", item: race } : null;
    }

    if (layerId.startsWith("trip-route") || layerId.startsWith("map-point") || layerId.startsWith("route-progress")) {
      const slug = properties.slug || activeTimelineSlug;
      const item = allPointsBySlug.get(slug);
      return item ? { key: `item:${item.slug}`, kind: "item", item } : null;
    }

    return null;
  };

  const popupChoicesAtPoint = (point) => {
    if (!point) return [];
    const layers = interactiveFeatureLayers();
    if (!layers.length) return [];
    const hitbox = [
      [point.x - 10, point.y - 10],
      [point.x + 10, point.y + 10],
    ];
    const seen = new Set();
    return map
      .queryRenderedFeatures(hitbox, { layers })
      .map(choiceFromRenderedFeature)
      .filter((choice) => {
        if (!choice || seen.has(choice.key)) return false;
        seen.add(choice.key);
        return true;
      });
  };

  const syncPopupChoiceScroll = () => {
    const rail = document.querySelector("[data-popup-stack-rail]");
    const active = document.querySelector(`[data-popup-choice-index="${activePopupChoiceIndex}"]`);
    active?.scrollIntoView?.({ block: "nearest", inline: "center" });
    if (rail && active) rail.setAttribute("aria-activedescendant", `popup-choice-${activePopupChoiceIndex}`);
  };

  const activatePopupChoice = (index, { render = true } = {}) => {
    if (!activePopupChoices.length) return;
    const nextIndex = (index + activePopupChoices.length) % activePopupChoices.length;
    const choice = activePopupChoices[nextIndex];
    activePopupChoiceIndex = nextIndex;

    if (choice.kind === "strava") {
      activeTimelineSlug = "";
      activeStravaActivityId = String(choice.properties.id || "");
      playbackStravaActivityId = "";
      playbackRaceSlug = "";
      timelineDots.forEach((dot) => dot.classList.remove("is-active"));
      if (map.getLayer("map-point-highlight")) {
        map.setFilter("map-point-highlight", ["==", ["get", "slug"], ""]);
      }
      setRouteHighlight("");
      setRaceRouteHighlight("");
      setStravaRouteHighlight(activeStravaActivityId);
      updateRouteProgressMarker(null);
      updateActiveSummary({
        title: choiceTitle(choice),
        date: String(choice.properties.startDate || "").slice(0, 10),
      });
      updateLayerVisibility();
    } else if (choice.item) {
      activeTimelineSlug = choice.item.slug;
      activeStravaActivityId = "";
      playbackStravaActivityId = "";
      playbackRaceSlug = "";
      updateActiveSummary(choice.item);
      timelineDots.forEach((dot) =>
        dot.classList.toggle("is-active", dot.getAttribute("data-map-timeline-item") === choice.item.slug),
      );
      if (map.getLayer("map-point-highlight")) {
        map.setFilter("map-point-highlight", ["==", ["get", "slug"], choice.item.slug]);
      }
      setStravaRouteHighlight("");
      updateLayerVisibility();
      updateRouteProgressMarker({
        item: choice.item,
        coordinate:
          activePopupCoordinate ||
          coordinateAtProgress(routeCoordinatesForItem(choice.item), 0) ||
          [choice.item.lon, choice.item.lat],
        routeProgress: 0,
        inGap: false,
        pathDistance: pathDistance(routeCoordinatesForItem(choice.item)),
      });
      keepTimelineDotVisible(choice.item.slug);
    }

    if (render && popup?.isOpen?.()) {
      popup.setHTML(stackedPopupHtml(activePopupChoices, activePopupChoiceIndex));
      window.requestAnimationFrame(syncPopupChoiceScroll);
    }
  };

  const showStackedPopup = (choices, coordinate, activeIndex = 0) => {
    clearScheduledPopup();
    popup.remove();
    activePopupChoices = choices;
    activePopupChoiceIndex = activeIndex;
    activePopupCoordinate = coordinate;
    activatePopupChoice(activeIndex, { render: false });
    const placement = routePopupPlacement(coordinate);
    popup = createPopup(placement.anchor);
    popup.setLngLat(coordinate).setHTML(stackedPopupHtml(choices, activePopupChoiceIndex)).addTo(map);
    window.requestAnimationFrame(syncPopupChoiceScroll);
  };

