---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/site";
import { getSanityPosts, type SanityPost } from "../../lib/sanity";

export async function getStaticPaths() {
  const posts = await getSanityPosts();
  const paths = posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));

  for (const post of posts) {
    if (
      post.id === "post.canyons-100k-truckee-week" ||
      post.slug === "canyons-100k" ||
      post.slug === "canyons-100k-truckee-week" ||
      post.slug === "canyons-100k-2026"
    ) {
      for (const slug of ["canyons-100k", "canyons-100k-2026", "canyons-100k-truckee-week"]) {
        if (!paths.some((path) => path.params.slug === slug)) {
          paths.push({
            params: { slug },
            props: { post }
          });
        }
      }
      break;
    }
  }

  return paths;
}

interface Props {
  post: SanityPost;
}

const { post } = Astro.props;
if (post.url) {
  return Astro.redirect(post.url);
}

const isTerigoPost = post.slug === "terigo-app-store";
const isCanyonsPost =
  post.id === "post.canyons-100k-truckee-week" ||
  post.slug === "canyons-100k" ||
  post.slug === "canyons-100k-truckee-week" ||
  post.slug === "canyons-100k-2026";
const terigoAppStoreUrl = "https://apps.apple.com/us/app/terigo/id6761634158";
---

<BaseLayout title={post.title} description={post.description} bodyClass={isCanyonsPost ? "canyons-post" : ""}>
  <article class:list={[{ "canyons-article": isCanyonsPost }]}>
    <header class:list={["page-header", { "page-header--terigo": isTerigoPost, "page-header--canyons": isCanyonsPost }]}>
      {
        isTerigoPost ? (
          <>
            <h1 class="sr-only">{post.title}</h1>
            <div class="terigo-page-top">
              <img src="/images/terigo/terigo-logo.png" alt="Terigo" width="1800" height="600" loading="eager" />
              <a href={terigoAppStoreUrl} target="_blank" rel="noreferrer noopener">
                View on the App Store
              </a>
            </div>
          </>
        ) : (
          <h1 class="page-title">{post.title}</h1>
        )
      }
      <p class:list={["page-intro", { "page-intro--terigo": isTerigoPost }]}>
        <time datetime={post.date.toISOString()}>{formatDate(post.date)}</time>
      </p>
    </header>
    <div class="prose">
      <Fragment set:html={post.html} />
    </div>
  </article>
</BaseLayout>

<script>
  import "../../scripts/post-enhancements";
</script>
